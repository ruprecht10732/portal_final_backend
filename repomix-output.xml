                {{ whatsAppToneSuccessMessage() }}
              </p>
            }

            @if (whatsAppToneErrorMessage()) {
              <p class="text-sm font-semibold text-rose-600">
                {{ whatsAppToneErrorMessage() }}
              </p>
            }

            <div class="flex justify-end">
              <shared-button
                variant="primary"
