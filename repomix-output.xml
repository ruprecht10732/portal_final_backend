<file path="../portal_final/src/app/routes/leads/lead-form/lead-form.component.html">
<!-- Main Wrapper: Mobile-first vertical flex -->
<div class="flex flex-col w-full pb-16 sm:pb-0">

  <shared-page-header
    [title]="isNew() ? ('leads.form.newLead' | translate) : ('leads.form.editLead' | translate)"
    [subtitle]="'leads.form.formId' | translate:{status: (isNew() ? ('leads.form.statusNew' | translate) : ('leads.form.statusEdit' | translate))}"
    [backAriaLabel]="'leads.form.goBack' | translate"
    (back)="cancel()"
  ></shared-page-header>

  <!-- Alerts Section: Stacks vertically -->
  @if (error()) {
    <div class="bg-red-50 border-b border-red-500 text-red-900 p-4 text-sm font-medium flex items-start gap-3">
      <span class="font-bold uppercase text-red-600 shrink-0">{{ 'leads.form.errorLabel' | translate }}</span>
      <span>{{ error() }}</span>
    </div>
  }

  @if (duplicateWarning(); as dup) {
    <div class="bg-amber-50 border-b border-amber-400 text-amber-900 p-4 sm:p-6">
      <div class="flex flex-col sm:flex-row gap-4 sm:items-start sm:justify-between">
        <div class="space-y-1">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span class="font-bold uppercase tracking-wide text-xs">{{ 'leads.form.duplicateFound' | translate }}</span>
          </div>
          <p class="text-sm pl-7">
            {{ 'leads.form.duplicateExists' | translate:{phone: dup.consumer.phone, firstName: dup.consumer.firstName, lastName: dup.consumer.lastName} }}
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 sm:items-center pl-7 sm:pl-0">
          <a [routerLink]="['/app/leads', dup.id]" class="text-sm font-bold border-b border-black pb-0.5 hover:text-zinc-600 hover:border-zinc-600 w-max">
            {{ 'leads.form.viewExistingLead' | translate }}
          </a>
          <button type="button" (click)="dismissDuplicateWarning()" class="text-sm text-zinc-500 hover:text-black hover:underline w-max">
            {{ 'leads.form.continueAnyway' | translate }}
          </button>
        </div>
      </div>
    </div>
  }

  <!-- Loading State -->
  @if (loading()) {
    <div class="flex-1 flex flex-col items-center justify-center p-12 gap-4">
      <div class="animate-spin h-10 w-10 border-4 border-zinc-100 border-t-black"></div>
      <p class="text-xs font-mono uppercase text-zinc-400">{{ 'leads.form.loading' | translate }}</p>
    </div>
  } @else {
    <form [formGroup]="form" (ngSubmit)="save()" class="flex-1 flex flex-col">
      
      <!-- Responsive Grid Layout:
           1. Mobile: Single column (stacked)
           2. Tablet (md): 2 Columns (Consumer | Address+Details)
           3. Desktop (xl): 3 Columns (Consumer | Address | Details)
      -->
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 w-full border-b border-zinc-200">
        
        <!-- SECTION 1: Consumer (Left Column) -->
        <section class="p-4 sm:p-6 border-b md:border-b-0 md:border-r border-zinc-200">
          <div class="flex items-center gap-3 mb-6">
            <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">01</span>
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
              {{ 'leads.form.consumerInfo' | translate }}
            </h2>
          </div>
          
          <div class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <shared-input
                [label]="'leads.form.firstName' | translate"
                [value]="form.controls.firstName.value ?? ''"
                (valueChange)="form.controls.firstName.setValue($event)"
                [required]="true"
                [error]="requiredControlError(form.controls.firstName)"
              />
              <shared-input
                [label]="'leads.form.lastName' | translate"
                [value]="form.controls.lastName.value ?? ''"
                (valueChange)="form.controls.lastName.setValue($event)"
                [required]="true"
                [error]="requiredControlError(form.controls.lastName)"
              />
            </div>
            
            <shared-input
              [label]="'leads.form.phone' | translate"
              type="tel"
              [value]="form.controls.phone.value ?? ''"
              (valueChange)="form.controls.phone.setValue($event)"
              (blur)="onPhoneBlur()"
              [required]="true"
              [error]="phoneControlError()"
            />
            
            <shared-input
              [label]="'leads.form.email' | translate"
              type="email"
              [value]="form.controls.email.value ?? ''"
              (valueChange)="form.controls.email.setValue($event)"
            />

            @if (isWhatsAppConfigured()) {
              <shared-checkbox
                [label]="'leads.form.whatsappOptedIn' | translate"
                [hint]="'leads.form.whatsappOptedInHelp' | translate"
                [checked]="form.controls.whatsappOptedIn.value ?? true"
                (checkedChange)="form.controls.whatsappOptedIn.setValue($event)"
              />
            } @else if (whatsAppStatus()) {
              <div class="flex items-start justify-between gap-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
                <div class="flex items-start gap-3">
                  <svg class="h-5 w-5 shrink-0 text-amber-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                  </svg>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-widest text-amber-700">
                      {{ 'leads.form.whatsappNotConfiguredTitle' | translate }}
                    </p>
                    <p class="mt-0.5 text-xs text-amber-700">
                      {{ 'leads.form.whatsappNotConfiguredMessage' | translate }}
                    </p>
                  </div>
                </div>
                <shared-button
                  variant="secondary"
                  type="button"
                  [fullWidth]="false"
                  [uppercase]="false"
                  (clicked)="goToSettings()"
                >
                  {{ 'leads.form.whatsappSetupCta' | translate }}
                </shared-button>
              </div>
            }
            
            <div class="sm:w-2/3">
              <shared-select
                [label]="'leads.form.role' | translate"
                [options]="consumerRoleOptions()"
                [value]="form.controls.consumerRole.value"
                (valueChange)="setConsumerRole($event)"
              />
            </div>
          </div>
        </section>

        <!-- SECTION 2: Address (Middle Column) -->
        <section class="p-4 sm:p-6 border-b xl:border-b-0 xl:border-r border-zinc-200">
          <div class="flex items-center gap-3 mb-6">
            <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">02</span>
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
              {{ 'leads.form.address' | translate }}
            </h2>
          </div>

          <div class="space-y-5">
            <!-- Mobile: Stacked | Desktop: 2/3 + 1/3 split -->
            <div class="grid grid-cols-1 sm:grid-cols-12 gap-4">
              <div class="sm:col-span-8">
                <shared-autocomplete
                  [label]="'leads.form.street' | translate"
                  [value]="form.controls.street.value ?? ''"
                  (valueChange)="onStreetChange($event)"
                  [options]="addressOptions()"
                  [filterMode]="'manual'"
                  [placeholder]="'leads.form.startTyping' | translate"
                  [required]="true"
                  [error]="requiredControlError(form.controls.street)"
                />
              </div>
              <div class="sm:col-span-4">
                <shared-input
                  [label]="'leads.form.houseNumber' | translate"
                  [value]="form.controls.houseNumber.value ?? ''"
                  (valueChange)="onHouseNumberChange($event)"
                  [required]="true"
                  [error]="requiredControlError(form.controls.houseNumber)"
                />
              </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-12 gap-4">
              <div class="sm:col-span-4">
                <shared-input
                  [label]="'leads.form.zipCode' | translate"
                  [value]="form.controls.zipCode.value ?? ''"
                  (valueChange)="onZipCodeChange($event)"
                  [required]="true"
                  [error]="requiredControlError(form.controls.zipCode)"
                />
              </div>
              <div class="sm:col-span-8">
                <shared-input
                  [label]="'leads.form.city' | translate"
                  [value]="form.controls.city.value ?? ''"
                  (valueChange)="onCityChange($event)"
                  [required]="true"
                  [error]="requiredControlError(form.controls.city)"
                />
              </div>
            </div>
          </div>
        </section>

        <!-- SECTION 3: Details (Right Column on XL, Bottom on MD) -->
        <section class="p-4 sm:p-6 md:col-span-2 xl:col-span-1">
          <div class="flex items-center gap-3 mb-6">
            <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">03</span>
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
              {{ 'leads.form.leadDetails' | translate }}
            </h2>
          </div>

          <div class="space-y-5">
            @if (isNew()) {
              <div class="border border-zinc-200 p-4 bg-zinc-50">
                <shared-select
                  [label]="'leads.form.serviceType' | translate"
                  [options]="serviceTypeOptions()"
                  [value]="form.controls.serviceType.value"
                  (valueChange)="setServiceType($event)"
                  [required]="true"
                  [error]="requiredControlError(form.controls.serviceType)"
                />
                <p class="text-xs text-zinc-400 mt-2 font-mono">
                  * {{ 'leads.form.additionalServicesNote' | translate }}
                </p>

                <div class="mt-4">
                  <shared-select
                    [label]="'leads.form.workflowLabel' | translate"
                    [options]="workflowOptions()"
                    [value]="form.controls.workflowId.value"
                    (valueChange)="setWorkflowId($event)"
                    [placeholder]="'leads.form.workflowPlaceholder' | translate"
                  />
                </div>
              </div>
            }

            <shared-input
              [label]="'leads.form.source' | translate"
              [value]="form.controls.source.value ?? ''"
              (valueChange)="onSourceChange($event)"
              [disabled]="!isNew()"
              [max]="sourceMaxLength.toString()"
            />
            
            <shared-textarea
              [label]="'leads.form.consumerNote' | translate"
              [rows]="4"
              [value]="form.controls.consumerNote.value ?? ''"
              (valueChange)="onConsumerNoteChange($event)"
              [disabled]="!isNew()"
            />
          </div>
        </section>
      </div>

      <!-- Footer: Stays at bottom of flow -->
      <div class="p-4 sm:p-6 flex flex-col-reverse sm:flex-row sm:justify-end gap-3 sm:gap-4">
        @if (submitAttempted() && form.invalid) {
          <p class="text-xs font-semibold uppercase tracking-wide text-red-600 sm:mr-auto">
            {{ 'leads.form.validation.required' | translate }}
          </p>
        }
        <shared-button 
          variant="secondary" 
          type="button" 
          (clicked)="cancel()"
          class="w-full sm:w-auto"
        >
          {{ 'leads.form.cancel' | translate }}
        </shared-button>
        
        <shared-button
          variant="primary"
          type="submit"
          class="w-full sm:w-auto"
          [disabled]="form.invalid || saving()"
          [loading]="saving()"
        >
          {{ saving() ? ('leads.form.saving' | translate) : (isNew() ? ('leads.form.createLead' | translate) : ('leads.form.saveChanges' | translate)) }}
        </shared-button>
      </div>
    </form>
  }
</div>
</file>

