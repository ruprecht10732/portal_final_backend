<section class="w-full space-y-6 bg-transparent border-none p-0 sm:bg-white sm:border sm:border-zinc-200 sm:p-6 sm:rounded-sm">
  <!-- Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="space-y-1">
      <h3 class="text-lg font-semibold text-zinc-900">{{ 'webhook.googleLeads.title' | translate }}</h3>
      <p class="text-sm text-zinc-500">{{ 'webhook.googleLeads.subtitle' | translate }}</p>
    </div>
    <shared-button
      variant="primary"
      size="compact"
      [ariaLabel]="'webhook.googleLeads.createConfig' | translate"
      (clicked)="toggleCreateForm()"
    >
      @if (showCreateForm()) {
        {{ 'webhook.googleLeads.cancel' | translate }}
      } @else {
        {{ 'webhook.googleLeads.createConfig' | translate }}
      }
    </shared-button>
  </div>

  <!-- Error -->
  @if (errorMessage()) {
    <div class="border-y border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 sm:border sm:rounded-sm">
      {{ errorMessage() }}
    </div>
  }

  <!-- Success -->
  @if (successMessage()) {
    <div class="border-y border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 sm:border sm:rounded-sm">
      {{ successMessage() }}
    </div>
  }

  <!-- Create Form -->
  @if (showCreateForm()) {
    <div class="border border-zinc-200 rounded-sm p-4 sm:p-6 space-y-4 bg-zinc-50">
      <h4 class="text-sm font-semibold text-zinc-900">{{ 'webhook.googleLeads.newConfig' | translate }}</h4>

      <shared-input
        [label]="'webhook.googleLeads.fields.name' | translate"
        [placeholder]="'webhook.googleLeads.fields.namePlaceholder' | translate"
        [(value)]="newConfigName"
        [required]="true"
      />

      <div class="flex justify-end">
        <shared-button
          variant="primary"
          size="compact"
          [loading]="isSaving()"
          [disabled]="!newConfigName()"
          (clicked)="createConfig()"
        >
          {{ 'webhook.googleLeads.generate' | translate }}
        </shared-button>
      </div>
    </div>
  }

  <!-- Newly Created Config (show once) -->
  @if (createdConfig(); as created) {
    <div class="border border-amber-300 rounded-sm bg-amber-50 p-4 sm:p-6 space-y-5">
      <div class="flex items-start gap-3">
        <lucide-icon name="alert-triangle" class="h-5 w-5 text-amber-600 shrink-0 mt-0.5"></lucide-icon>
        <div class="space-y-1">
          <h4 class="text-sm font-semibold text-amber-900">{{ 'webhook.googleLeads.keyCreated' | translate }}</h4>
          <p class="text-xs text-amber-700">{{ 'webhook.googleLeads.keyCreatedWarning' | translate }}</p>
        </div>
      </div>

      <!-- Google Key -->
      <div class="space-y-2">
        <p class="block text-xs font-medium text-zinc-700">{{ 'webhook.googleLeads.fields.googleKey' | translate }}</p>
        <div class="flex items-center gap-2">
          <code class="flex-1 rounded bg-white border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
            {{ created.googleKey }}
          </code>
          <shared-button
            variant="secondary"
            size="compact"
            [iconOnly]="true"
            shape="square"
            [fullWidth]="false"
            [ariaLabel]="'webhook.googleLeads.copyKey' | translate"
            (clicked)="copyGoogleKey()"
          >
            @if (keyCopied()) {
              <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
            } @else {
              <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
            }
          </shared-button>
        </div>
      </div>

      <!-- Webhook URL -->
      <div class="space-y-2">
        <p class="block text-xs font-medium text-zinc-700">{{ 'webhook.googleLeads.fields.webhookUrl' | translate }}</p>
        <div class="flex items-center gap-2">
          <code class="flex-1 rounded bg-white border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
            {{ created.webhookUrl }}
          </code>
          <shared-button
            variant="secondary"
            size="compact"
            [iconOnly]="true"
            shape="square"
            [fullWidth]="false"
            [ariaLabel]="'webhook.googleLeads.copyUrl' | translate"
            (clicked)="copyWebhookUrl()"
          >
            @if (urlCopied()) {
              <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
            } @else {
              <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
            }
          </shared-button>
        </div>
      </div>

      <!-- Integration Instructions -->
      <div class="space-y-3 border-t border-amber-200 pt-4">
        <h5 class="text-xs font-semibold text-zinc-700 uppercase tracking-wider">{{ 'webhook.googleLeads.instructions.title' | translate }}</h5>
        <ol class="list-decimal list-inside space-y-2 text-sm text-zinc-700">
          <li>{{ 'webhook.googleLeads.instructions.step1' | translate }}</li>
          <li>{{ 'webhook.googleLeads.instructions.step2' | translate }}</li>
          <li>{{ 'webhook.googleLeads.instructions.step3' | translate }}</li>
        </ol>
      </div>

      <div class="flex justify-end">
        <shared-button variant="secondary" size="compact" (clicked)="dismissCreatedConfig()">
          {{ 'webhook.googleLeads.dismiss' | translate }}
        </shared-button>
      </div>
    </div>
  }

  <!-- Loading -->
  @if (isLoading()) {
    <div class="flex items-center justify-center py-12">
      <div class="h-6 w-6 animate-spin rounded-full border-2 border-zinc-300 border-t-zinc-900"></div>
    </div>
  }

  <!-- Active Configs List -->
  @if (!isLoading()) {
    @if (activeConfigs().length === 0) {
      <div class="text-center py-12 space-y-2">
        <lucide-icon name="webhook" class="h-10 w-10 text-zinc-300 mx-auto"></lucide-icon>
        <p class="text-sm text-zinc-500">{{ 'webhook.googleLeads.empty' | translate }}</p>
        <p class="text-xs text-zinc-400">{{ 'webhook.googleLeads.emptyHint' | translate }}</p>
      </div>
    } @else {
      <div class="space-y-3">
        @for (config of activeConfigs(); track config.id) {
          <div class="rounded-sm border border-zinc-200 bg-white p-4 space-y-4">
            <div class="flex flex-col sm:flex-row sm:items-center gap-3">
              <div class="flex items-center gap-3 flex-1 min-w-0">
                <div class="flex h-9 w-9 items-center justify-center rounded-md bg-sky-50 text-sky-600 shrink-0">
                  <lucide-icon name="webhook" class="h-4 w-4"></lucide-icon>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-medium text-zinc-900 truncate">{{ config.name }}</p>
                  <p class="text-xs text-zinc-500">
                    <span class="font-mono">{{ config.googleKeyPrefix }}•••</span>
                    · {{ formatDate(config.createdAt) }}
                  </p>
                </div>
              </div>

              <shared-button
                variant="danger"
                size="compact"
                [fullWidth]="false"
                [disabled]="isSaving()"
                (clicked)="confirmDelete(config)"
              >
                {{ 'webhook.googleLeads.delete' | translate }}
              </shared-button>
            </div>

            <div class="space-y-1">
              <p class="text-xs font-medium text-zinc-600">{{ 'webhook.googleLeads.fields.webhookUrl' | translate }}</p>
              <code class="block rounded bg-zinc-50 border border-zinc-200 px-3 py-2 text-xs font-mono text-zinc-700 break-all">
                {{ googleWebhookUrl() }}
              </code>
            </div>

            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-zinc-700 uppercase tracking-wider">{{ 'webhook.googleLeads.mappingsTitle' | translate }}</p>
              </div>

              @if (mappingEntries(config).length === 0) {
                <p class="text-xs text-zinc-500">{{ 'webhook.googleLeads.mappingsEmpty' | translate }}</p>
              } @else {
                <div class="flex flex-wrap gap-2">
                  @for (mapping of mappingEntries(config); track mapping.campaignId) {
                    <span class="inline-flex items-center gap-2 rounded-full bg-zinc-100 px-2 py-1 text-[11px] text-zinc-600 font-mono">
                      {{ mapping.campaignId }} → {{ mapping.serviceType }}
                      <button
                        type="button"
                        class="inline-flex h-6 w-6 items-center justify-center rounded-full text-zinc-500 transition hover:text-red-600 touch-manipulation"
                        [attr.aria-label]="'webhook.googleLeads.deleteMapping' | translate"
                        (click)="confirmMappingDelete(config.id, mapping.campaignId)"
                      >
                        <lucide-icon name="x" class="h-3 w-3"></lucide-icon>
                      </button>
                    </span>
                  }
                </div>
              }

              <div class="grid gap-3 grid-cols-1 sm:grid-cols-3 sm:items-end">
                <div class="sm:col-span-1">
                  <label
                    class="block text-xs font-medium text-zinc-700 mb-1"
                    [attr.for]="'google-campaign-' + config.id"
                  >
                    {{ 'webhook.googleLeads.fields.campaignId' | translate }}
                  </label>
                  <input
                    [id]="'google-campaign-' + config.id"
                    class="block w-full h-11 rounded-lg border border-zinc-200 bg-white px-3 py-2.5 text-sm text-zinc-900 placeholder:text-zinc-400
                      outline-none transition-all duration-200 ease-out
                      focus:border-zinc-900 focus:ring-2 focus:ring-zinc-900/10"
                    [placeholder]="'webhook.googleLeads.fields.campaignIdPlaceholder' | translate"
                    [value]="getMappingInput(config.id).campaignId"
                    (input)="setMappingCampaignId(config.id, $any($event.target).value)"
                  />
                </div>
                <div class="sm:col-span-1">
                  <label
                    class="block text-xs font-medium text-zinc-700 mb-1"
                    [attr.for]="'google-service-' + config.id"
                  >
                    {{ 'webhook.googleLeads.fields.serviceType' | translate }}
                  </label>
                  <input
                    [id]="'google-service-' + config.id"
                    class="block w-full h-11 rounded-lg border border-zinc-200 bg-white px-3 py-2.5 text-sm text-zinc-900 placeholder:text-zinc-400
                      outline-none transition-all duration-200 ease-out
                      focus:border-zinc-900 focus:ring-2 focus:ring-zinc-900/10"
                    [placeholder]="'webhook.googleLeads.fields.serviceTypePlaceholder' | translate"
                    [value]="getMappingInput(config.id).serviceType"
                    (input)="setMappingServiceType(config.id, $any($event.target).value)"
                  />
                </div>
                <div class="sm:col-span-1">
                  <shared-button
                    variant="secondary"
                    size="compact"
                    [fullWidth]="true"
                    [disabled]="isSaving()"
                    (clicked)="addMapping(config)"
                  >
                    {{ 'webhook.googleLeads.addMapping' | translate }}
                  </shared-button>
                </div>
              </div>
            </div>
          </div>
        }
      </div>
    }
  }
</section>

<!-- Delete Confirm Dialog -->
<shared-confirm-dialog
  [isOpen]="showDeleteDialog()"
  [title]="'webhook.googleLeads.deleteConfirm.title' | translate"
  [message]="'webhook.googleLeads.deleteConfirm.message' | translate"
  [confirmText]="'webhook.googleLeads.deleteConfirm.confirm' | translate"
  [cancelText]="'webhook.googleLeads.deleteConfirm.cancel' | translate"
  confirmVariant="danger"
  (confirm)="executeDelete()"
  (cancelled)="cancelDelete()"
/>

<!-- Mapping Delete Confirm Dialog -->
<shared-confirm-dialog
  [isOpen]="showMappingDeleteDialog()"
  [title]="'webhook.googleLeads.deleteMappingConfirm.title' | translate"
  [message]="'webhook.googleLeads.deleteMappingConfirm.message' | translate"
  [confirmText]="'webhook.googleLeads.deleteMappingConfirm.confirm' | translate"
  [cancelText]="'webhook.googleLeads.deleteMappingConfirm.cancel' | translate"
  confirmVariant="danger"
  (confirm)="executeMappingDelete()"
  (cancelled)="cancelMappingDelete()"
/>
