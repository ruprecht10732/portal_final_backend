                        <option value="fixed">{{ 'catalog.products.pricing.fixed' | translate }}</option>
                        <option value="unit">{{ 'catalog.products.pricing.unit' | translate }}</option>
                      </select>
                    </label>

                    @if (row.priceType === 'fixed') {
                      <label class="text-xs font-semibold uppercase tracking-wide text-zinc-600 md:col-span-2">
                        {{ 'catalog.products.fields.price' | translate }}
