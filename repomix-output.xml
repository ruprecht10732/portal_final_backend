              @if (q.status === 'Accepted' || q.status === 'Rejected' || q.status === 'Expired') {
                <div class="px-4 mb-6">
                  <app-quote-status-banner
                    [status]="q.status"
                    [acceptedAt]="q.acceptedAt ?? null"
                    [downloading]="downloadingPdf()"
                    [variant]="'mobile'"
                    (download)="downloadPdf()"
                  />
