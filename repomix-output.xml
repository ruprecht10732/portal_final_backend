                <p class="mt-1 text-xs text-amber-700">{{ 'webhook.keyCreatedWarning' | translate }}</p>
              </div>

              <div class="space-y-2">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-zinc-500">
                  {{ 'webhook.fields.apiKey' | translate }}
