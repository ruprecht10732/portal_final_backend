          #filterTrigger
          type="button"
          class="inline-flex items-center gap-2 rounded-lg border bg-white px-3 py-2 text-sm font-medium text-zinc-700 transition-all hover:bg-zinc-50 focus:outline-none focus:border-black"
          [class.border-black]="showFilters()"
          [class.border-zinc-200]="!showFilters()"
          [attr.aria-expanded]="showFilters()"
          aria-haspopup="true"
          [attr.aria-controls]="'filter-panel'"
          (click)="toggleFilters()"
        >
          <svg class="w-4 h-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
          </svg>
          <span>{{ 'dataGrid.addFilter' | translate }}</span>
          <svg class="w-4 h-4 text-zinc-400 transition-transform" [class.rotate-180]="showFilters()" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <!-- Filter popover via CDK Overlay -->
        <ng-template
          cdkConnectedOverlay
          [cdkConnectedOverlayOrigin]="filterOrigin"
          [cdkConnectedOverlayOpen]="showFilters()"
          (overlayOutsideClick)="closeFilters()"
          (detach)="closeFilters()"
        >
          <div 
            id="filter-panel"
            class="w-80 rounded-xl border border-zinc-200 bg-white mt-2"
          >
            <div class="p-4">
              @if (!activeFilterColumn()) {
                <!-- Column selection -->
                <div class="space-y-3">
                  <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500">
                    {{ 'dataGrid.selectColumn' | translate }}
                  </p>
                  <div class="grid gap-1">
                    @for (col of filterableColumns(); track col.id) {
                      <button
                        type="button"
                        class="flex items-center gap-3 w-full rounded-lg px-3 py-2.5 text-left text-sm font-medium text-zinc-700 transition-colors hover:bg-zinc-100 focus:outline-none focus:bg-zinc-100"
                        (click)="selectFilterColumn(col.id)"
                      >
                        <span class="flex-1">{{ col.header }}</span>
                        <svg class="w-4 h-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </button>
                    }
                  </div>
                </div>
              } @else {
                <!-- Filter value input -->
                <div class="space-y-4">
                  <div class="flex items-center justify-between">
                    <button
                      type="button"
                      class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-500 hover:text-zinc-700 transition-colors"
                      (click)="activeFilterColumn.set(null)"
                    >
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                      </svg>
                      {{ 'dataGrid.back' | translate }}
                    </button>
                  </div>
                  
                  <div class="space-y-2">
                    <span class="block text-sm font-semibold text-zinc-900">
                      {{ activeFilterColumnData()?.header }}
                    </span>
                    @if (activeFilterUiConfig().inputType === 'select') {
                      <shared-select
                        [options]="activeFilterUiConfig().options ?? []"
                        [value]="filterValue()"
                        (valueChange)="filterValue.set($event ?? '')"
                        [placeholder]="'dataGrid.selectOption' | translate"
                        [ariaLabel]="'dataGrid.filterValueFor' | translate:{column: activeFilterColumnData()?.header}"
                      />
                    } @else {
                      <shared-input
                        [value]="filterValue()"
                        (valueChange)="filterValue.set($event)"
                        (keydown.enter)="applyFilter()"
                        [placeholder]="'dataGrid.enterValue' | translate"
                        [ariaLabel]="'dataGrid.filterValueFor' | translate:{column: activeFilterColumnData()?.header}"
                      />
                    }
                  </div>

                  <shared-button
                    variant="primary"
                    [fullWidth]="true"
                    [disabled]="!filterValue().trim()"
                    (clicked)="applyFilter()"
                  >
                    {{ 'dataGrid.apply' | translate }}
                  </shared-button>
                </div>
              }
            </div>
          </div>
        </ng-template>
      </div>
    }

    <!-- Spacer -->
    <div class="flex-1"></div>

    <!-- Column picker -->
    @if (columnPickerEnabled() && allColumns().length > 0) {
      <div cdkOverlayOrigin #columnPickerOrigin="cdkOverlayOrigin">
        <button
          #columnPickerTrigger
          type="button"
          class="inline-flex items-center gap-2 rounded-lg border bg-white px-3 py-2 text-sm font-medium text-zinc-700 transition-all hover:bg-zinc-50 focus:outline-none focus:border-black"
          [class.border-black]="showColumnPicker()"
          [class.border-zinc-200]="!showColumnPicker()"
          [attr.aria-expanded]="showColumnPicker()"
          aria-haspopup="true"
          [attr.aria-label]="'dataGrid.toggleColumnVisibility' | translate"
          (click)="toggleColumnPicker()"
        >
          <svg class="w-4 h-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
          </svg>
          <span>{{ 'dataGrid.columns' | translate }}</span>
        </button>

        <ng-template
          cdkConnectedOverlay
          [cdkConnectedOverlayOrigin]="columnPickerOrigin"
          [cdkConnectedOverlayOpen]="showColumnPicker()"
          (overlayOutsideClick)="closeColumnPicker()"
          (detach)="closeColumnPicker()"
        >
          <div class="w-64 max-h-[calc(100vh-200px)] overflow-y-auto rounded-xl border border-zinc-200 bg-white mt-2">
            <div class="sticky top-0 bg-white px-4 py-3 border-b border-zinc-100">
              <span class="text-xs font-semibold uppercase tracking-wider text-zinc-500">
                {{ 'dataGrid.showHideColumns' | translate }}
              </span>
            </div>
            <div class="p-2 space-y-0.5">
              @for (column of allColumns(); track column.id) {
                <div class="flex items-center gap-3 px-2 py-1.5 rounded-lg hover:bg-zinc-50 transition-colors">
                  <shared-checkbox
                    [checked]="isColumnVisible(column)"
                    (checkedChange)="onColumnVisibilityToggle(column.id)"
                    [label]="column.header"
                    class="flex-1"
                  />
                  @if (column.frozen) {
                    <svg class="w-3.5 h-3.5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" [attr.title]="'dataGrid.frozen' | translate">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                  }
                </div>
              }
            </div>
          </div>
        </ng-template>
      </div>
    }

    <!-- Action buttons -->
    @if (hasDirtyRows() || hasSelection()) {
      <div class="h-6 w-px bg-zinc-200"></div>
      
      <div class="flex items-center gap-2">
        @if (hasDirtyRows()) {
          <shared-button
            variant="ghost"
            size="compact"
            [fullWidth]="false"
            [ariaLabel]="'dataGrid.cancelChanges' | translate"
            (clicked)="onCancel()"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            {{ 'dataGrid.cancel' | translate }}
          </shared-button>

          <shared-button
            variant="primary"
            size="default"
            [fullWidth]="false"
            [disabled]="!isOnline()"
            [ariaLabel]="isOnline() ? ('dataGrid.saveChanges' | translate) : ('dataGrid.cannotSaveOffline' | translate)"
            (clicked)="onSave()"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {{ 'dataGrid.save' | translate }}
          </shared-button>
        }

        @if (hasSelection()) {
          <shared-button
            variant="danger"
            size="compact"
            [fullWidth]="false"
            [ariaLabel]="'dataGrid.deleteSelected' | translate:{count: selectedCount()}"
            (clicked)="onDelete()"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
            {{ 'dataGrid.delete' | translate }}
          </shared-button>
        }
      </div>
    }
  </div>

  <!-- Active filters row -->
  @if (filters().length > 0) {
    <div class="flex items-center gap-2 flex-wrap">
      <span class="text-xs font-medium text-zinc-500 uppercase tracking-wide">{{ 'dataGrid.activeFilters' | translate }}:</span>
      @for (filter of filters(); track filter.columnId) {
        <span class="group inline-flex items-center gap-1.5 rounded-full bg-zinc-900 pl-3 pr-1.5 py-1 text-xs font-medium text-white">
          <span class="text-zinc-400">{{ columns() | columnLabel:filter.columnId }}</span>
          <span class="text-white">{{ filter.value }}</span>
          <button 
            type="button"
            class="ml-0.5 flex h-5 w-5 items-center justify-center rounded-full text-zinc-400 transition-colors hover:bg-white/20 hover:text-white focus:outline-none"
            [attr.aria-label]="'dataGrid.removeFilter' | translate:{column: (columns() | columnLabel:filter.columnId)}"
            (click)="removeFilter(filter.columnId)"
          >
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </span>
      }
      <button
        type="button"
        class="text-xs font-medium text-zinc-500 hover:text-zinc-900 underline underline-offset-2 transition-colors"
        (click)="onClearAll()"
      >
        {{ 'dataGrid.clearAll' | translate }}
      </button>
    </div>
  }
</div>

