            <span class="text-right text-[9px] font-black uppercase tracking-widest text-zinc-400">{{ 'offertes.form.unitPrice' | translate }}</span>
            <span class="text-right text-[9px] font-black uppercase tracking-widest text-zinc-400">{{ 'offertes.tax' | translate }}</span>
            <span class="text-right text-[9px] font-black uppercase tracking-widest text-zinc-400">{{ 'offertes.total' | translate }}</span>
            <span class="text-center text-[9px] font-black uppercase tracking-widest text-zinc-400">{{ 'offertes.optional' | translate }}</span>
