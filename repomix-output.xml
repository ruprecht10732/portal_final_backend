<!-- Selection checkbox column (always frozen if present) -->
@if (selectable()) {
  <th
    role="columnheader"
    scope="col"
    tabindex="-1"
    [attr.aria-colindex]="1"
    class="w-10 px-0 py-2 sticky left-0 z-20 bg-black text-white border-b border-r border-zinc-200 focus:outline-none focus:ring-2 focus:ring-white focus:ring-inset"
  >
    <div class="flex w-full min-h-7 items-center justify-center">
      <shared-checkbox
        #headerCheckbox
        [checked]="allSelected()"
        [indeterminate]="partiallySelected()"
        [ariaLabel]="'dataGrid.selectAllRows' | translate"
        [dense]="true"
        (checkedChange)="onSelectAll()"
      />
    </div>
  </th>
}

<!-- Data columns -->
@for (column of columns(); track column.id; let colIndex = $index) {
  @let sortDirection = getSortDirection(column.id);
  <th
    #thCell
    role="columnheader"
    scope="col"
    tabindex="-1"
    [attr.aria-colindex]="getAriaColIndex(colIndex)"
    [attr.aria-sort]="column.sortable ? (sortDirection === 'asc' ? 'ascending' : sortDirection === 'desc' ? 'descending' : 'none') : null"
    class="relative px-2 py-2 text-xs font-semibold uppercase tracking-wide text-left text-white border-b border-zinc-200 bg-black focus:outline-none focus:ring-2 focus:ring-white focus:ring-inset"
    [class.border-r]="colIndex !== columns().length - 1"
    [class.border-r-0]="colIndex === columns().length - 1"
    [class.sticky]="column.frozen"
    [class.z-20]="column.frozen"
    [class.shadow-[2px_0_4px_-2px_rgba(0,0,0,0.1)]]="column.frozen"
    [style.width]="column.width"
    [style.min-width]="column.minWidth ?? '80px'"
    [style.max-width]="column.maxWidth"
    [style.left]="column.frozen ? getFrozenColumnLeft(colIndex) : null"
    [class.text-center]="column.align === 'center'"
    [class.text-right]="column.align === 'right'"
  >
    @if (column.sortable) {
      <button
        type="button"
        (click)="onSort(column)"
        class="flex items-center justify-between gap-2 w-full focus:outline-none"
        [attr.aria-label]="getSortAriaLabel(column)"
      >
        <span class="truncate" [title]="column.header">{{ column.header }}</span>
        <span 
          class="flex items-center justify-center w-4 h-4 text-white"
          aria-hidden="true"
        >
          @if (sortDirection === 'asc') {
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
            </svg>
          } @else if (sortDirection === 'desc') {
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          } @else {
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
            </svg>
          }
        </span>
      </button>
    } @else {
      <span class="block truncate" [title]="column.header">{{ column.header }}</span>
    }
    
    <!-- Resize handle -->
    <div
      class="absolute top-0 right-0 w-1 h-full cursor-col-resize z-10 hover:bg-zinc-400 active:bg-zinc-500"
      (mousedown)="onResizeStart($event, colIndex, thCell)"
      aria-hidden="true"
    ></div>
  </th>
}
