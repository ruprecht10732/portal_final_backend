<div class="flex flex-col h-full">
  <shared-page-header
    [title]="'offertes.partnerOffer.title' | translate"
    [subtitle]="'offertes.partnerOffer.subtitle' | translate"
    [backAriaLabel]="'offertes.goBack' | translate"
    (back)="goBack()"
  />

  @if (error()) {
    <div class="px-4 sm:px-6">
      <div role="alert" aria-live="assertive" class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-sm">
        {{ error() }}
      </div>
    </div>
  }

  @if (loading()) {
    <div class="flex-1 flex items-center justify-center p-12">
      <div class="h-10 w-10 rounded-full border-[3px] border-indigo-100 border-t-indigo-600 animate-spin"></div>
    </div>
  } @else if (quote(); as q) {
    <div class="flex-1 overflow-y-auto px-4 sm:px-6 pb-8">
      <shared-card>
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <p class="text-xs text-zinc-500">{{ 'offertes.partnerOffer.quoteLabel' | translate }}</p>
            <p class="text-sm font-semibold">#{{ q.quoteNumber }}</p>
          </div>

          <div class="rounded-lg border border-zinc-200 bg-zinc-50 px-3 py-2 text-sm">
            <span class="text-zinc-600">{{ 'offertes.partnerOffer.totalLabel' | translate }}:</span>
            <span class="font-semibold text-zinc-900 ml-1">{{ formatEuroCents(q.totalCents) }}</span>
          </div>

          @if (q.status !== 'Accepted') {
            <div class="text-sm text-amber-700">
              {{ 'offertes.partnerOffer.notAccepted' | translate }}
            </div>
          }
          @if (!q.leadServiceId) {
            <div class="text-sm text-amber-700">
              {{ 'offertes.partnerOffer.noService' | translate }}
            </div>
          }

          <shared-autocomplete
            [label]="'offertes.partnerOffer.searchLabel' | translate"
            [placeholder]="'offertes.partnerOffer.searchPlaceholder' | translate"
            [value]="partnerSearch()"
            (valueChange)="onPartnerSearchChange($event); onPartnerSelected($event)"
            [options]="partnerOptions()"
            filterMode="manual"
            [disabled]="partnerSearchLoading()"
            [hint]="partnerSearchLoading() ? ('common.loading' | translate) : ''"
          />

          @if (partnerSearchError()) {
            <div class="text-sm text-red-600">{{ partnerSearchError() }}</div>
          }

          <div class="flex flex-wrap gap-2">
            <shared-button
              variant="ghost"
              [fullWidth]="false"
              [disabled]="partnerSearchLoading()"
              (clicked)="clearPartnerSearch()"
            >
              {{ 'common.reset' | translate }}
            </shared-button>
          </div>

          <shared-number-input
            [label]="'offertes.partnerOffer.expiryHoursLabel' | translate"
            [value]="expiresInHours()"
            (valueChange)="expiresInHours.set($event ?? 12)"
            [min]="1"
            [max]="12"
            [step]="1"
            [suffix]="'u'"
          />

          @if (offerError()) {
            <div class="text-sm text-red-600">{{ offerError() }}</div>
          }

          <div class="flex flex-wrap gap-2">
            <shared-button
              variant="primary"
              [fullWidth]="false"
              [loading]="offerCreating()"
              [disabled]="!canCreateOffer()"
              (clicked)="createOffer()"
            >
              {{ 'offertes.partnerOffer.createOffer' | translate }}
            </shared-button>
            <shared-button
              variant="ghost"
              [fullWidth]="false"
              [disabled]="offerCreating() || !selectedPartnerId()"
              (clicked)="linkPartnerToLead()"
            >
              {{ 'offertes.partnerOffer.linkPartner' | translate }}
            </shared-button>
          </div>

          @if (offerAcceptanceUrl()) {
            <div class="rounded-lg border border-zinc-200 bg-white p-3 text-sm">
              <p class="text-zinc-600">{{ 'offertes.partnerOffer.offerLinkLabel' | translate }}</p>
              <a class="text-indigo-600 font-semibold break-all" [href]="offerAcceptanceUrl()" target="_blank" rel="noopener">
                {{ offerAcceptanceUrl() }}
              </a>
              <div class="mt-2">
                <shared-button
                  variant="ghost"
                  [fullWidth]="false"
                  [disabled]="!selectedPartner()"
                  (clicked)="openWhatsApp()"
                >
                  {{ 'offertes.partnerOffer.openWhatsApp' | translate }}
                </shared-button>
              </div>
            </div>
          }
        </div>
      </shared-card>
    </div>
  }
</div>
