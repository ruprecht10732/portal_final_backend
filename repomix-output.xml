<section class="w-full space-y-6 bg-transparent border-none p-0 sm:bg-white sm:border sm:border-zinc-200 sm:p-6 sm:rounded-sm">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
    <div class="space-y-1">
      <h3 class="text-lg font-semibold text-zinc-900">{{ title() }}</h3>
      <p class="text-sm text-zinc-500">{{ subtitle() }}</p>
    </div>
    <a class="inline-flex min-h-11 items-center text-xs uppercase tracking-widest font-semibold text-zinc-500 hover:text-zinc-900 sm:shrink-0" [routerLink]="listLink()">
      {{ listLinkLabel() }}
    </a>
  </div>

  @if (errorMessage()) {
    <div class="border-y border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 sm:border sm:rounded-sm">
      {{ errorMessage() }}
    </div>
  }

  @if (successMessage()) {
    <div class="border border-emerald-200 bg-emerald-50 px-4 py-3 text-xs uppercase tracking-widest font-semibold text-emerald-700">
      {{ successMessage() }}
    </div>
  }

  @if (isLoading()) {
    <div class="flex items-center justify-center py-8">
      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-black"></div>
    </div>
  } @else {
    <form class="space-y-4" (submit)="onSubmit($event)">
      <shared-input
        [label]="'organization.invite.emailLabel' | translate"
        [value]="email()"
        (valueChange)="emailChange.emit($event)"
        [error]="emailError()"
        [required]="true"
      />

