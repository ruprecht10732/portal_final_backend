            <button type="button" (click)="clearQuery()"
                class="absolute right-3.5 flex h-6 w-6 items-center justify-center rounded-full text-zinc-400 transition-colors hover:bg-zinc-100 hover:text-zinc-600"
                aria-label="Zoekopdracht wissen">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
            }
        </div>

        <!-- Hint / error -->
        @if (error()) {
        <p class="mt-2 text-xs text-red-500">{{ error()! | translate }}</p>
        } @else if (showMinCharsHint()) {
        <p class="mt-2 text-xs text-zinc-400">{{ 'search.minChars' | translate }}</p>
        }

        <!-- Filters -->
        <div class="mt-3 flex flex-wrap gap-2 px-6">
            @for (chip of typeChips(); track chip.value) {
            <button type="button" (click)="setSelectedType(chip.value)" class="rounded-full border px-3 py-1 text-xs transition"
                [class.border-zinc-200]="selectedType() !== chip.value" [class.text-zinc-500]="selectedType() !== chip.value"
                [class.hover:bg-zinc-50]="selectedType() !== chip.value"
                [class.border-zinc-900]="selectedType() === chip.value" [class.bg-zinc-900]="selectedType() === chip.value"
                [class.text-white]="selectedType() === chip.value">
                {{ chip.labelKey | translate }}
            </button>
            }
        </div>

        <!-- Content -->
        <div class="mt-6 flex-1 overflow-y-auto px-6">

            @if (showRecent()) {
            <!-- Recent header -->
            <div class="mb-3 flex items-center justify-between">
                <span class="text-base font-semibold text-zinc-900">{{ 'search.recent' | translate }}</span>
                <button type="button" (click)="clearAllRecent()"
                    class="text-sm text-zinc-400 transition-colors hover:text-zinc-600">
                    {{ 'search.clearAll' | translate }}
                </button>
            </div>
            <!-- Plain divider list -->
            <ul>
                @for (item of recentSearches(); track item.query) {
                <li class="border-b border-zinc-100 last:border-0">
                    <button type="button" (click)="onRecentClick(item.query)"
                        class="group flex w-full items-center justify-between py-3.5 text-left">
                        <span class="truncate text-sm text-zinc-800">{{ item.query }}</span>
                        <span class="ml-4 shrink-0 text-sm text-zinc-400">{{ formatDate(item.date) }}</span>
                    </button>
                </li>
                }
            </ul>

            } @else if (isLoading()) {
            <ul>
                @for (_ of [0, 1, 2, 3, 4, 5]; track $index) {
                <li class="border-b border-zinc-100 py-3.5 last:border-0">
                    <div class="flex items-center justify-between">
                        <shared-skeleton width="55%" height="0.875rem" />
                        <shared-skeleton width="3rem" height="0.875rem" />
                    </div>
                </li>
                }
            </ul>

            } @else if (showNoResults()) {
            <div class="flex flex-col items-center justify-center gap-2 py-16 text-center">
                <svg class="h-8 w-8 text-zinc-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                    stroke-width="1.5">
                    <circle cx="11" cy="11" r="8" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35" />
                </svg>
                <p class="text-sm text-zinc-400">{{ 'search.noResults' | translate }}</p>
                <p class="text-xs text-zinc-300">"{{ trimmedQuery() }}"</p>
            </div>

            } @else if (items().length > 0) {
            <p class="mb-1 text-sm text-zinc-400">
                {{ items().length }} {{ 'search.resultsFor' | translate }} "<span class="font-medium text-zinc-600">{{
                    trimmedQuery() }}</span>"
            </p>
            @for (section of sections(); track section.type; let first = $first) {
            <div class="mt-2" [class.mt-6]="!first">
                <div class="mb-2 flex items-center justify-between">
                    <span class="text-sm font-semibold text-zinc-900">{{ sectionLabelKey(section.type) | translate
                        }}:</span>
                </div>

                <ul>
                    @for (item of section.items; track item.id + ':' + item.type) {
                    <li class="border-b border-zinc-100 last:border-0">
                        <a class="group flex items-center gap-3 py-3 transition-colors hover:opacity-80 focus-visible:outline-none"
                            [routerLink]="buildLink(item)" (click)="onResultClick()" [attr.aria-label]="item.title">
                            <!-- Type icon badge -->
                            <span
                                class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-zinc-100 text-zinc-400">
                                @switch (item.type) {
                                @case ('lead') {
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    stroke-width="1.75">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                                </svg>
                                }
                                @case ('quote') {
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    stroke-width="1.75">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                                </svg>
                                }
                                @case ('appointment') {
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    stroke-width="1.75">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                                </svg>
                                }
                                @case ('partner') {
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    stroke-width="1.75">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
                                </svg>
                                }
                                @case ('catalog_product') {
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    stroke-width="1.75">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="M20.25 7.5l-8.25-4.5-8.25 4.5m16.5 0l-8.25 4.5m8.25-4.5v9l-8.25 4.5m0-9L3.75 7.5m8.25 4.5v9m0 0l-8.25-4.5v-9" />
                                </svg>
                                }
                                @case ('service_type') {
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                    stroke-width="1.75">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="M10.5 6h9.75M10.5 12h9.75M10.5 18h9.75M3.75 6h.008v.008H3.75V6zm0 6h.008v.008H3.75V12zm0 6h.008v.008H3.75V18z" />
                                </svg>
                                }
                                }
                            </span>
                            <!-- Text -->
                            <div class="min-w-0 flex-1">
                                <p class="truncate text-sm font-medium text-zinc-900">{{ item.title }}</p>
                                <p class="mt-0.5 truncate text-xs text-zinc-500">{{ item.preview || item.subtitle }}</p>
                            </div>
                            <!-- Type label -->
                            <span class="shrink-0 text-xs text-zinc-400">{{ typeLabelKey(item.type) | translate }}</span>
                        </a>
                    </li>
                    }
                </ul>
            </div>
            }
            }

        </div>
    </div>
</shared-page-layout>
