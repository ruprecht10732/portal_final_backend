/* Quote Proposal - public page styles */

:host ::ng-deep .signature-frame .signature-pad-wrapper {
	position: relative;
	align-items: stretch;
	gap: 0;
	padding: 0;
}

:host ::ng-deep .signature-frame .signature-canvas {
	display: block;
	border: 1px solid #e4e4e7;
	border-radius: 1rem;
	background: #ffffff;
	height: 180px;
}

:host ::ng-deep .signature-frame .clear-btn {
	display: none;
}

/* ── Rich-text (Quill HTML output) styling ──────────────────────────── */

:host ::ng-deep .rich-text p {
	margin-bottom: 0.5em;
}

:host ::ng-deep .rich-text p:last-child {
	margin-bottom: 0;
}

:host ::ng-deep .rich-text strong,
:host ::ng-deep .rich-text b {
	font-weight: 700;
}

:host ::ng-deep .rich-text em,
:host ::ng-deep .rich-text i {
	font-style: italic;
}

:host ::ng-deep .rich-text u {
	text-decoration: underline;
}

:host ::ng-deep .rich-text s {
	text-decoration: line-through;
}

:host ::ng-deep .rich-text a {
	color: #2563eb;
	text-decoration: underline;
}

:host ::ng-deep .rich-text ul,
:host ::ng-deep .rich-text ol {
	padding-left: 1.5em;
	margin-top: 0.25em;
	margin-bottom: 0.5em;
}

:host ::ng-deep .rich-text ul {
	list-style-type: disc;
}

:host ::ng-deep .rich-text ol {
	list-style-type: decimal;
}

:host ::ng-deep .rich-text li {
	margin-bottom: 0.15em;
}

:host ::ng-deep .rich-text blockquote {
	border-left: 3px solid #d1d5db;
	padding-left: 0.75em;
	margin: 0.5em 0;
	color: #6b7280;
	font-style: italic;
}

:host ::ng-deep .rich-text h1 {
	font-size: 1.5em;
	font-weight: 700;
	margin-bottom: 0.5em;
}

:host ::ng-deep .rich-text h2 {
	font-size: 1.25em;
	font-weight: 700;
	margin-bottom: 0.4em;
}

:host ::ng-deep .rich-text h3 {
	font-size: 1.1em;
	font-weight: 600;
	margin-bottom: 0.3em;
}

:host ::ng-deep .rich-text br {
	content: '';
	display: block;
	margin-top: 0.25em;
}

/* Quill indent classes */
:host ::ng-deep .rich-text .ql-indent-1 { padding-left: 1.5em; }
:host ::ng-deep .rich-text .ql-indent-2 { padding-left: 3em; }
:host ::ng-deep .rich-text .ql-indent-3 { padding-left: 4.5em; }

/* Quill alignment classes */
:host ::ng-deep .rich-text .ql-align-center { text-align: center; }
:host ::ng-deep .rich-text .ql-align-right { text-align: right; }
:host ::ng-deep .rich-text .ql-align-justify { text-align: justify; }

/* --- Bulletproof Rich Text Layout Constraints --- */

:host ::ng-deep .rich-text {
	overflow-wrap: break-word;
	word-wrap: break-word;
	word-break: normal;
	-webkit-hyphens: none;
	hyphens: none;
	/* Prevent the container itself from expanding */
	max-width: 100%;
}

/* Force all descendants to respect the max-width */
:host ::ng-deep .rich-text * {
	max-width: 100% !important;
}

/* Ensure images and videos scale proportionally */
:host ::ng-deep .rich-text img,
:host ::ng-deep .rich-text video,
:host ::ng-deep .rich-text iframe {
	height: auto !important;
	border-radius: 0.5rem;
}

/* Force tables to become horizontally scrollable rather than breaking the page width */
:host ::ng-deep .rich-text table {
	display: block !important;
	width: 100% !important;
	overflow-x: auto !important;
	-webkit-overflow-scrolling: touch;
	border-collapse: collapse;
	margin-bottom: 0.5rem;
}

/* Force preformatted text and code blocks to wrap instead of overflowing */
:host ::ng-deep .rich-text pre,
:host ::ng-deep .rich-text code {
	white-space: pre-wrap !important;
	word-break: break-word !important;
}
