<file path="../portal_final/src/app/routes/offertes/offertes-pricing-intelligence/offertes-pricing-intelligence.component.html">
<div class="min-h-full bg-zinc-50">
  <shared-page-header
    [title]="'offertes.pricingIntelligence.screenTitle' | translate"
    [subtitle]="'offertes.pricingIntelligence.screenSubtitle' | translate"
    [backAriaLabel]="'offertes.goBack' | translate"
    (back)="goBack()"
  >
    <div actions class="flex items-center gap-2">
      <shared-button
        variant="secondary"
        size="compact"
        [fullWidth]="false"
        [disabled]="!hasQuery()"
        [loading]="loading()"
        (clicked)="refresh()"
      >
        <lucide-icon name="refresh-cw" class="h-4 w-4"></lucide-icon>
        {{ 'offertes.pricingIntelligence.refresh' | translate }}
      </shared-button>
    </div>
  </shared-page-header>

  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <section class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm sm:p-6">
      <div class="grid gap-4 lg:grid-cols-[minmax(0,1.3fr)_180px_auto] lg:items-end">
        <shared-input
          [label]="'offertes.pricingIntelligence.serviceFilter' | translate"
          [hint]="'offertes.pricingIntelligence.serviceFilterHint' | translate"
          [value]="serviceTypeInput()"
          (valueChange)="serviceTypeInput.set($event)"
        />

        <shared-input
          [label]="'offertes.pricingIntelligence.postcodeFilter' | translate"
          [hint]="'offertes.pricingIntelligence.postcodeFilterHint' | translate"
          [value]="postcodePrefixInput()"
          (valueChange)="postcodePrefixInput.set($event)"
        />

        <div class="flex gap-2 lg:justify-end">
          <shared-button
            variant="secondary"
            size="compact"
            [fullWidth]="false"
            (clicked)="clearFilters()"
          >
            {{ 'offertes.pricingIntelligence.clearFilters' | translate }}
          </shared-button>

          <shared-button
            variant="primary"
            size="compact"
            [fullWidth]="false"
            [disabled]="!serviceTypeInput().trim()"
            (clicked)="applyFilters()"
          >
            <lucide-icon name="search" class="h-4 w-4"></lucide-icon>
            {{ 'offertes.pricingIntelligence.applyFilters' | translate }}
          </shared-button>
        </div>
      </div>
    </section>

    @if (!hasQuery()) {
      <section class="mt-6 rounded-2xl border border-dashed border-zinc-300 bg-white px-6 py-10 text-center shadow-sm">
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-zinc-100 text-zinc-500">
          <lucide-icon name="chart-column" class="h-6 w-6"></lucide-icon>
        </div>
        <h2 class="mt-4 text-lg font-semibold text-zinc-900">{{ 'offertes.pricingIntelligence.emptyTitle' | translate }}</h2>
        <p class="mt-2 text-sm text-zinc-600">{{ 'offertes.pricingIntelligence.emptyBody' | translate }}</p>
      </section>
    } @else {
      @if (error()) {
        <section class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700 shadow-sm">
          {{ error() }}
        </section>
      }

      @if (loading()) {
        <section class="mt-6 grid gap-4 lg:grid-cols-4">
          @for (_ of [1, 2, 3, 4]; track $index) {
            <div class="h-28 animate-pulse rounded-2xl border border-zinc-200 bg-white"></div>
          }
        </section>
      } @else if (summary(); as report) {
        <section class="mt-6 grid gap-4 lg:grid-cols-4">
          <article class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
            <p class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.serviceLabel' | translate }}</p>
            <p class="mt-3 text-lg font-semibold text-zinc-900">{{ report.serviceType }}</p>
          </article>

          <article class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
            <p class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.regionLabel' | translate }}</p>
            <p class="mt-3 text-lg font-semibold text-zinc-900">{{ report.regionPrefix || ('offertes.pricingIntelligence.allRegions' | translate) }}</p>
          </article>

          <article class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
            <p class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.sampleCount' | translate }}</p>
            <p class="mt-3 text-3xl font-black tracking-tight text-zinc-900">{{ totalSamples() }}</p>
          </article>

          <article class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
            <p class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.averageQuoted' | translate }}</p>
            <p class="mt-3 text-3xl font-black tracking-tight text-zinc-900">{{ formatCurrency(weightedAverageQuotedCents()) }}</p>
          </article>
        </section>

        <section class="mt-6 rounded-2xl border border-zinc-200 bg-white shadow-sm">
          <div class="flex items-center justify-between border-b border-zinc-100 px-5 py-4">
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.aggregatesTitle' | translate }}</p>
              <p class="mt-1 text-sm text-zinc-600">{{ 'offertes.pricingIntelligence.aggregatesSubtitle' | translate }}</p>
            </div>
            <div class="flex gap-2 text-xs font-semibold text-zinc-600">
              <span>{{ acceptedTotal() }} {{ 'offertes.pricingIntelligence.acceptedCount' | translate }}</span>
              <span>·</span>
              <span>{{ rejectedTotal() }} {{ 'offertes.pricingIntelligence.rejectedCount' | translate }}</span>
            </div>
          </div>

          @if (sortedAggregates().length > 0) {
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-zinc-100">
                <thead class="bg-zinc-50">
                  <tr>
                    <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.priceBand' | translate }}</th>
                    <th class="px-5 py-3 text-left text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.regionLabel' | translate }}</th>
                    <th class="px-5 py-3 text-right text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.sampleCount' | translate }}</th>
                    <th class="px-5 py-3 text-right text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.acceptedCount' | translate }}</th>
                    <th class="px-5 py-3 text-right text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.rejectedCount' | translate }}</th>
                    <th class="px-5 py-3 text-right text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.conversionRate' | translate }}</th>
                    <th class="px-5 py-3 text-right text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.averageQuoted' | translate }}</th>
                    <th class="px-5 py-3 text-right text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.averageOutcome' | translate }}</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100 bg-white">
                  @for (aggregate of sortedAggregates(); track trackAggregate($index, aggregate)) {
                    <tr>
                      <td class="px-5 py-3 text-sm font-semibold text-zinc-900">{{ aggregate.priceBand }}</td>
                      <td class="px-5 py-3 text-sm text-zinc-600">{{ aggregate.regionPrefix || ('offertes.pricingIntelligence.allRegions' | translate) }}</td>
                      <td class="px-5 py-3 text-right text-sm tabular-nums text-zinc-700">{{ aggregate.sampleCount }}</td>
                      <td class="px-5 py-3 text-right text-sm tabular-nums text-zinc-700">{{ aggregate.acceptedCount }}</td>
                      <td class="px-5 py-3 text-right text-sm tabular-nums text-zinc-700">{{ aggregate.rejectedCount }}</td>
                      <td class="px-5 py-3 text-right text-sm tabular-nums text-zinc-700">{{ formatPercent(aggregate.conversionRate) }}</td>
                      <td class="px-5 py-3 text-right text-sm tabular-nums text-zinc-700">{{ formatCurrency(aggregate.averageQuotedCents) }}</td>
                      <td class="px-5 py-3 text-right text-sm tabular-nums text-zinc-700">
                        {{ aggregate.averageOutcomeCents != null ? formatCurrency(aggregate.averageOutcomeCents) : '—' }}
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          } @else {
            <div class="px-5 py-8 text-sm text-zinc-600">{{ 'offertes.pricingIntelligence.noData' | translate }}</div>
          }
        </section>

        @if (records(); as data) {
          <section class="mt-6 grid gap-6 xl:grid-cols-3">
            <article class="rounded-2xl border border-zinc-200 bg-white shadow-sm">
              <div class="border-b border-zinc-100 px-5 py-4">
                <p class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.snapshotsTitle' | translate }}</p>
              </div>
              @if (data.snapshots.length > 0) {
                <div class="divide-y divide-zinc-100">
                  @for (snapshot of data.snapshots; track trackSnapshot($index, snapshot)) {
                    <button type="button" class="block w-full px-5 py-4 text-left transition hover:bg-zinc-50" (click)="openQuote(snapshot.quoteId)">
                      <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                          <p class="text-sm font-semibold text-zinc-900">{{ snapshot.priceBand }}</p>
                          <p class="mt-1 text-xs text-zinc-500">{{ snapshot.sourceType }} · {{ 'offertes.pricingIntelligence.quoteRevision' | translate }} {{ snapshot.quoteRevision }}</p>
                        </div>
                        <div class="text-right">
                          <p class="text-sm font-semibold tabular-nums text-zinc-900">{{ formatCurrency(snapshot.totalCents) }}</p>
                          <p class="mt-1 text-xs text-zinc-500">{{ snapshot.createdAt | date:'short' }}</p>
                        </div>
                      </div>
                    </button>
                  }
                </div>
              } @else {
                <div class="px-5 py-8 text-sm text-zinc-600">{{ 'offertes.pricingIntelligence.noRecords' | translate }}</div>
              }
            </article>

            <article class="rounded-2xl border border-zinc-200 bg-white shadow-sm">
              <div class="border-b border-zinc-100 px-5 py-4">
                <p class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.outcomesTitle' | translate }}</p>
              </div>
              @if (data.outcomes.length > 0) {
                <div class="divide-y divide-zinc-100">
                  @for (outcome of data.outcomes; track trackOutcome($index, outcome)) {
                    <button type="button" class="block w-full px-5 py-4 text-left transition hover:bg-zinc-50" (click)="openQuote(outcome.quoteId)">
                      <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                          <p class="text-sm font-semibold text-zinc-900">{{ outcome.outcomeType }}</p>
                          <p class="mt-1 text-xs text-zinc-500">{{ outcome.priceBand }} · {{ outcome.regionPrefix || ('offertes.pricingIntelligence.allRegions' | translate) }}</p>
                          @if (outcome.reason) {
                            <p class="mt-2 text-xs leading-relaxed text-zinc-600">{{ outcome.reason }}</p>
                          }
                        </div>
                        <div class="text-right">
                          <p class="text-sm font-semibold tabular-nums text-zinc-900">
                            {{ outcome.finalTotalCents != null ? formatCurrency(outcome.finalTotalCents) : '—' }}
                          </p>
                          <p class="mt-1 text-xs text-zinc-500">{{ outcome.createdAt | date:'short' }}</p>
                        </div>
                      </div>
                    </button>
                  }
                </div>
              } @else {
                <div class="px-5 py-8 text-sm text-zinc-600">{{ 'offertes.pricingIntelligence.noRecords' | translate }}</div>
              }
            </article>

            <article class="rounded-2xl border border-zinc-200 bg-white shadow-sm">
              <div class="border-b border-zinc-100 px-5 py-4">
                <p class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.pricingIntelligence.correctionsTitle' | translate }}</p>
              </div>
              @if (data.corrections.length > 0) {
                <div class="divide-y divide-zinc-100">
                  @for (correction of data.corrections; track trackCorrection($index, correction)) {
                    <button type="button" class="block w-full px-5 py-4 text-left transition hover:bg-zinc-50" (click)="openQuote(correction.quoteId)">
                      <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                          <p class="text-sm font-semibold text-zinc-900">{{ correction.fieldName }}</p>
                          <p class="mt-1 text-xs text-zinc-500">{{ correction.priceBand }} · {{ correction.regionPrefix || ('offertes.pricingIntelligence.allRegions' | translate) }}</p>
                          @if (correction.reason) {
                            <p class="mt-2 text-xs leading-relaxed text-zinc-600">{{ correction.reason }}</p>
                          }
                          @if (correction.aiFindingCode) {
                            <p class="mt-1 text-[11px] font-medium text-zinc-500">{{ correction.aiFindingCode }}</p>
                          }
                        </div>
                        <div class="text-right">
                          <p class="text-sm font-semibold tabular-nums text-zinc-900">{{ formatDelta(correction) }}</p>
                          <p class="mt-1 text-xs text-zinc-500">{{ correction.createdAt | date:'short' }}</p>
                        </div>
                      </div>
                    </button>
                  }
                </div>
              } @else {
                <div class="px-5 py-8 text-sm text-zinc-600">{{ 'offertes.pricingIntelligence.noRecords' | translate }}</div>
              }
            </article>
          </section>
        }
      }
    }
  </div>
</div>
