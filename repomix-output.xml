<section class="h-full w-full bg-white sm:rounded-xl sm:border sm:border-zinc-200 overflow-hidden flex flex-col">

  <div class="group relative w-full bg-zinc-100">
    <div class="relative aspect-video w-full overflow-hidden sm:h-64">
      
      <div class="absolute inset-0 flex items-center justify-center text-zinc-300">
        <lucide-icon name="image" class="h-10 w-10 opacity-20"></lucide-icon>
      </div>

      @if (heroImageUrl()) {
        <div
          class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105"
          [style.background-image]="'url(' + heroImageUrl() + ')'"
          aria-hidden="true"
        ></div>
      }

      @if (getActiveHero()) {
        <div class="absolute right-3 top-3 flex gap-2 transition-opacity duration-200 sm:opacity-0 sm:group-hover:opacity-100">
          <button
            class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-md hover:bg-black/60 transition-colors"
            (click)="onPreviewHeroImage()(getActiveHero()!.id)"
          >
            <lucide-icon name="eye" class="h-4 w-4"></lucide-icon>
          </button>
          <button
            class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-red-500/80 text-white backdrop-blur-md hover:bg-red-600 transition-colors"
            (click)="onDeleteHeroImage()(getActiveHero()!.id)"
          >
            <lucide-icon name="trash-2" class="h-4 w-4"></lucide-icon>
          </button>
        </div>
      }

      <div class="absolute bottom-0 left-0 w-full p-5">
        <h3 class="text-xl font-bold leading-tight text-white sm:text-2xl">
          {{ product().title }}
        </h3>
      </div>
    </div>
  </div>

  <div class="flex-1 overflow-y-auto bg-white p-5">
    
    @if (heroImages().length > 0) {
      <div class="mb-6 flex gap-3 overflow-x-auto pb-2 scrollbar-hide mask-fade-right">
        @for (image of heroImages(); track image.id) {
          <button
            type="button"
            class="relative h-14 w-14 shrink-0 overflow-hidden rounded-lg border transition-all hover:opacity-100 focus:ring-2 focus:ring-blue-500"
            [class.border-blue-500]="image.url === heroImageUrl()"
            [class.border-zinc-200]="image.url !== heroImageUrl()"
            [class.opacity-100]="image.url === heroImageUrl()"
            [class.opacity-60]="image.url !== heroImageUrl()"
            (click)="onSelectHeroImage()(image.url)"
          >
            <img [src]="image.url" class="h-full w-full object-cover" alt="" />
          </button>
        }
      </div>
    }

    @if (product().description) {
      <div class="mb-6">
        <h4 class="mb-2 text-xs font-bold uppercase tracking-wider text-zinc-400">
          {{ 'catalog.products.fields.description' | translate }}
        </h4>
        <div class="text-sm leading-relaxed text-zinc-600 whitespace-pre-wrap" [innerHTML]="renderDescription(product().description)"></div>
      </div>
    }

    <div>
      <h4 class="mb-3 text-sm font-bold text-zinc-900">Details</h4>
      <div class="divide-y divide-zinc-100 border-t border-b border-zinc-100">
        @for (row of detailsRows(); track row.labelKey) {
          <div class="group flex items-center justify-between py-3.5 gap-4">
            
            <span class="shrink-0 text-sm font-medium text-zinc-500">
               {{ row.labelKey | translate }}
            </span>

            <div class="flex min-w-0 flex-1 justify-end">
              @switch (row.valueType) {
                
                @case ('vatSelect') {
                  <select
                    class="block w-full max-w-35 rounded-md border-0 bg-zinc-50 py-1.5 pl-3 pr-8 text-right text-sm text-zinc-900 ring-1 ring-inset ring-zinc-200 focus:ring-2 focus:ring-blue-500 sm:text-sm sm:leading-6"
                    (change)="onVatRateChange()($any($event.target).value)"
                  >
                    @for (rate of vatRates(); track rate.id) {
                      <option [value]="rate.id" [selected]="rate.id === selectedVatRateId()">{{ rate.name }} ({{ rate.rateBps / 100 }}%)</option>
                    }
                  </select>
                }

                @case ('typeSelect') {
                   <select
                    class="block w-full max-w-35 rounded-md border-0 bg-zinc-50 py-1.5 pl-3 pr-8 text-right text-sm text-zinc-900 ring-1 ring-inset ring-zinc-200 focus:ring-2 focus:ring-blue-500 sm:text-sm sm:leading-6"
                    (change)="onTypeChange()($any($event.target).value)"
                  >
                    @for (option of typeOptions(); track option.value) {
                      <option [value]="option.value" [selected]="option.value === selectedType()">{{ option.label }}</option>
                    }
                  </select>
                }

                @case ('chip') {
                  <shared-chip [variant]="row.variant || 'default'" size="sm">
                    {{ row.value | translate }}
                  </shared-chip>
                }

                @default {
                   <div class="relative flex w-full items-center justify-end gap-2">
                    @if (row.editable && editingField() === row.key) {
                      <div class="flex flex-1 items-center justify-end gap-2 animate-in fade-in zoom-in-95">
                        <input
                          class="w-full max-w-30 rounded-md border-0 py-1.5 text-right text-sm text-zinc-900 ring-1 ring-inset ring-blue-300 placeholder:text-zinc-400 focus:ring-2 focus:ring-inset focus:ring-blue-500"
                          [type]="row.valueType === 'price' ? 'number' : 'text'"
                          [value]="row.valueType === 'price' ? editPrice() : (row.key === 'title' ? editTitle() : editReference())"
                          (input)="row.valueType === 'price' 
                            ? editPrice.set($any($event.target).value) 
                            : (row.key === 'title' ? editTitle.set($any($event.target).value) : editReference.set($any($event.target).value))"
                        />
                        <button class="min-h-11 min-w-11 flex items-center justify-center text-green-600 hover:text-green-700 touch-manipulation" (click)="saveEdit(row.key)">
                          <lucide-icon name="check" class="h-4 w-4"></lucide-icon>
                        </button>
                         <button class="min-h-11 min-w-11 flex items-center justify-center text-zinc-400 hover:text-zinc-500 touch-manipulation" (click)="cancelEdit()">
                          <lucide-icon name="x" class="h-4 w-4"></lucide-icon>
                        </button>
                      </div>
                    } @else {
                      <span class="truncate text-sm font-medium text-zinc-900">
                        {{ row.value }}
                      </span>
                      @if (row.editable) {
                        <button
                          class="ml-2 inline-flex h-9 w-9 items-center justify-center text-zinc-400 hover:text-blue-600 transition-opacity sm:opacity-0 sm:group-hover:opacity-100 touch-manipulation"
                          (click)="startEdit(row.key)"
                        >
                          <lucide-icon name="pencil" class="h-3.5 w-3.5"></lucide-icon>
                        </button>
                      }
                    }
                  </div>
                }
              }
            </div>
          </div>
        }
      </div>
    </div>
  </div>
</section>
