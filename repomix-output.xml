<section>
  @if (assetsError()) {
    <div role="alert" class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-sm">
      {{ assetsError() }}
    </div>
  }

  @if (assetsLoading()) {
    <div class="flex items-center justify-center p-6">
      <div class="animate-spin h-6 w-6 border-4 border-zinc-200 border-t-black rounded-full"></div>
    </div>
  } @else if (assetsCount() === 0) {
    <div class="border border-dashed border-zinc-300 p-6 text-center">
      <h3 class="mt-3 text-sm font-semibold text-zinc-900">{{ 'catalog.products.assets.empty' | translate }}</h3>
      <p class="mt-1 text-xs text-zinc-500">{{ 'catalog.products.assets.emptyHint' | translate }}</p>
    </div>
  } @else {
    <div class="space-y-4">
      @for (section of assetSections(); track section.key) {
        <div>
          <div class="flex items-center justify-between gap-3 mb-2">
            <h3 class="text-sm font-semibold text-black uppercase tracking-wide">
              {{ section.titleKey | translate }}
            </h3>
            <div class="flex items-center gap-2">
              <shared-chip variant="info">
                {{ section.assets.length }} {{ getCountKey(section, section.assets.length) | translate }}
              </shared-chip>
              <shared-button
                type="button"
                variant="ghost"
                size="compact"
                [iconOnly]="true"
                [fullWidth]="false"
                [disabled]="assetsLoading()"
                [ariaLabel]="section.addLabelKey | translate"
                [tooltip]="section.addLabelKey | translate"
                (clicked)="toggleAddSection(section.key)"
              >
                <lucide-icon name="plus" class="h-4 w-4" aria-hidden="true"></lucide-icon>
              </shared-button>
            </div>
          </div>
          @if (addOpen() === section.key) {
            <div class="mb-3">
              @switch (section.key) {
                @case ('images') {
                  <app-file-uploader
                    [label]="'catalog.products.assets.selectImage' | translate"
                    [dropLabel]="'common.upload.dropHint' | translate"
                    [accept]="'image/*'"
                    [multiple]="true"
                    [buttonLabel]="'catalog.products.assets.uploadImage' | translate"
                    [uploadingLabel]="'catalog.products.assets.uploading' | translate"
                    [errorFallback]="'catalog.products.errors.uploadAsset' | translate"
                    [disabled]="assetsLoading() || imageUploading()"
                    [presign]="presignImageAsset()"
                    [finalize]="finalizeImageAsset()"
                    (uploaded)="handleUploaded($any($event))"
                    (uploadError)="onAssetError()($event)"
                    (uploadingChange)="imageUploading.set($event)"
                  />
                }
                @case ('documents') {
                  <app-file-uploader
                    [label]="'catalog.products.assets.selectDocument' | translate"
                    [dropLabel]="'common.upload.dropHint' | translate"
                    [accept]="'application/pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.csv,.txt'"
                    [multiple]="true"
                    [buttonLabel]="'catalog.products.assets.uploadDocument' | translate"
                    [uploadingLabel]="'catalog.products.assets.uploading' | translate"
                    [errorFallback]="'catalog.products.errors.uploadAsset' | translate"
                    [disabled]="assetsLoading() || documentUploading()"
                    [presign]="presignDocumentAsset()"
                    [finalize]="finalizeDocumentAsset()"
                    (uploaded)="handleUploaded($any($event))"
                    (uploadError)="onAssetError()($event)"
                    (uploadingChange)="documentUploading.set($event)"
                  />
                }
                @case ('terms') {
                  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                    <label class="flex flex-col gap-2 text-sm font-medium">
                      {{ 'catalog.products.assets.termsUrl' | translate }}
                      <input
                        type="url"
                        class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                        [value]="termsUrl()"
                        (input)="termsUrl.set($any($event.target).value)"
                        placeholder="https://..."
                      />
                    </label>
                    <label class="flex flex-col gap-2 text-sm font-medium">
                      {{ 'catalog.products.assets.termsLabel' | translate }}
                      <input
                        type="text"
                        class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                        [value]="termsLabel()"
                        (input)="termsLabel.set($any($event.target).value)"
                        placeholder="{{ 'catalog.products.assets.optionalLabel' | translate }}"
                      />
                    </label>
                  </div>
                  <div class="flex justify-end mt-3">
                    <shared-button
                      variant="secondary"
                      size="compact"
                      [uppercase]="false"
                      [fullWidth]="false"
                      [disabled]="!termsUrl().trim() || termsSubmitting() || assetsLoading()"
                      (clicked)="submitTermsUrl()"
                    >
                      {{ 'catalog.products.assets.addTerms' | translate }}
                    </shared-button>
                  </div>
                }
              }
            </div>
          }
          @if (section.assets.length === 0) {
            <p class="text-xs text-zinc-500">{{ section.emptyKey | translate }}</p>
          } @else {
            <div class="flex flex-col gap-1.5">
              @for (asset of section.assets; track asset.id) {
                <div class="flex items-center justify-between gap-3 rounded-[10px] border border-zinc-200 bg-white px-2.5 py-2 text-sm transition-colors hover:border-zinc-300 hover:bg-zinc-100">
                  <span
                    class="flex min-w-0 items-center"
                    [class.gap-3]="section.showThumbnail"
                    [class.gap-2]="!section.showThumbnail"
                  >
                    @if (section.showThumbnail) {
                      <span class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-md border border-zinc-200 bg-white shrink-0">
                        @if (imagePreviewUrls()[asset.id]) {
                          <img
                            class="h-full w-full object-cover rounded"
                            [src]="imagePreviewUrls()[asset.id]"
                            [alt]="getAssetLabel(asset)"
                            loading="lazy"
                          />
                        } @else {
                          <lucide-icon
                            [name]="section.iconName"
                            class="h-4 w-4 text-zinc-400"
                            aria-hidden="true"
                          ></lucide-icon>
                        }
                      </span>
                    } @else {
                      <span class="flex h-8 w-8 items-center justify-center rounded-md border border-zinc-200 bg-white shrink-0">
                        <lucide-icon
                          [name]="section.key === 'documents' ? getDocumentIcon(asset) : section.iconName"
                          class="h-4 w-4 text-zinc-400"
                          aria-hidden="true"
                        ></lucide-icon>
                      </span>
                    }
                    <span class="flex min-w-0 flex-col gap-0.5">
                      <span class="text-sm text-slate-900 truncate">{{ getAssetLabel(asset) }}</span>
                      @if (section.subtitleMode === 'fileSize') {
                        <span class="flex items-center gap-1.5 text-xs text-zinc-500">
                          {{ getAssetExtension(asset) || section.extensionFallback }}
                          <span class="text-zinc-400">•</span>
                          {{ formatFileSize()(asset.sizeBytes) }}
                        </span>
                      }
                      @if (section.showUrl && asset.url) {
                        <span class="text-xs text-blue-500 break-all underline">{{ asset.url }}</span>
                      }
                    </span>
                  </span>
                  <div class="inline-flex items-center gap-1.5 shrink-0">
                    <button
                      type="button"
                      class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-zinc-200 bg-white text-zinc-500 transition-colors hover:border-zinc-300 hover:text-zinc-900 hover:bg-zinc-100 touch-manipulation"
                      (click)="previewAsset()(asset)"
                      [attr.aria-label]="section.previewLabel"
                    >
                      <lucide-icon [name]="section.actionIcon" class="h-4 w-4" aria-hidden="true"></lucide-icon>
                    </button>
                    @if (section.showDownload) {
                      <button
                        type="button"
                        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-zinc-200 bg-white text-zinc-500 transition-colors hover:border-zinc-300 hover:text-zinc-900 hover:bg-zinc-100 touch-manipulation"
                        (click)="downloadAsset()(asset)"
                        aria-label="Download"
                      >
                        <lucide-icon name="download" class="h-4 w-4" aria-hidden="true"></lucide-icon>
                      </button>
                    }
                    <button
                      type="button"
                      class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-red-200 bg-white text-red-600 transition-colors hover:border-red-300 hover:text-red-700 touch-manipulation"
                      (click)="deleteAsset()(asset)"
                      aria-label="Delete"
                    >
                      <lucide-icon name="trash-2" class="h-4 w-4" aria-hidden="true"></lucide-icon>
                    </button>
                  </div>
                </div>
              }
            </div>
          }
        </div>
      }
    </div>
  }
</section>
