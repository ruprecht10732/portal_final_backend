<file path="../portal_final/src/app/routes/organization/google-ads-export/google-ads-export.component.html">
<section class="w-full space-y-6 bg-transparent border-none p-0 sm:bg-white sm:border sm:border-zinc-200 sm:p-6 sm:rounded-sm">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="space-y-1">
      <h3 class="text-lg font-semibold text-zinc-900">{{ 'googleAds.title' | translate }}</h3>
      <p class="text-sm text-zinc-500">{{ 'googleAds.subtitle' | translate }}</p>
    </div>
    <shared-button
      variant="primary"
      size="compact"
      [loading]="isSaving()"
      [ariaLabel]="(hasCredential() ? 'googleAds.rotateCredentials' : 'googleAds.createCredentials') | translate"
      (clicked)="generateOrRotateCredential()"
    >
      @if (hasCredential()) {
        {{ 'googleAds.rotateCredentials' | translate }}
      } @else {
        {{ 'googleAds.createCredentials' | translate }}
      }
    </shared-button>
  </div>

  @if (errorMessage()) {
    <div class="border-y border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 sm:border sm:rounded-sm">
      {{ errorMessage() }}
    </div>
  }

  @if (successMessage()) {
    <div class="border-y border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 sm:border sm:rounded-sm">
      {{ successMessage() }}
    </div>
  }

  @if (generatedCredential(); as generated) {
    <div class="border border-amber-300 rounded-sm bg-amber-50 p-4 sm:p-6 space-y-5">
      <div class="flex items-start gap-3">
        <lucide-icon name="alert-triangle" class="h-5 w-5 text-amber-600 shrink-0 mt-0.5"></lucide-icon>
        <div class="space-y-1">
          <h4 class="text-sm font-semibold text-amber-900">{{ 'googleAds.credentialsCreated' | translate }}</h4>
          <p class="text-xs text-amber-700">{{ 'googleAds.credentialsCreatedWarning' | translate }}</p>
        </div>
      </div>

      <div class="space-y-2">
        <p class="block text-xs font-medium text-zinc-700">{{ 'googleAds.fields.password' | translate }}</p>
        <div class="flex items-center gap-2">
          <code class="flex-1 rounded bg-white border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
            {{ generated.password }}
          </code>
          <shared-button
            variant="secondary"
            size="compact"
            [iconOnly]="true"
            shape="square"
            [fullWidth]="false"
            [ariaLabel]="'googleAds.copyPassword' | translate"
            (clicked)="copyPassword()"
          >
            @if (passwordCopied()) {
              <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
            } @else {
              <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
            }
          </shared-button>
        </div>
      </div>

      <div class="space-y-2">
        <p class="block text-xs font-medium text-zinc-700">{{ 'googleAds.fields.url' | translate }}</p>
        <div class="flex items-center gap-2">
          <code class="flex-1 rounded bg-white border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
            {{ exportUrl() }}
          </code>
          <shared-button
            variant="secondary"
            size="compact"
            [iconOnly]="true"
            shape="square"
            [fullWidth]="false"
            [ariaLabel]="'googleAds.copyUrl' | translate"
            (clicked)="copyExportUrl()"
          >
            @if (urlCopied()) {
              <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
            } @else {
              <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
            }
          </shared-button>
        </div>
      </div>

      <div class="space-y-3 border-t border-amber-200 pt-4">
        <h5 class="text-xs font-semibold text-zinc-700 uppercase tracking-wider">{{ 'googleAds.instructions.title' | translate }}</h5>
        <ol class="list-decimal list-inside space-y-2 text-sm text-zinc-700">
          <li>{{ 'googleAds.instructions.step1' | translate }}</li>
          <li>{{ 'googleAds.instructions.step2' | translate }}</li>
          <li>{{ 'googleAds.instructions.step3' | translate }}</li>
          <li>{{ 'googleAds.instructions.step4' | translate }}</li>
        </ol>
      </div>

      <div class="flex justify-end">
        <shared-button variant="secondary" size="compact" (clicked)="dismissGeneratedCredential()">
          {{ 'googleAds.dismiss' | translate }}
        </shared-button>
      </div>
    </div>
  }

  @if (isLoading()) {
    <div class="flex items-center justify-center py-12">
      <div class="h-6 w-6 animate-spin rounded-full border-2 border-zinc-300 border-t-zinc-900"></div>
    </div>
  }

  @if (!isLoading()) {
    @if (!hasCredential()) {
      <div class="text-center py-12 space-y-2">
        <lucide-icon name="shield-check" class="h-10 w-10 text-zinc-300 mx-auto"></lucide-icon>
        <p class="text-sm text-zinc-500">{{ 'googleAds.emptyCredentials' | translate }}</p>
        <p class="text-xs text-zinc-400">{{ 'googleAds.emptyCredentialsHint' | translate }}</p>
      </div>
    } @else {
      @if (credential(); as credential) {
        <div class="space-y-5 border border-zinc-200 rounded-sm p-4 sm:p-6 bg-white">
          <div class="space-y-2">
            <p class="block text-xs font-medium text-zinc-700">{{ 'googleAds.fields.username' | translate }}</p>
            <div class="flex items-center gap-2">
              <code class="flex-1 rounded bg-zinc-50 border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
                {{ credential.username }}
              </code>
              <shared-button
                variant="secondary"
                size="compact"
                [iconOnly]="true"
                shape="square"
                [fullWidth]="false"
                [ariaLabel]="'googleAds.copyUsername' | translate"
                (clicked)="copyUsername()"
              >
                @if (usernameCopied()) {
                  <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
                } @else {
                  <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
                }
              </shared-button>
            </div>
          </div>

          <div class="space-y-2">
            <p class="block text-xs font-medium text-zinc-700">{{ 'googleAds.fields.password' | translate }}</p>
            <div class="flex items-center gap-2">
              <code class="flex-1 rounded bg-zinc-50 border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
                @if (revealedPassword(); as password) {
                  {{ password }}
                } @else {
                  ••••••••••••••••
                }
              </code>
              <shared-button
                variant="secondary"
                size="compact"
                [iconOnly]="true"
                shape="square"
                [fullWidth]="false"
                [loading]="isRevealingPassword()"
                [disabled]="isSaving()"
                [ariaLabel]="(revealedPassword() ? 'googleAds.hidePassword' : 'googleAds.revealPassword') | translate"
                (clicked)="togglePasswordReveal()"
              >
                @if (revealedPassword()) {
                  <lucide-icon name="eye-off" class="h-4 w-4"></lucide-icon>
                } @else {
                  <lucide-icon name="eye" class="h-4 w-4"></lucide-icon>
                }
              </shared-button>

              <shared-button
                variant="secondary"
                size="compact"
                [iconOnly]="true"
                shape="square"
                [fullWidth]="false"
                [disabled]="!revealedPassword()"
                [ariaLabel]="'googleAds.copyPassword' | translate"
                (clicked)="copyPassword()"
              >
                @if (passwordCopied()) {
                  <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
                } @else {
                  <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
                }
              </shared-button>
            </div>
          </div>

          <div class="space-y-2">
            <p class="block text-xs font-medium text-zinc-700">{{ 'googleAds.fields.url' | translate }}</p>
            <div class="flex items-center gap-2">
              <code class="flex-1 rounded bg-zinc-50 border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
                {{ exportUrl() }}
              </code>
              <shared-button
                variant="secondary"
                size="compact"
                [iconOnly]="true"
                shape="square"
                [fullWidth]="false"
                [ariaLabel]="'googleAds.copyUrl' | translate"
                (clicked)="copyExportUrl()"
              >
                @if (urlCopied()) {
                  <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
                } @else {
                  <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
                }
              </shared-button>
            </div>
          </div>

          <div class="text-xs text-zinc-500">
            {{ 'googleAds.lastUsedLabel' | translate }}:
            @if (credential.lastUsedAt) {
              {{ formatDate(credential.lastUsedAt) }}
            } @else {
              {{ 'googleAds.neverUsed' | translate }}
            }
          </div>

          <div class="space-y-3 border-t border-zinc-200 pt-4">
            <h5 class="text-xs font-semibold text-zinc-700 uppercase tracking-wider">{{ 'googleAds.instructions.title' | translate }}</h5>
            <ol class="list-decimal list-inside space-y-2 text-sm text-zinc-700">
              <li>{{ 'googleAds.instructions.step1' | translate }}</li>
              <li>{{ 'googleAds.instructions.step2' | translate }}</li>
              <li>{{ 'googleAds.instructions.step3' | translate }}</li>
              <li>{{ 'googleAds.instructions.step4' | translate }}</li>
            </ol>
          </div>

          <div class="flex justify-end">
            <shared-button
              variant="danger"
              size="compact"
              [fullWidth]="false"
              [disabled]="isSaving()"
              (clicked)="confirmDeleteCredential()"
            >
              {{ 'googleAds.deleteCredentials' | translate }}
            </shared-button>
          </div>
        </div>

      }
    }
  }
</section>

<shared-confirm-dialog
  [isOpen]="showDeleteDialog()"
  [title]="'googleAds.deleteConfirm.title' | translate"
  [message]="'googleAds.deleteConfirm.message' | translate"
  [confirmText]="'googleAds.deleteConfirm.confirm' | translate"
  [cancelText]="'googleAds.deleteConfirm.cancel' | translate"
  confirmVariant="danger"
  (confirm)="executeDeleteCredential()"
  (cancelled)="cancelDeleteCredential()"
/>
