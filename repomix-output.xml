    blur?: number;
    maxZoom?: number;
    max?: number;
    minOpacity?: number;
  }

  class HeatLayer extends Layer {
    setLatLngs(latlngs: [number, number, number?][]): this;
    addLatLng(latlng: [number, number, number?]): this;
    redraw(): this;
  }

