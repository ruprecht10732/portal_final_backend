<!-- ============ ACCEPT WIZARD BOTTOM SHEET ============ -->
<app-bottom-sheet
  [isOpen]="showAcceptSheet()"
  title=""
  [showCloseButton]="false"
  (closed)="closeAcceptSheet()"
>
  <div class="px-6 pb-6 pt-4">
    <!-- Header with back/cancel + step indicator -->
    <div class="flex items-center justify-between mb-6">
      @if (acceptStep() > 1) {
        <button type="button" class="text-sm font-medium text-blue-600" (click)="prevAcceptStep()">
          {{ 'partners.offer.wizard.back' | translate }}
        </button>
      } @else {
        <button type="button" class="text-sm font-medium text-blue-600" (click)="closeAcceptSheet()">
          {{ 'partners.offer.actions.cancel' | translate }}
        </button>
      }
      <span class="text-[15px] font-extrabold text-zinc-900">{{ 'partners.offer.wizard.title' | translate }}</span>
      <span class="w-16 text-right text-xs font-semibold text-zinc-400">{{ acceptStep() }} / 4</span>
    </div>

    <!-- Step progress bar -->
    <div class="flex gap-2 mb-8">
      <div class="h-1 flex-1 rounded-full" [class]="acceptStep() >= 1 ? 'bg-teal-500' : 'bg-zinc-200'"></div>
      <div class="h-1 flex-1 rounded-full" [class]="acceptStep() >= 2 ? 'bg-teal-500' : 'bg-zinc-200'"></div>
      <div class="h-1 flex-1 rounded-full" [class]="acceptStep() >= 3 ? 'bg-teal-500' : 'bg-zinc-200'"></div>
      <div class="h-1 flex-1 rounded-full" [class]="acceptStep() >= 4 ? 'bg-teal-500' : 'bg-zinc-200'"></div>
    </div>

    <!-- STEP 1: Algemene voorwaarden -->
    @if (acceptStep() === 1) {
      <div class="typeform-step">
        <div class="typeform-step-number">1</div>
        <h3 class="text-xl font-extrabold tracking-tight text-zinc-900">{{ 'partners.offer.wizard.termsHeading' | translate }}</h3>
        <p class="mt-2 text-sm text-zinc-500 leading-relaxed">{{ 'partners.offer.wizard.termsBody' | translate }}</p>

        <div class="mt-6 rounded-2xl border border-zinc-100 bg-zinc-50 p-4">
          <p class="text-xs leading-relaxed text-zinc-500">{{ 'partners.offer.wizard.termsLegal' | translate }}</p>
        </div>

        <label class="mt-6 flex items-start gap-3 cursor-pointer">
          <input type="checkbox" class="mt-0.5 h-5 w-5 rounded border-zinc-300 text-teal-600 focus:ring-teal-500" [checked]="termsAccepted()" (change)="termsAccepted.set($any($event.target).checked)" />
          <span class="text-sm font-medium text-zinc-700">{{ 'partners.offer.wizard.termsCheckbox' | translate }}</span>
        </label>
      </div>
    }

    <!-- STEP 2: Legal details -->
    @if (acceptStep() === 2) {
      <div class="typeform-step">
        <div class="typeform-step-number">2</div>
        <h3 class="text-xl font-extrabold tracking-tight text-zinc-900">{{ 'partners.offer.wizard.detailsHeading' | translate }}</h3>
        <p class="mt-2 text-sm text-zinc-500">{{ 'partners.offer.wizard.detailsBody' | translate }}</p>

        <div class="mt-6 space-y-4">
          <div>
            <label for="accept-full-name" class="block text-xs font-bold uppercase tracking-widest text-zinc-400">{{ 'partners.offer.wizard.fullName' | translate }}</label>
            <input id="accept-full-name" type="text" class="mt-2 w-full rounded-2xl border bg-zinc-50 px-4 py-3 text-sm font-semibold text-zinc-900 placeholder:text-zinc-400 focus:outline-none focus:ring-2" [class.border-red-400]="step2Attempted() && !signerFullName().trim()" [class.focus:ring-red-500/20]="step2Attempted() && !signerFullName().trim()" [class.focus:border-red-500]="step2Attempted() && !signerFullName().trim()" [class.border-zinc-200]="!step2Attempted() || signerFullName().trim()" [class.focus:ring-teal-500/20]="!step2Attempted() || signerFullName().trim()" [class.focus:border-teal-500]="!step2Attempted() || signerFullName().trim()" [placeholder]="'partners.offer.wizard.fullNamePlaceholder' | translate" [ngModel]="signerFullName()" (ngModelChange)="signerFullName.set($event)" />
