<shared-page-layout
  [title]="'organization.settings.smtp.title' | translate"
  [subtitle]="'organization.settings.smtp.subtitle' | translate"
  [error]="errorMessage()"
>
  @if (isLoading()) {
    <div class="mx-auto w-full max-w-4xl flex flex-col gap-6 py-6">
      <shared-skeleton height="12rem" width="100%" />
    </div>
  } @else {
    <div class="mx-auto w-full max-w-4xl flex flex-col gap-6 py-6">
      <shared-card>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
          <h4 class="text-xs font-bold uppercase tracking-widest text-zinc-400">
            {{ 'organization.settings.smtp.title' | translate }}
          </h4>
          <div class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold"
               [class.bg-emerald-100]="smtpConfigured()"
               [class.text-emerald-700]="smtpConfigured()"
               [class.bg-zinc-100]="!smtpConfigured()"
               [class.text-zinc-600]="!smtpConfigured()">
            {{ (smtpConfigured() ? 'organization.settings.smtp.statusConfigured' : 'organization.settings.smtp.statusNotConfigured') | translate }}
          </div>
        </div>

        <p class="text-xs text-zinc-500 mb-5">
          {{ 'organization.settings.smtp.subtitle' | translate }}
        </p>

        @if (isSmtpDetecting()) {
          <div class="flex items-center gap-3 rounded-lg border border-blue-200 bg-blue-50 px-4 py-3 mb-5">
            <svg class="h-5 w-5 shrink-0 animate-spin text-blue-500" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-blue-700">
                {{ 'organization.settings.smtp.detectingTitle' | translate }}
              </p>
              <p class="mt-0.5 text-xs text-blue-600">
                {{ 'organization.settings.smtp.detectingBody' | translate }}
              </p>
            </div>
          </div>
        }

        @if (!isSmtpDetecting() && smtpDetectedHost()) {
          <div class="flex items-start gap-3 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 mb-5">
            <svg class="h-5 w-5 shrink-0 text-emerald-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-emerald-700">
                {{ 'organization.settings.smtp.detectedTitle' | translate }}
              </p>
              <p class="mt-0.5 text-xs text-emerald-600">
                {{ 'organization.settings.smtp.detectedBody' | translate:{ host: smtpDetectedHost(), port: smtpDetectedPort() } }}
              </p>
            </div>
          </div>
        }

        @if (!isSmtpDetecting() && smtpDetectionFailed()) {
          <div class="flex items-start gap-3 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 mb-5">
            <svg class="h-5 w-5 shrink-0 text-amber-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-amber-700">
                {{ 'organization.settings.smtp.detectFailedTitle' | translate }}
              </p>
              <p class="mt-0.5 text-xs text-amber-600">
                {{ 'organization.settings.smtp.detectFailedBody' | translate }}
              </p>
            </div>
          </div>
        }

        <div class="space-y-4 mb-5">
          <shared-input
            [(value)]="smtpFromEmail"
            [label]="'organization.settings.smtp.fromEmail' | translate"
            [placeholder]="'organization.settings.smtp.fromEmailPlaceholder' | translate"
            [type]="'email'"
          />
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <shared-input
              [(value)]="smtpFromName"
              [label]="'organization.settings.smtp.fromName' | translate"
              [placeholder]="'organization.settings.smtp.fromNamePlaceholder' | translate"
            />
            <shared-input
              [(value)]="smtpPassword"
              [label]="'organization.settings.smtp.password' | translate"
              [placeholder]="smtpConfigured() ? '••••••••' : ('organization.settings.smtp.passwordPlaceholder' | translate)"
              [type]="'password'"
              [passwordToggle]="true"
              [hint]="smtpConfigured() ? ('organization.settings.smtp.passwordHint' | translate) : ''"
            />
          </div>
        </div>

        <div class="mb-5">
          <button
            type="button"
            class="text-xs font-semibold text-zinc-500 hover:text-zinc-700 uppercase tracking-widest flex items-center gap-1 min-h-11"
            (click)="showSmtpAdvanced.set(!showSmtpAdvanced())"
          >
            <svg class="h-3 w-3 transition-transform" [class.rotate-90]="showSmtpAdvanced()" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
            {{ 'organization.settings.smtp.advanced' | translate }}
          </button>
          @if (showSmtpAdvanced()) {
            <div class="mt-3 grid grid-cols-1 gap-4 sm:grid-cols-2">
              <shared-input
                [(value)]="smtpHost"
                [label]="'organization.settings.smtp.host' | translate"
                [placeholder]="'organization.settings.smtp.hostPlaceholder' | translate"
              />
              <shared-number-input
                [(value)]="smtpPort"
                [label]="'organization.settings.smtp.port' | translate"
                [min]="1"
                [max]="65535"
                [step]="1"
              />
              <shared-input
                [(value)]="smtpUsername"
                [label]="'organization.settings.smtp.username' | translate"
                [placeholder]="'organization.settings.smtp.usernamePlaceholder' | translate"
              />
            </div>
          }
        </div>

        @if (smtpSuccessMessage()) {
          <p class="mt-4 text-sm font-semibold text-emerald-600">
            {{ smtpSuccessMessage() }}
          </p>
        }

        @if (smtpErrorMessage()) {
          <p class="mt-4 text-sm font-semibold text-rose-600">
            {{ smtpErrorMessage() }}
          </p>
        }

        <div class="flex flex-col sm:flex-row sm:items-center gap-3 mt-5">
          <shared-button
            variant="primary"
            [disabled]="!canSaveSMTP() || isSmtpBusy()"
            [loading]="isSmtpSaving()"
            (clicked)="saveSMTP()"
          >
            {{ 'organization.settings.smtp.save' | translate }}
          </shared-button>

          @if (smtpConfigured()) {
            <shared-button
              variant="secondary"
              [disabled]="isSmtpBusy()"
              [loading]="isSmtpTesting()"
              (clicked)="showSmtpTest.set(!showSmtpTest())"
            >
              {{ 'organization.settings.smtp.testToggle' | translate }}
            </shared-button>
            <shared-button
              variant="danger"
              [disabled]="isSmtpBusy()"
              [loading]="isSmtpClearing()"
              (clicked)="clearSMTP()"
            >
              {{ 'organization.settings.smtp.clear' | translate }}
            </shared-button>
          }
        </div>

        @if (showSmtpTest()) {
          <div class="mt-5 flex flex-col sm:flex-row sm:items-end gap-3">
            <div class="flex-1 w-full">
              <shared-input
                [(value)]="smtpTestEmail"
                [label]="'organization.settings.smtp.testEmailLabel' | translate"
                [placeholder]="'organization.settings.smtp.testEmailPlaceholder' | translate"
                [type]="'email'"
              />
            </div>
            <shared-button
              variant="primary"
              [disabled]="isSmtpBusy() || !smtpTestEmail().trim()"
              [loading]="isSmtpTesting()"
              (clicked)="testSMTP()"
            >
              {{ 'organization.settings.smtp.testSend' | translate }}
            </shared-button>
          </div>
        }
      </shared-card>
    </div>
  }
</shared-page-layout>
