              type="lead"
              size="md"
              [emptyLabel]="noServiceLabel()"
            ></shared-status-badge>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          @if (statusMenuOpen()) {
            <div class="dropdown-backdrop" (click)="closeStatusMenu.emit()" (keydown.escape)="closeStatusMenu.emit()" tabindex="-1" aria-hidden="true"></div>
            <div
              id="status-menu"
              class="absolute right-0 mt-2 w-48 rounded-lg border border-zinc-200 bg-white shadow-lg z-20"
            >
              @for (option of statusOptions(); track option.value) {
                <button
                  type="button"
                  class="flex w-full items-center justify-between px-3 py-2 text-sm hover:bg-zinc-50 cursor-pointer min-h-11"
                  [class.bg-zinc-50]="option.value === selectedStatus()"
                  (click)="selectStatus.emit(option.value)"
                >
                  <span>{{ statusLabelMap()[option.value] ?? option.label }}</span>
                  @if (option.value === selectedStatus()) {
                    <svg class="w-4 h-4 text-green-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-7.5 7.5a1 1 0 01-1.414 0l-3.5-3.5a1 1 0 011.414-1.414l2.793 2.793 6.793-6.793a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  }
                </button>
              }
            </div>
          }
        </div>
      </div>
    }
  </div>
</div>
