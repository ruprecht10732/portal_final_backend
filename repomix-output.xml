                      }
                    </div>
                    <div>
                      <h1 class="text-xl font-extrabold tracking-tight text-slate-900 line-clamp-2">{{ q.organizationName }}</h1>
                      <p class="text-sm font-medium text-slate-500">{{ 'offertes.proposal.customerLabel' | translate }}: {{ q.customerName }}</p>
                    </div>
                  </div>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                  <div class="rounded-full px-4 py-1.5 text-[13px] font-bold text-white shadow-sm" [class]="mobileStatusBadge()">
                    {{ statusLabel(q.status) }}
                  </div>
                  @if (q.validUntil) {
                    <div class="rounded-full bg-slate-100 px-4 py-1.5 text-[13px] font-semibold text-slate-600">
                      {{ 'offertes.validUntilLabel' | translate }} {{ q.validUntil | date:'d MMM':'':'nl' }}
                    </div>
                  }
                </div>
              </div>

              @if (isReadOnly()) {
                <div class="px-4 mb-4">
                  <div class="rounded-3xl border border-blue-200 bg-blue-50 px-5 py-4 text-sm font-medium text-blue-800 shadow-sm">
                    {{ 'offertes.proposal.readOnlyNotice' | translate }}
                  </div>
                </div>
