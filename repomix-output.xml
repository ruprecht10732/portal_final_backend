<app-right-sidebar [isOpen]="isOpen()" title="AI taken" (closed)="close()">
  @if (loading()) {
    <div class="px-4 py-4 text-xs text-zinc-600">Laden...</div>
  } @else if (jobs().length === 0) {
    <div class="px-4 py-4 text-xs text-zinc-600">Geen taken</div>
  } @else {
    <ul class="m-0 list-none p-0">
      @for (job of jobs(); track job.jobId) {
        <li class="relative border-b border-zinc-100 px-4 py-3" [class.job-unviewed]="unviewedJobIds().has(job.jobId)">
          <button
            type="button"
            class="w-full text-left"
            (click)="viewJob(job.jobId, job.quoteId)"
          >
            <div class="flex items-center justify-between gap-2 pr-8">
              <span class="flex items-center gap-2 text-xs font-bold text-zinc-900">
                <span>Offerte generatie</span>
                @if (unviewedJobIds().has(job.jobId)) {
                  <span class="job-badge">Nieuw</span>
                }
              </span>
              <span class="text-[11px] font-semibold uppercase"
                    [class.text-blue-700]="job.status === 'pending' || job.status === 'running'"
                    [class.text-green-700]="job.status === 'completed'"
                    [class.text-red-700]="job.status === 'failed'"
                    [class.text-zinc-500]="job.status === 'cancelled'">
                {{ job.status }}
              </span>
            </div>
            <div class="mt-1 text-xs text-zinc-700">{{ job.step }}</div>
            <div class="mt-2 h-1.5 w-full rounded-full bg-zinc-100">
              <div class="h-full rounded-full bg-zinc-900 transition-all" [style.width.%]="job.progressPercent"></div>
            </div>
            @if (job.quoteNumber) {
              <div class="mt-2 text-[11px] text-zinc-500">{{ job.quoteNumber }}</div>
            }
            @if (job.error) {
              <div class="mt-2 text-[11px] text-red-600">{{ job.error }}</div>
            }
            @if (job.cancellationReason) {
              <div class="mt-2 text-[11px] text-zinc-500">Reden: {{ job.cancellationReason }}</div>
            }
            @if (job.feedbackRating) {
              <div class="mt-2 text-[11px] text-zinc-500">
                Feedback: {{ job.feedbackRating === 1 ? 'positief' : 'negatief' }}
                @if (job.feedbackComment) {
                  <span class="block pt-1 text-zinc-600">{{ job.feedbackComment }}</span>
                }
              </div>
            }
          </button>

          @if (job.status === 'pending' || job.status === 'running') {
            <div class="mt-3 flex justify-end">
              <shared-button
                variant="danger"
                size="compact"
                [fullWidth]="false"
                [loading]="cancellingJobId() === job.jobId"
                ariaLabel="Annuleer AI taak"
                (clicked)="onCancelJob($event, job)"
              >
                Annuleren
              </shared-button>
            </div>
          }

          @if ((job.status === 'completed' || job.status === 'failed') && !job.feedbackRating) {
            <div class="mt-3 flex items-center justify-end gap-2">
              <shared-button
                variant="secondary"
                size="compact"
                [fullWidth]="false"
                [loading]="feedbackJobId() === job.jobId"
                ariaLabel="Positieve AI feedback"
                (clicked)="onSubmitFeedback($event, job, 1)"
              >
                Goed
              </shared-button>
              <shared-button
                variant="secondary"
                size="compact"
                [fullWidth]="false"
                [loading]="feedbackJobId() === job.jobId"
                ariaLabel="Negatieve AI feedback"
                (clicked)="onSubmitFeedback($event, job, -1)"
              >
                Slecht
              </shared-button>
            </div>
          }

          @if (job.status === 'completed' || job.status === 'failed' || job.status === 'cancelled') {
            <button
              type="button"
              class="absolute right-2 top-2 inline-flex h-6 w-6 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 hover:text-zinc-900"
              aria-label="Verwijder AI taak"
              (click)="onDeleteJob($event, job)"
            >
              <lucide-icon name="x" class="h-4 w-4"></lucide-icon>
            </button>
          }
        </li>
      }
    </ul>
  }

  <div rightSidebarFooter class="grid grid-cols-2 gap-3">
    <shared-button
      variant="secondary"
      [disabled]="!hasCompleted()"
      (clicked)="onClearCompleted()"
      ariaLabel="Wis voltooide AI taken"
    >
      Voltooide wissen
    </shared-button>
    <shared-button variant="primary" (clicked)="close()" ariaLabel="Sluit AI taken">
      Sluiten
    </shared-button>
  </div>
</app-right-sidebar>
</file>

