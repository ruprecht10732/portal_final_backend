                <div class="flex items-center justify-between px-2 mb-3">
                  <h3 class="text-xs font-extrabold uppercase tracking-[0.15em] text-slate-400">{{ 'offertes.proposal.itemsTitle' | translate }}</h3>
                  <span class="text-[11px] font-bold text-blue-600 bg-blue-100 px-2 py-0.5 rounded-full">{{ 'offertes.itemsCount' | translate:{count: q.items.length} }}</span>
