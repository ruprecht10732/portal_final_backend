<div class="flex flex-col gap-6">
  <div class="flex items-center justify-between">
    <div>
      <h3 class="text-lg font-semibold">{{ 'leads.detail.files.title' | translate }}</h3>
      <p class="text-sm text-zinc-500">{{ 'leads.detail.files.description' | translate }}</p>
    </div>
  </div>

  @if (serviceAttachmentError()) {
    <div role="alert" class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-sm">
      {{ serviceAttachmentError() }}
    </div>
  }

  @if (!hasSelectedService()) {
    <p class="text-sm text-zinc-500">{{ 'leads.detail.files.selectService' | translate }}</p>
  } @else {
    <div class="rounded-xl border border-zinc-200 p-4">
      <h4 class="text-sm font-semibold mb-3">{{ 'leads.detail.files.upload' | translate }}</h4>
      <app-file-uploader
        [label]="'leads.detail.files.selectFile' | translate"
        [dropLabel]="'common.upload.dropHint' | translate"
        [accept]="'image/*,application/pdf,video/*,.doc,.docx,.xls,.xlsx'"
        [multiple]="true"
        [maxSizeBytes]="maxServiceAttachmentSizeBytes()"
        [maxSizeError]="'common.upload.sizeError' | translate"
        [buttonLabel]="'leads.detail.files.uploadButton' | translate"
        [uploadingLabel]="'leads.detail.files.uploading' | translate"
        [errorFallback]="'leads.detail.files.uploadError' | translate"
        [disabled]="serviceAttachmentUploading()"
        [presign]="presign()"
        [finalize]="finalize()"
        (uploaded)="uploaded.emit($any($event))"
        (uploadError)="uploadError.emit($event)"
        (uploadingChange)="uploadingChange.emit($event)"
      />
    </div>

    <div class="rounded-xl border border-zinc-200 p-4">
      <h4 class="text-sm font-semibold mb-3">{{ 'leads.detail.files.attachments' | translate }}</h4>
      @if (serviceAttachmentsLoading()) {
        <div class="flex items-center gap-2 text-sm text-zinc-500">
          <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-black" aria-hidden="true"></div>
          {{ 'leads.detail.files.loading' | translate }}
        </div>
      } @else if (serviceAttachments().length === 0) {
        <p class="text-sm text-zinc-500">{{ 'leads.detail.files.noFiles' | translate }}</p>
      } @else {
        <div class="flex flex-col gap-2">
          @for (attachment of serviceAttachments(); track attachment.id) {
            <div class="flex items-center justify-between rounded-lg bg-zinc-50 px-3 py-3">
              <div class="flex items-center gap-3 min-w-0">
                <div class="shrink-0 w-8 h-8 flex items-center justify-center rounded bg-zinc-200">
                  @if (attachment.contentType.startsWith('image/')) {
                    <svg class="w-4 h-4 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                    </svg>
                  } @else if (attachment.contentType.startsWith('video/')) {
                    <svg class="w-4 h-4 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
                    </svg>
                  } @else if (attachment.contentType === 'application/pdf') {
                    <svg class="w-4 h-4 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                    </svg>
                  } @else {
                    <svg class="w-4 h-4 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                    </svg>
                  }
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-medium truncate">{{ attachment.fileName }}</p>
                  <p class="text-xs text-zinc-500">{{ formatFileSize()(attachment.sizeBytes) }}</p>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <button
                  type="button"
                  class="p-2.5 min-h-11 min-w-11 flex items-center justify-center text-zinc-500 hover:text-black hover:bg-zinc-100 rounded-lg"
                  [attr.aria-label]="'Download ' + attachment.fileName"
                  [disabled]="serviceAttachmentUploading()"
                  (click)="downloadAttachment.emit(attachment)"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
                  </svg>
                </button>
                <button
                  type="button"
                  class="p-2.5 min-h-11 min-w-11 flex items-center justify-center text-zinc-500 hover:text-red-600 hover:bg-red-50 rounded-lg"
                  [attr.aria-label]="'Delete ' + attachment.fileName"
                  [disabled]="serviceAttachmentDeleting() === attachment.id || serviceAttachmentUploading()"
                  (click)="deleteAttachment.emit(attachment.id)"
                >
                  @if (serviceAttachmentDeleting() === attachment.id) {
                    <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-red-600" aria-hidden="true"></div>
                  } @else {
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                  }
                </button>
              </div>
            </div>
          }
        </div>
      }
    </div>
  }
</div>
