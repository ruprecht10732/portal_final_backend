<div class="calendar basic-calendar">
  <div class="calendar-header">
    <div class="calendar-header-row">
      @if (showNav()) {
        <button class="month-control" [attr.aria-label]="t('appointments.calendarUi.previous')" (click)="previousPeriod()">
          <span aria-hidden="true" class="material-symbols-outlined" translate="no">chevron_left</span>
          <span class="visually-hidden">{{ t('appointments.calendarUi.previous') }}</span>
        </button>
      }
      <div class="calendar-title">
        <h3 [id]="gridLabelId" aria-live="polite">{{ headerLabel() }}</h3>
      </div>
      @if (showNav()) {
        <button class="month-control" [attr.aria-label]="t('appointments.calendarUi.next')" (click)="nextPeriod()">
          <span aria-hidden="true" class="material-symbols-outlined" translate="no">chevron_right</span>
          <span class="visually-hidden">{{ t('appointments.calendarUi.next') }}</span>
        </button>
      }
    </div>

    <div class="calendar-header-row secondary">
      @if (showViews()) {
        <div class="calendar-views" role="tablist" [attr.aria-label]="t('appointments.calendarUi.views')">
          <button
            type="button"
            role="tab"
            [attr.aria-selected]="view() === 'day'"
            (click)="view.set('day')"
            class="view-button"
          >
            {{ t('appointments.calendarUi.day') }}
          </button>
          <button
            type="button"
            role="tab"
            [attr.aria-selected]="view() === 'week'"
            (click)="view.set('week')"
            class="view-button"
          >
            {{ t('appointments.calendarUi.week') }}
          </button>
          <button
            type="button"
            role="tab"
            [attr.aria-selected]="view() === 'month'"
            (click)="view.set('month')"
            class="view-button"
          >
            {{ t('appointments.calendarUi.month') }}
          </button>
        </div>
      }
      @if (showToday()) {
        <button type="button" class="today-button" (click)="selectToday()">{{ t('appointments.calendarUi.today') }}</button>
      }
    </div>

    @if (showLegend()) {
      <div class="calendar-legend" aria-hidden="true">
        <span class="legend-item"><span class="legend-swatch is-selected"></span>{{ t('appointments.calendarUi.selected') }}</span>
        <span class="legend-item"><span class="legend-swatch in-range"></span>{{ t('appointments.calendarUi.range') }}</span>
        <span class="legend-item"><span class="legend-swatch is-unavailable"></span>{{ t('appointments.calendarUi.unavailable') }}</span>
      </div>
    }
  </div>

  <p [id]="instructionsId" class="visually-hidden">
    {{ t('appointments.calendarUi.instructions') }}
  </p>

  @switch (view()) {
    @case ('day') {
      <shared-calendar-day-view
        [day]="activeDay()"
        [events]="getEventsForDay(activeDay())"
        [isUnavailable]="isUnavailable(activeDay())"
        [holidayName]="holidayName(activeDay())"
        [startHour]="dayViewStartHour()"
        [endHour]="dayViewEndHour()"
        [hourStep]="dayViewHourStep()"
        [timeSlotMinutes]="dayViewTimeSlotMinutes()"
        [blockedHours]="dayViewBlockedHours()"
        [blockedRanges]="dayViewBlockedRanges()"
        [blockedTimes]="dayViewBlockedTimes()"
        [blockedTimeRanges]="dayViewBlockedTimeRanges()"
        [selectedTime]="selectedTime()"
        (selected)="selectDay($event)"
        (timeSelected)="selectedTime.set($event)"
        (eventClick)="onDayViewEventClick($event)"
        (slotClick)="onDayViewSlotClick($event)"
      />
    }
    @case ('week') {
      <div class="grid-scroll">
        <table
          ngGrid
          colWrap="continuous"
          rowWrap="nowrap"
          [enableSelection]="true"
          [softDisabled]="false"
          selectionMode="explicit"
          [attr.aria-labelledby]="gridLabelId"
          [attr.aria-describedby]="instructionsId"
          class="w-full border-collapse border border-zinc-900"
        >
          <thead>
            <tr>
              @if (showWeekNumbers()) {
                <th scope="col" class="week-number">{{ t('appointments.calendarUi.weekShort') }}</th>
              }
              @for (day of weekdays(); track day.long; let i = $index) {
                <th scope="col" class="text-xs uppercase tracking-wide text-zinc-500 border-b border-zinc-900 bg-zinc-50 p-2">
                  <span class="visually-hidden">{{ day.long }}</span>
                  <span aria-hidden="true">{{ day.narrow }}</span>
                </th>
              }
            </tr>
          </thead>
          <tr ngGridRow>
            @if (showWeekNumbers()) {
              <td class="week-number">{{ activeWeekNumber() }}</td>
            }
            @for (day of weekDays(); track day.iso; let colIndex = $index) {
              <td
                ngGridCell
                #cell="ngGridCell"
                [rowIndex]="0"
                [colIndex]="colIndex"
                [selected]="isSelected(day)"
                [class.is-active]="cell.active()"
                [attr.aria-disabled]="isUnavailable(day) || null"
                class="align-top border border-zinc-200 p-0"
              >
                <div class="min-h-24 flex flex-col hover:bg-zinc-50 relative">
                  <button
                    type="button"
                    class="absolute inset-0 w-full h-full text-left focus-visible:outline-2 focus-visible:outline-zinc-900 focus-visible:outline-offset-2"
                    [attr.aria-label]="day.ariaLabel"
                    [disabled]="isUnavailable(day)"
                    (click)="onSlotClick(day)"
                  ></button>
                  <div class="relative z-10 flex flex-col h-full">
                    <div
                      class="p-1 text-sm font-medium"
                      [class.bg-zinc-900]="isToday(day)"
                      [class.text-white]="isToday(day)"
                      [class.rounded-full]="isToday(day)"
                      [class.w-7]="isToday(day)"
                      [class.h-7]="isToday(day)"
                      [class.flex]="isToday(day)"
                      [class.items-center]="isToday(day)"
                      [class.justify-center]="isToday(day)"
                      [class.mx-1]="isToday(day)"
                      [class.mt-1]="isToday(day)"
                      [class.text-zinc-400]="!day.inMonth"
                    >
                      {{ day.displayName }}
                    </div>
                    <div class="flex-1 overflow-hidden px-1 space-y-0.5 pb-1">
                      @for (event of getEventsForDay(day).slice(0, maxVisibleEvents()); track event.id) {
                        <button
                          type="button"
                          class="w-full text-left text-xs px-1.5 py-0.5 rounded truncate"
                          [class.bg-blue-100]="event.status === 'scheduled'"
                          [class.text-blue-800]="event.status === 'scheduled'"
                          [class.bg-green-100]="event.status === 'completed'"
                          [class.text-green-800]="event.status === 'completed'"
                          [class.bg-red-100]="event.status === 'cancelled'"
                          [class.text-red-800]="event.status === 'cancelled'"
                          [class.bg-amber-100]="event.status === 'no_show'"
                          [class.text-amber-800]="event.status === 'no_show'"
                          [class.bg-zinc-100]="!event.status"
                          [class.text-zinc-800]="!event.status"
                          (click)="onEventClick(event, $event)"
                        >
                          {{ event.title }}
                        </button>
                      }
                      @if (getEventsForDay(day).length > maxVisibleEvents()) {
                        <div class="text-xs text-zinc-500 px-1">
                          {{ t('appointments.calendarUi.moreCount', { count: getEventsForDay(day).length - maxVisibleEvents() }) }}
                        </div>
                      }
                    </div>
                  </div>
                </div>
              </td>
            }
          </tr>
        </table>
      </div>
    }
    @default {
      <div class="grid-scroll">
        <table
          ngGrid
          colWrap="continuous"
          rowWrap="nowrap"
          [enableSelection]="true"
          [softDisabled]="false"
          selectionMode="explicit"
          (keydown)="onKeyDown($event)"
          tabindex="0"
          [attr.aria-labelledby]="gridLabelId"
          [attr.aria-describedby]="instructionsId"
          class="w-full border-collapse border border-zinc-900"
        >
          <thead>
            <tr>
              @if (showWeekNumbers()) {
                <th scope="col" class="week-number">{{ t('appointments.calendarUi.weekShort') }}</th>
              }
              @for (day of weekdays(); track day.long; let i = $index) {
                <th scope="col" class="text-xs uppercase tracking-wide text-zinc-500 border-b border-zinc-900 bg-zinc-50 p-2">
                  <span class="visually-hidden">{{ day.long }}</span>
                  <span aria-hidden="true">{{ day.narrow }}</span>
                </th>
              }
            </tr>
          </thead>
          @for (week of weeks(); track $index; let rowIndex = $index) {
            <tr ngGridRow>
              @if (showWeekNumbers()) {
                <td class="week-number">{{ weekNumbers()[rowIndex] }}</td>
              }
              @if ($first) {
                @for (day of daysFromPrevMonth(); track day) {
                  <td ngGridCell [attr.aria-disabled]="true" class="is-disabled align-top border border-zinc-200 p-2 text-zinc-300">{{ day }}</td>
                }
              }
              @for (day of week; track day.iso; let colIndex = $index) {
                <td
                  ngGridCell
                  #cell="ngGridCell"
                  [rowIndex]="rowIndex"
                  [colIndex]="colIndex"
                  [selected]="isSelected(day)"
                  [class.is-active]="cell.active()"
                  [attr.aria-disabled]="isUnavailable(day) || null"
                  class="align-top border border-zinc-200 p-0"
                >
                <div class="min-h-24 flex flex-col hover:bg-zinc-50 relative">
                  <button
                    type="button"
                    class="absolute inset-0 w-full h-full text-left focus-visible:outline-2 focus-visible:outline-zinc-900 focus-visible:outline-offset-2"
                    [attr.aria-label]="day.ariaLabel"
                    [disabled]="isUnavailable(day)"
                    (click)="onSlotClick(day)"
                  ></button>
                  <div class="relative z-10 flex flex-col h-full">
                    <div
                      class="p-1 text-sm font-medium"
                      [class.bg-zinc-900]="isToday(day)"
                      [class.text-white]="isToday(day)"
                      [class.rounded-full]="isToday(day)"
                      [class.w-7]="isToday(day)"
                      [class.h-7]="isToday(day)"
                      [class.flex]="isToday(day)"
                      [class.items-center]="isToday(day)"
                      [class.justify-center]="isToday(day)"
                      [class.mx-1]="isToday(day)"
                      [class.mt-1]="isToday(day)"
                      [class.text-zinc-400]="!day.inMonth"
                    >
                      {{ day.displayName }}
                    </div>
                    <div class="flex-1 overflow-hidden px-1 space-y-0.5 pb-1">
                      @for (event of getEventsForDay(day).slice(0, maxVisibleEvents()); track event.id) {
                        <button
                          type="button"
                          class="w-full text-left text-xs px-1.5 py-0.5 rounded truncate"
                          [class.bg-blue-100]="event.status === 'scheduled'"
                          [class.text-blue-800]="event.status === 'scheduled'"
                          [class.bg-green-100]="event.status === 'completed'"
                          [class.text-green-800]="event.status === 'completed'"
                          [class.bg-red-100]="event.status === 'cancelled'"
                          [class.text-red-800]="event.status === 'cancelled'"
                          [class.bg-amber-100]="event.status === 'no_show'"
                          [class.text-amber-800]="event.status === 'no_show'"
                          [class.bg-zinc-100]="!event.status"
                          [class.text-zinc-800]="!event.status"
                          (click)="onEventClick(event, $event)"
                        >
                          {{ event.title }}
                        </button>
                      }
                      @if (getEventsForDay(day).length > maxVisibleEvents()) {
                        <div class="text-xs text-zinc-500 px-1">
                          {{ t('appointments.calendarUi.moreCount', { count: getEventsForDay(day).length - maxVisibleEvents() }) }}
                        </div>
                      }
                    </div>
                  </div>
                </div>
                </td>
              }
              @if ($last && week.length + daysFromPrevMonth().length < 7) {
                @for (day of [].constructor(7 - week.length - daysFromPrevMonth().length); track $index) {
                  <td ngGridCell [attr.aria-disabled]="true" class="is-disabled align-top border border-zinc-200 p-2 text-zinc-300">{{ $index + 1 }}</td>
                }
              }
            </tr>
          }
        </table>
      </div>
    }
  }
</div>
