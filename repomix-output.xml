            <h2 class="text-xs font-extrabold uppercase tracking-[0.18em] text-emerald-700">
              {{ 'partners.createOfferPage.resultTitle' | translate }}
            </h2>
          </div>

          <div class="mt-4 grid gap-3">
            <div class="rounded-lg border border-zinc-200 bg-white px-4 py-3">
              <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">
                {{ 'partners.createOfferPage.offerLinkLabel' | translate }}
              </p>
              <p class="mt-1 break-all text-sm text-zinc-900 font-mono">{{ acceptanceUrl() }}</p>

              <div class="mt-3 flex flex-col gap-2 sm:flex-row">
                <shared-button variant="secondary" size="compact" [fullWidth]="false" (clicked)="openAcceptanceLink()">
                  <lucide-icon name="external-link" class="h-4 w-4"></lucide-icon>
                  {{ 'partners.createOfferPage.openLink' | translate }}
                </shared-button>

                <shared-button variant="ghost" size="compact" [fullWidth]="false" (clicked)="openWhatsApp()">
                  <lucide-icon name="message-circle" class="h-4 w-4"></lucide-icon>
                  {{ 'partners.createOfferPage.openWhatsApp' | translate }}
                </shared-button>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-2 sm:grid-cols-3">
              <div class="rounded-lg border border-zinc-200 bg-white px-4 py-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">{{ 'partners.createOfferPage.vakmanFeeLabel' | translate }}</p>
                <p class="mt-1 text-sm font-semibold text-zinc-900">{{ formatEuroCents(offer.vakmanPriceCents) }}</p>
              </div>
              <div class="rounded-lg border border-zinc-200 bg-white px-4 py-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">{{ 'partners.createOfferPage.expiresAtLabel' | translate }}</p>
                <p class="mt-1 text-sm font-semibold text-zinc-900">{{ offer.expiresAt }}</p>
              </div>
              <div class="rounded-lg border border-zinc-200 bg-white px-4 py-3">
                <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">{{ 'partners.createOfferPage.offerIdLabel' | translate }}</p>
                <p class="mt-1 text-sm font-semibold text-zinc-900">{{ offer.id }}</p>
              </div>
            </div>
          </div>
        </shared-card>
      }
    </div>
  </div>
</div>
