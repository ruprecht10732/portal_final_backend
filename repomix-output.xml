    <div class="flex-1 flex flex-col items-center justify-center p-12 gap-5">
      <div class="h-16 w-16 rounded-full bg-red-100 flex items-center justify-center">
        <lucide-icon name="circle-alert" class="h-8 w-8 text-red-500"></lucide-icon>
      </div>
      <div class="text-center space-y-1">
        <p class="text-sm font-medium text-zinc-900">{{ 'common.error' | translate }}</p>
        <p class="text-sm text-zinc-500">{{ error() }}</p>
      </div>
      <shared-button variant="secondary" [fullWidth]="false" (clicked)="goBack()">
        {{ 'offertes.goBack' | translate }}
      </shared-button>
    </div>
  } @else if (loading()) {
    <div class="flex-1 flex flex-col items-center justify-center p-12 gap-4">
      <div class="h-10 w-10 rounded-full border-[3px] border-indigo-100 border-t-indigo-600 animate-spin"></div>
