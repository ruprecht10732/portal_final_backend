            </p>
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
              <code class="block flex-1 overflow-x-auto rounded-xl border border-zinc-200 bg-zinc-50 px-3 py-2 text-xs text-zinc-900">
                {{ whatsAppWebhookUrl() }}
              </code>
              <shared-button
                variant="secondary"
                size="compact"
                [fullWidth]="false"
                (clicked)="copyWhatsAppWebhookUrl()"
              >
                @if (webhookUrlCopied()) {
                  {{ 'webhook.copyKey' | translate }}
                } @else {
                  {{ 'webhook.whatsapp.copyUrl' | translate }}
                }
              </shared-button>
            </div>
            <p class="text-xs text-zinc-500">
              {{ 'webhook.whatsapp.headerHint' | translate }}
            </p>
          </div>

          @if (whatsAppWebhookSuccessMessage()) {
            <p class="text-sm font-semibold text-emerald-600">
              {{ whatsAppWebhookSuccessMessage() }}
            </p>
          }

