                    <app-quote-proposal-item-mobile
                      [item]="item"
                      [pricingMode]="q.pricingMode"
                      [isFinalized]="isFinalized()"
                      [isReadOnly]="isReadOnly()"
                      [hasAgentResponse]="hasAgentResponse(item)"
                      [deletingId]="deletingAnnotationId()"
                      [organizationName]="q.organizationName"
                      (toggleItem)="toggleItem($event)"
                      (requestAsk)="startAnnotation(item.id)"
                      (requestEdit)="startAnnotation(item.id, $event)"
                      (requestRemove)="deleteAnnotation(item.id, $event.id)"
                    />
                  }
