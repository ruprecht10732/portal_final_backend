              >
                {{ 'organization.settings.save' | translate }}
              </shared-button>
            </div>
          </div>

          @if (whatsAppSuccessMessage()) {
            <p class="text-sm font-semibold text-emerald-600">
              {{ whatsAppSuccessMessage() }}
            </p>
          }

          @if (whatsAppErrorMessage()) {
            <p class="text-sm font-semibold text-rose-600">
              {{ whatsAppErrorMessage() }}
            </p>
          }

          @if (!isWhatsAppUnregistered()) {
            <div class="mt-2 grid gap-4 sm:grid-cols-[minmax(0,1fr)_220px] items-start">
              <div class="flex flex-col gap-2">
                <p class="text-sm font-semibold text-zinc-900">
                  {{ 'organization.settings.whatsapp.qrTitle' | translate }}
                </p>
                <p class="text-xs text-zinc-500">
                  {{ 'organization.settings.whatsapp.qrHint' | translate }}
                </p>
                <shared-button
                  variant="ghost"
                  [disabled]="isWhatsAppAction()"
                  [fullWidth]="false"
                  (clicked)="refreshQr()"
                >
                  {{ 'organization.settings.whatsapp.refreshQr' | translate }}
                </shared-button>
              </div>

              @if (qrUrl()) {
                <div class="whatsapp-qr">
                  <img
                    [src]="qrUrl()"
