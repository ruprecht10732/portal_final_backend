              <div class="space-y-2 border-t border-zinc-200 pt-4">
                <div class="flex items-baseline justify-between gap-4 text-zinc-600">
                  <span class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.taxTotal' | translate }}</span>
                  <span class="font-mono text-sm font-bold tabular-nums text-zinc-800">{{ formatCurrency(totals().taxAmount) }}</span>
                </div>

                @if (taxBreakdown().length > 0) {
                  <div class="space-y-1.5 rounded-lg bg-zinc-50 px-3 py-2">
                    @for (entry of taxBreakdown(); track entry.rate) {
                      <div class="flex items-center justify-between text-xs text-zinc-500">
                        <span>{{ 'offertes.tax' | translate }} {{ entry.rate }}%</span>
                        <span class="font-mono tabular-nums text-zinc-700">{{ formatCurrency(entry.amount) }}</span>
                      </div>
                    }
                  </div>
                }
              </div>
            </div>
          </section>

          <section class="rounded-xl border border-zinc-200 bg-zinc-50 px-5 py-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500">{{ 'offertes.totalAmount' | translate }}</p>
                <p class="mt-2 font-mono text-[1.75rem] font-black leading-none tracking-tight tabular-nums text-zinc-900">{{ formatCurrency(totals().total) }}</p>
              </div>
              <span class="rounded-full border border-zinc-200 bg-white px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.14em] text-zinc-500">
                {{ 'offertes.pricesInclVat' | translate }}
              </span>
            </div>

            @if (isAdmin()) {
              <div class="mt-5 border-t border-zinc-200 pt-5">
                <app-quote-pricing-intelligence-panel
                  [serviceType]="pricingIntelligenceServiceType()"
                  [postcodePrefix]="pricingIntelligencePostcodePrefix()"
                />
              </div>
            }
          </section>
          
          <div class="hidden lg:block pt-6">
            <shared-button 
              variant="primary" 
              size="default" 
              [fullWidth]="true" 
              [disabled]="!canSave() || saving()" 
              [loading]="saving()"
              (clicked)="saveDraft()"
              class="h-12"
            >
              <lucide-icon name="send" class="h-5 w-5 mr-3"></lucide-icon>
              {{ 'offertes.saveDraft' | translate }}
            </shared-button>
          </div>
        </div>
      </div>
    </aside>
  </main>

  <shared-file-preview-dialog
    [isOpen]="previewOpen()"
    [title]="previewTitle()"
    [fileUrl]="previewUrl()"
    [fileName]="previewFileName()"
    [contentType]="previewContentType()"
    [isLoading]="previewLoading()"
    [error]="previewError()"
    (closed)="closePreview()"
  />

  @if (loading()) {
    <div class="pointer-events-none fixed inset-0 z-40 flex items-center justify-center bg-white/60 backdrop-blur-sm">
      <div class="pointer-events-auto rounded-2xl border border-zinc-200 bg-white px-6 py-5 shadow-xl">
        <div class="flex items-center gap-3">
          <lucide-icon name="loader-circle" class="h-5 w-5 animate-spin text-zinc-900"></lucide-icon>
          <div>
            <p class="text-[10px] font-black uppercase tracking-[0.18em] text-zinc-400">{{ 'offertes.loading' | translate }}</p>
            <p class="text-sm text-zinc-600">{{ 'offertes.createHint' | translate }}</p>
          </div>
        </div>
      </div>
    </div>
  }
</div>
