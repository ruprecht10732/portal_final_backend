<file path="../portal_final/src/app/shared/components/activity-notes/activity-notes.component.html">
<div class="flex flex-col gap-8 font-sans text-slate-900">
  
  <section class="flex flex-col gap-3">
    
    <div class="flex items-center justify-between px-1">
      <label [for]="noteId()" class="text-sm font-semibold text-slate-900">
        {{ noteLabel() | translate }}
      </label>

      @if (showTypeSelector()) {
        <div class="flex items-center gap-1 rounded-lg bg-slate-100 p-1">
          @for (option of noteTypeOptions(); track option.value) {
            <button
              type="button"
              class="group relative flex items-center gap-1.5 rounded-md px-2.5 py-1.5 transition-all"
              [class.bg-white]="noteType() === option.value"
              [class.shadow-sm]="noteType() === option.value"
              [class.text-slate-900]="noteType() === option.value"
              [class.text-slate-500]="noteType() !== option.value"
              [class.hover:text-slate-700]="noteType() !== option.value"
              (click)="noteTypeChange.emit(option.value)"
            >
              @switch (option.value) {
                @case ('call') { 
                  <svg class="h-3.5 w-3.5" [class.text-red-500]="noteType() === option.value" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
                }
                @case ('email') { 
                  <svg class="h-3.5 w-3.5" [class.text-blue-500]="noteType() === option.value" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
                }
                @default { 
                  <svg class="h-3.5 w-3.5" [class.text-amber-500]="noteType() === option.value" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
                }
              }
              <span class="text-xs font-semibold">
                {{ option.label | translate }}
              </span>
            </button>
          }
        </div>
      }
    </div>

    <div class="relative rounded-xl border border-slate-200 bg-white shadow-sm focus-within:border-indigo-500 focus-within:ring-1 focus-within:ring-indigo-500 transition-all">
      <textarea
        #noteInput
        [id]="noteId()"
        class="block w-full resize-none border-0 bg-transparent p-4 text-sm text-slate-900 placeholder:text-slate-400 focus:ring-0 min-h-30"
        [value]="noteText()"
        (input)="noteTextChange.emit($any($event.target).value)"
        [placeholder]="notePlaceholder() | translate"
      ></textarea>
      
      <div class="flex items-center justify-between bg-slate-50/50 px-3 py-2 border-t border-slate-100 rounded-b-xl">
        <div class="text-xs text-slate-400">{{ 'leads.detail.notes.markdownSupported' | translate }}</div>
        <button
          class="inline-flex items-center justify-center rounded-md bg-slate-900 px-4 py-2 text-xs font-semibold text-white transition-all hover:bg-slate-800 disabled:opacity-50 disabled:cursor-not-allowed"
          [disabled]="!canSubmit()"
          (click)="addNote.emit()"
        >
          @if (isSaving()) {
            <svg class="animate-spin -ml-1 mr-2 h-3 w-3 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          }
          {{ isSaving() ? ('leads.detail.notes.processing' | translate) : ('leads.detail.notes.addEntry' | translate) }}
        </button>
      </div>
    </div>
  </section>

  <div class="flex flex-col">
    
    @if (activityFeed().length === 0) {
      <div class="flex flex-col items-center justify-center py-12 text-center border-t border-slate-100 mt-2">
        <div class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center mb-2">
           <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 01-.923 1.785A5.969 5.969 0 006 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337z" /></svg>
        </div>
        <p class="text-xs font-semibold text-slate-900">{{ 'leads.detail.notes.empty' | translate }}</p>
        <p class="text-xs text-slate-500">{{ 'leads.detail.notes.emptySubtitle' | translate }}</p>
      </div>
    } @else {
      <div class="relative pl-6 space-y-8">
        <div class="absolute top-2 bottom-0 left-2.5 w-px bg-slate-200"></div>

