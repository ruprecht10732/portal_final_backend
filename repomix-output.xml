            <span class="pointer-events-none absolute left-4 flex items-center text-zinc-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35" />
                </svg>
            </span>
            <input type="text" [placeholder]="'search.placeholder' | translate" [value]="query()"
                (input)="onQueryChange($any($event.target).value)" (keydown.enter)="onEnterSearch()" autocomplete="off"
                spellcheck="false"
                class="block w-full rounded-full border border-zinc-200 bg-white py-3 pl-11 pr-10 text-sm text-zinc-900 placeholder:text-zinc-400 outline-none transition focus:border-zinc-300 focus:ring-2 focus:ring-zinc-900/8"
                [attr.aria-label]="'search.placeholder' | translate" />
