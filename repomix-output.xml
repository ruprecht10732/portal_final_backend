  } @else if (quote(); as q) {
    <div class="flex-1 overflow-y-auto bg-linear-to-br from-zinc-50 to-zinc-100 sm:bg-zinc-50/50">
      <!-- Mobile layout -->
      <div class="sm:hidden">
        <nav class="sticky top-0 z-40 grid grid-cols-[40px_1fr_40px] items-center border-b border-gray-100 bg-white/70 px-4 py-4 backdrop-blur">
