<tbody class="divide-y divide-zinc-200 bg-white">
  @for (row of rows(); track trackByRowId($index, row); let rowIndex = $index) {
    <tr
      role="row"
      [attr.aria-selected]="row.selected"
      [attr.aria-rowindex]="rowIndex + 2"
      class="group transition-colors duration-200 ease-out"
      [class.bg-white]="
        rowIndex % 2 === 0 && !row.recentlyUpdated && !row.error && !row.dirty && !row.isNew
      "
      [class.bg-zinc-50]="
        rowIndex % 2 === 1 && !row.recentlyUpdated && !row.error && !row.dirty && !row.isNew
      "
      [class.bg-green-50]="row.recentlyUpdated"
      [class.bg-red-50]="row.error"
      [class.bg-amber-50]="row.dirty && !row.isNew && !row.error && !row.recentlyUpdated"
      [class.bg-blue-50]="row.isNew && !row.error && !row.recentlyUpdated"
      [class.hover:bg-zinc-100]="!row.recentlyUpdated && !row.error && !row.dirty && !row.isNew"
    >
      @if (selectable()) {
        <td
          role="gridcell"
          [attr.aria-colindex]="1"
          class="sticky left-0 z-20 w-12 border-b border-r border-zinc-200 bg-inherit p-0 transition-colors"
          [class.border-b-0]="rowIndex === rows().length - 1"
          [attr.title]="getRowStatusTooltip(row)"
        >
          <div class="relative flex h-full w-full items-center justify-center">
            @if (row.saving) {
              <svg
                class="absolute h-4 w-4 animate-spin text-zinc-500"
                viewBox="0 0 24 24"
                fill="none"
              >
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z" />
              </svg>
            } @else {
              @if (row.dirty || row.error || row.isNew || row.recentlyUpdated) {
                <span
                  class="absolute inset-y-0 left-0 w-1 rounded-r-full transition-colors duration-300"
                  [class.bg-green-500]="row.recentlyUpdated"
                  [class.bg-red-500]="row.error && !row.recentlyUpdated"
                  [class.bg-amber-500]="row.dirty && !row.isNew && !row.error && !row.recentlyUpdated"
                  [class.bg-blue-500]="row.isNew && !row.error && !row.recentlyUpdated"
                ></span>
              }
              <div class="flex items-center justify-center p-3">
                <shared-checkbox
                  [checked]="row.selected"
                  [ariaLabel]="'dataGrid.selectRow' | translate: { rowIndex: rowIndex + 1 }"
                  [dense]="true"
                  (checkedChange)="onRowSelect(rowIndex)"
                />
              </div>
            }
          </div>
        </td>
      }

      @for (column of columns(); track column.id; let colIndex = $index) {
        <td
          #cellRef
          role="gridcell"
          [attr.aria-colindex]="getAriaColIndex(colIndex)"
          [attr.tabindex]="isCellFocused(rowIndex, colIndex) ? 0 : -1"
          (click)="onCellClick(rowIndex, colIndex)"
          (keydown)="onCellKeydown($event, rowIndex, colIndex)"
          (focus)="cellFocus.emit({ rowIndex: rowIndex, columnIndex: colIndex })"
          class="relative whitespace-nowrap border-b border-zinc-200 px-3 py-2.5 text-sm outline-none transition-all duration-200"
          [class.border-r]="colIndex !== columns().length - 1"
          [class.border-r-0]="colIndex === columns().length - 1"
          [class.border-b-0]="rowIndex === rows().length - 1"
          [class.sticky]="column.frozen"
          [class.z-10]="column.frozen"
          [class.bg-inherit]="column.frozen"
          [class.shadow-[2px_0_4px_-2px_rgba(0,0,0,0.05)]]="column.frozen"
          [style.width]="column.width"
          [style.min-width]="column.minWidth ?? '80px'"
          [style.max-width]="column.maxWidth"
          [style.left]="column.frozen ? getFrozenColumnLeft(colIndex) : null"
          [class.text-center]="column.align === 'center'"
          [class.text-right]="column.align === 'right'"
          [class.ring-2]="isCellFocused(rowIndex, colIndex)"
          [class.ring-blue-500]="isCellFocused(rowIndex, colIndex)"
          [class.ring-inset]="isCellFocused(rowIndex, colIndex)"
          [class.z-[15]]="isCellFocused(rowIndex, colIndex)"
        >
          @if (isCellEditable(rowIndex, column)) {
            <div class="flex flex-col gap-1">
              <div #inputRef class="relative w-full">
                @switch (column.cellType) {
                  @case ('address') {
                    <data-grid-address-cell
                      [value]="getInputStringValue(row, column)"
                      (valueChange)="onInputChange(rowIndex, column, $event)"
                      (addressSelect)="onAddressSelect(rowIndex, column, $event)"
                    />
                  }
                  @case ('icon') {
                    <data-grid-icon-cell
                      [value]="getInputStringValue(row, column) || null"
                      (valueChange)="onInputChange(rowIndex, column, $event ?? '')"
                    />
                  }
                  @case ('color') {
                    <data-grid-color-cell
                      [value]="getInputStringValue(row, column) || null"
                      (valueChange)="onInputChange(rowIndex, column, $event)"
                    />
                  }
                  @case ('thumbnail') {
                    <data-grid-thumbnail-cell
                      [value]="getInputStringValue(row, column) || null"
                      [config]="column.thumbnailConfig"
                    />
                  }
                  @case ('select') {
                    <div class="relative">
                      <select
                        class="w-full appearance-none rounded-md border border-transparent bg-transparent px-2.5 py-1.5 pr-8 text-sm transition-all hover:bg-zinc-50 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500"
                        [class.text-zinc-500]="getInputValue(row, column) === ''"
                        [class.border-red-500]="getCellError(row, column.id)"
                        [class.bg-red-50]="getCellError(row, column.id)"
                        [attr.aria-invalid]="getCellError(row, column.id) ? true : null"
                        [attr.aria-describedby]="getCellError(row, column.id) ? getCellErrorId(rowIndex, column.id) : null"
                        (change)="onInputChange(rowIndex, column, $event)"
                        (keydown.enter)="onInputEnter($event)"
                        (focus)="cellFocus.emit({ rowIndex: rowIndex, columnIndex: colIndex })"
                      >
                        <option value="" disabled [selected]="getInputValue(row, column) === ''">
                          {{ 'dataGrid.selectOption' | translate }}
                        </option>
                        @for (option of column.selectOptions ?? []; track option.value) {
                          <option [value]="option.value" [selected]="option.value === getInputValue(row, column)">
                            {{ option.label }}
                          </option>
                        }
                      </select>
                      <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-zinc-400">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                      </div>
                    </div>
                  }
                  @case ('boolean') {
                    <div class="flex justify-center">
                      <input
                        type="checkbox"
                        class="h-4 w-4 cursor-pointer rounded border-zinc-300 text-blue-600 transition-colors focus:ring-blue-500"
                        [checked]="!!getCellValue(row, column)"
                        (change)="onInputChange(rowIndex, column, $event)"
                        (focus)="cellFocus.emit({ rowIndex: rowIndex, columnIndex: colIndex })"
                        [attr.aria-invalid]="getCellError(row, column.id) ? true : null"
                        [attr.aria-describedby]="getCellError(row, column.id) ? getCellErrorId(rowIndex, column.id) : null"
                      />
                    </div>
                  }
                  @default {
                    <input
                      [type]="getInputType(column)"
                      class="w-full rounded-md border border-transparent bg-transparent px-2.5 py-1.5 text-base transition-all hover:bg-zinc-50 sm:text-sm focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500"
                      [class.pr-8]="isActionColumn(colIndex)"
                      [value]="getInputValue(row, column)"
                      [class.text-zinc-500]="getInputValue(row, column) === ''"
                      [class.border-red-500]="getCellError(row, column.id)"
                      [class.bg-red-50]="getCellError(row, column.id)"
                      [attr.aria-invalid]="getCellError(row, column.id) ? true : null"
                      [attr.aria-describedby]="getCellError(row, column.id) ? getCellErrorId(rowIndex, column.id) : null"
                      (input)="onInputChange(rowIndex, column, $event)"
                      (keydown.enter)="onInputEnter($event)"
                      (focus)="cellFocus.emit({ rowIndex: rowIndex, columnIndex: colIndex })"
                    />
                  }
                }

                @if (isActionColumn(colIndex) && (rowViewActionEnabled() || (rowDeleteActionEnabled() && canDeleteRow(row)))) {
                  <div class="absolute right-1 top-1/2 z-20 flex -translate-y-1/2 items-center gap-1 rounded-md bg-inherit py-0.5 pl-1 opacity-0 transition-opacity duration-200 group-hover:opacity-100 focus-within:opacity-100">
                    @if (rowViewActionEnabled()) {
                      <button
                        type="button"
                        class="flex h-7 w-7 transform cursor-pointer items-center justify-center rounded-md border border-zinc-200 bg-white text-zinc-500 shadow-sm transition-all duration-200 hover:scale-105 hover:bg-zinc-50 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 active:scale-95"
                        aria-label="{{ 'dataGrid.viewDetails' | translate }}"
                        title="{{ 'dataGrid.viewDetails' | translate }}"
                        (click)="onRowDoubleClick(rowIndex); $event.stopPropagation()"
                      >
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.522 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.478 0-8.268-2.943-9.542-7z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                      </button>
                    }
                    @if (rowDeleteActionEnabled() && canDeleteRow(row)) {
                      <button
                        type="button"
                        class="flex h-7 w-7 transform cursor-pointer items-center justify-center rounded-md border border-zinc-200 bg-white text-red-500 shadow-sm transition-all duration-200 hover:scale-105 hover:border-red-200 hover:bg-red-50 hover:text-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 active:scale-95"
                        aria-label="{{ 'dataGrid.delete' | translate }}"
                        title="{{ 'dataGrid.delete' | translate }}"
                        (click)="onRowDelete(rowIndex); $event.stopPropagation()"
                      >
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7h6m-7 0h8m-9 0V5a2 2 0 012-2h4a2 2 0 012 2v2" />
                        </svg>
                      </button>
                    }
                  </div>
                }
              </div>

              @if (getCellError(row, column.id)) {
                <span
                  class="block animate-in fade-in slide-in-from-top-1 px-1 text-[10px] font-bold uppercase tracking-wider text-red-600"
                  role="alert"
                  [id]="getCellErrorId(rowIndex, column.id)"
                >
                  {{ getCellError(row, column.id) }}
                </span>
              }
            </div>
          } @else {
            <div
              class="flex min-h-7 items-center gap-2"
              [class.justify-between]="isActionColumn(colIndex)"
            >
              <span
                class="truncate"
                [title]="getCellDisplayValue(row, column)"
                [class.text-zinc-400]="
                  getCellValue(row, column) === null ||
                  getCellValue(row, column) === undefined ||
                  getCellValue(row, column) === ''
                "
              >
                @if (column.cellType === 'boolean') {
                  @if (getCellValue(row, column)) {
                    <div class="flex items-center gap-1.5 rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700 shadow-sm">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span>Yes</span>
                    </div>
                  } @else {
                    <div class="flex items-center gap-1.5 rounded-full bg-zinc-100 px-2 py-0.5 text-xs font-medium text-zinc-500 shadow-sm">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                      <span>No</span>
                    </div>
                  }
                } @else if (column.cellType === 'color') {
                  <div class="flex items-center gap-2">
                    <span
                      class="h-4 w-4 shrink-0 rounded-full border border-zinc-200 shadow-sm"
                      [style.backgroundColor]="hexOrTransparent(getCellValue(row, column))"
                      aria-hidden="true"
                    ></span>
                    <span class="truncate font-mono text-xs">{{ getCellValue(row, column) ?? '—' }}</span>
                  </div>
                } @else if (isStatusColumn(column)) {
                  <shared-status-badge [status]="$any(getCellValue(row, column))" type="lead"></shared-status-badge>
                } @else if (column.cellType === 'select') {
                  @let meta = getSelectMeta(column, getCellValue(row, column));
                  @if (meta) {
                    <span class="inline-flex items-center gap-2" [title]="meta.description ?? ''">
                      @if (meta.color) {
                        <span class="h-2 w-2 shrink-0 rounded-full" [style.backgroundColor]="hexOrTransparent(meta.color)" aria-hidden="true"></span>
                      }
                      @if (meta.icon) {
                        <lucide-icon [name]="meta.icon" class="h-4 w-4 shrink-0 text-zinc-500"></lucide-icon>
                      }
                      <span class="truncate">{{ meta.label ?? (column.selectOptions | optionLabel: getCellValue(row, column)) }}</span>
                    </span>
                  } @else {
                    {{ column.selectOptions | optionLabel: getCellValue(row, column) }}
                  }
                } @else if (column.cellType === 'thumbnail') {
                  <data-grid-thumbnail-cell [value]="getInputStringValue(row, column) || null" [config]="column.thumbnailConfig" />
                } @else if (column.cellType === 'date') {
                  <span class="tabular-nums">{{ getRelativeDateValue(row, column) }}</span>
                } @else {
                  {{ getCellValue(row, column) ?? '—' }}
                }
              </span>

              @if (isActionColumn(colIndex) && (rowViewActionEnabled() || (rowDeleteActionEnabled() && canDeleteRow(row)))) {
                <div class="ml-2 flex items-center gap-1 opacity-0 transition-opacity duration-200 group-hover:opacity-100 has-focus:opacity-100">
                  @if (rowViewActionEnabled()) {
                    <button
                      type="button"
                      class="flex h-7 w-7 transform cursor-pointer items-center justify-center rounded-md border border-zinc-200 bg-white text-zinc-500 shadow-sm transition-all duration-200 hover:scale-105 hover:bg-zinc-50 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 active:scale-95"
                      aria-label="{{ 'dataGrid.viewDetails' | translate }}"
                      title="{{ 'dataGrid.viewDetails' | translate }}"
                      (click)="onRowDoubleClick(rowIndex); $event.stopPropagation()"
                    >
                      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.522 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.478 0-8.268-2.943-9.542-7z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    </button>
                  }
                  @if (rowDeleteActionEnabled() && canDeleteRow(row)) {
                    <button
                      type="button"
                      class="flex h-7 w-7 transform cursor-pointer items-center justify-center rounded-md border border-zinc-200 bg-white text-red-500 shadow-sm transition-all duration-200 hover:scale-105 hover:border-red-200 hover:bg-red-50 hover:text-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 active:scale-95"
                      aria-label="{{ 'dataGrid.delete' | translate }}"
                      title="{{ 'dataGrid.delete' | translate }}"
                      (click)="onRowDelete(rowIndex); $event.stopPropagation()"
                    >
                      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7h6m-7 0h8m-9 0V5a2 2 0 012-2h4a2 2 0 012 2v2" />
                      </svg>
                    </button>
                  }
                </div>
              }
            </div>
          }
        </td>
      }
    </tr>
  } @empty {
    <tr>
      <td colspan="100" class="px-6 py-16 text-center text-zinc-500">
        <div class="flex flex-col items-center justify-center gap-3">
          <div class="rounded-full bg-zinc-50 p-3">
            <svg class="h-6 w-6 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
            </svg>
          </div>
          @let noDataLabel = 'dataGrid.noData' | translate;
          <p class="text-sm font-medium">
            {{ noDataLabel && noDataLabel !== 'dataGrid.noData' ? noDataLabel : 'No data available' }}
          </p>
        </div>
      </td>
    </tr>
  }
