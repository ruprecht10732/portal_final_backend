<shared-card class="flex flex-col overflow-hidden rounded-xl border border-slate-200 bg-white font-sans">
  
  <div class="flex items-center justify-between px-5 py-4">
    <div class="flex items-center gap-3">
      <h2 class="text-sm font-semibold text-slate-900">{{ 'leads.detail.services.title' | translate }}</h2>
      <span class="flex h-5 items-center justify-center rounded-md bg-slate-100 px-2 text-xs font-medium text-slate-600">
        {{ services().length }}
      </span>
    </div>
    
    <button
      type="button"
      class="flex h-8 w-8 items-center justify-center rounded-md border border-slate-200 text-slate-500 hover:border-slate-300 hover:text-slate-900 active:bg-slate-50"
      (click)="openAdd.emit()"
      title="{{ 'leads.detail.services.addTitle' | translate }}"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
    </button>
  </div>

  @if (showAddForm()) {
    <div class="border-t border-b border-slate-200 bg-slate-50 p-5">
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <h3 class="text-xs font-bold uppercase tracking-wide text-slate-500">{{ 'leads.detail.services.newScopeTitle' | translate }}</h3>
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <shared-select
            [label]="'leads.detail.services.serviceType' | translate"
            class="w-full bg-white"
            [options]="serviceTypeOptions()"
            [value]="newServiceType()"
            (valueChange)="newServiceTypeChange.emit($event)"
          />
          <shared-input
            [label]="'leads.detail.services.source' | translate"
            class="bg-white"
            [placeholder]="'leads.detail.services.sourcePlaceholder' | translate"
            [value]="newServiceSource()"
            (valueChange)="newServiceSourceChange.emit($event)"
          />
        </div>
        
        <shared-textarea
          id="new-service-note"
          [label]="'leads.detail.services.consumerNote' | translate"
          class="bg-white"
          [placeholder]="'leads.detail.services.consumerNotePlaceholder' | translate"
          [rows]="2"
          [value]="newServiceConsumerNote()"
          (valueChange)="newServiceConsumerNoteChange.emit($event)"
        />
        
        <div class="flex items-center justify-between pt-2">
          <shared-checkbox
            [label]="'leads.detail.services.closeActiveService' | translate"
            [checked]="closeCurrentService()"
            (checkedChange)="closeCurrentServiceChange.emit($event)"
            [dense]="true"
          />
          
          <div class="flex items-center gap-3">
            <button
              type="button"
              class="text-xs font-medium text-slate-500 hover:text-slate-900 hover:underline"
              (click)="cancelAdd.emit()"
            >
              {{ 'leads.detail.services.cancel' | translate }}
            </button>
            <button
              type="button"
              class="rounded-md bg-slate-900 px-4 py-2 text-xs font-semibold text-white hover:bg-slate-800 disabled:opacity-50"
              [disabled]="!newServiceType() || saving()"
              (click)="addService.emit()"
            >
              {{ saving() ? ('leads.detail.services.saving' | translate) : ('leads.detail.services.confirmScope' | translate) }}
            </button>
          </div>
        </div>
      </div>
    </div>
  }

  <div class="flex flex-col border-t border-slate-100">
    @if (services().length === 0) {
      <div class="flex flex-col items-center justify-center py-12 text-center">
        <p class="text-sm font-medium text-slate-900">{{ 'leads.detail.services.noServicesTitle' | translate }}</p>
        <p class="text-xs text-slate-500 mt-1">{{ 'leads.detail.services.noServicesSubtitle' | translate }}</p>
      </div>
    } @else {
      @for (service of services(); track service.id) {
        <button
          type="button"
          class="group relative flex w-full items-start justify-between border-b border-slate-100 px-5 py-4 text-left last:border-0 hover:bg-slate-50"
          [class.bg-slate-50]="isSelected(service)"
          (click)="selectService.emit(service)"
        >
          @if (isSelected(service)) {
            <div class="absolute inset-y-0 left-0 w-0.75 bg-slate-900"></div>
          }

          <div class="flex flex-col gap-1">
            @if (isEditing(service)) {
              <div class="flex items-center gap-2">
                <shared-select
                  class="min-w-50"
                  [options]="serviceTypeOptions()"
                  [value]="editingServiceType()"
                  (valueChange)="editingServiceTypeChange.emit($event)"
                  [disabled]="savingServiceType()"
                />
                <button
                  type="button"
                  class="text-xs font-medium text-slate-500 hover:text-slate-900"
                  (click)="cancelEditServiceType.emit(); $event.stopPropagation()"
                  [disabled]="savingServiceType()"
                >
                  {{ 'common.cancel' | translate }}
                </button>
                <button
                  type="button"
                  class="text-xs font-medium text-indigo-600 hover:text-indigo-700 disabled:opacity-50"
                  (click)="saveServiceType.emit(); $event.stopPropagation()"
                  [disabled]="!editingServiceType() || savingServiceType()"
                >
                  {{ savingServiceType() ? ('common.saving' | translate) : ('common.save' | translate) }}
                </button>
              </div>
            } @else {
              <div class="flex items-center gap-2">
                <span 
                  class="text-sm font-semibold text-slate-900"
                  [class.text-indigo-600]="isSelected(service)"
                >
                  {{ serviceTypeLabels()[service.serviceType] || service.serviceType }}
                </span>
                <button
                  type="button"
                  class="opacity-0 group-hover:opacity-100 text-slate-400 hover:text-slate-600"
                  (click)="startEditServiceType.emit(service); $event.stopPropagation()"
                  title="{{ 'leads.detail.services.editType' | translate }}"
                >
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                  </svg>
                </button>
              </div>
            }
            <div class="flex items-center gap-2 text-xs text-slate-500">
              <span>{{ service.createdAt | date: 'MMM d, y' }}</span>
              <span class="text-slate-300">•</span>
              <span>{{ service.source || ('leads.detail.services.directSource' | translate) }}</span>
            </div>
          </div>

          <div class="flex items-center gap-4">
             <span
              class="inline-flex items-center rounded border px-2 py-1 text-[10px] font-bold uppercase tracking-wider"
              [class.border-slate-200]="!isSelected(service)"
              [class.bg-white]="!isSelected(service)"
              [class.text-slate-500]="!isSelected(service)"
              [class.border-indigo-200]="isSelected(service)"
              [class.bg-indigo-50]="isSelected(service)"
              [class.text-indigo-700]="isSelected(service)"
            >
              {{ statusLabels()[service.status] || service.status }}
            </span>
          </div>
        </button>
      }
    }
  </div>
</shared-card>
