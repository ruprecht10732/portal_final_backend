                [class.text-white]="appointment()!.status === opt.value"
                [class.border-black]="appointment()!.status === opt.value"
                [class.bg-white]="appointment()!.status !== opt.value"
                [class.text-zinc-600]="appointment()!.status !== opt.value"
                [class.border-zinc-200]="appointment()!.status !== opt.value"
