<shared-page-layout
  [title]="'offertes.overviewTitle' | translate"
  [subtitle]="'offertes.overviewSubtitle' | translate"
  [error]="error()"
  [removeMobilePadding]="true"
>
  <shared-button
    actions
    variant="primary"
    [fullWidth]="false"
    (clicked)="createQuote()"
  >
    <lucide-icon name="plus" class="h-4 w-4"></lucide-icon>
    {{ 'offertes.create' | translate }}
  </shared-button>

  <shared-button
    class="actions-desktop"
    variant="primary"
    [fullWidth]="false"
    (clicked)="createQuote()"
  >
    <lucide-icon name="plus" class="h-4 w-4"></lucide-icon>
    {{ 'offertes.create' | translate }}
  </shared-button>

  @if (moneybirdConnected() && selectedQuoteIds().length > 0) {
    <shared-button
      class="actions-desktop"
      variant="secondary"
      [fullWidth]="false"
      [loading]="bulkExporting()"
      (clicked)="bulkSendToMoneybird()"
    >
      <lucide-icon name="send" class="h-4 w-4"></lucide-icon>
      {{ 'offertes.bulkSendToMoneybird' | translate:{count: selectedQuoteIds().length} }}
    </shared-button>
  }

  @if (bulkExportFeedback(); as feedback) {
    <div
      class="mb-3 border-y px-4 py-3 text-sm sm:border sm:rounded-sm"
      [class.border-emerald-200]="feedback.type === 'success'"
      [class.bg-emerald-50]="feedback.type === 'success'"
      [class.text-emerald-800]="feedback.type === 'success'"
      [class.border-amber-200]="feedback.type === 'warning'"
      [class.bg-amber-50]="feedback.type === 'warning'"
      [class.text-amber-800]="feedback.type === 'warning'"
      [class.border-red-200]="feedback.type === 'error'"
      [class.bg-red-50]="feedback.type === 'error'"
      [class.text-red-800]="feedback.type === 'error'"
    >
      {{ feedback.message }}
    </div>
  }

  <shared-data-grid
    [columns]="gridColumns()"
    [data]="gridData()"
    [totalItems]="total()"
    [loading]="loading()"
    [config]="gridConfigAdapter"
    [serverSide]="true"
    [fetchData]="fetchDataAdapter"
    (dataRequest)="onDataRequest($event)"
    (rowDoubleClick)="onGridRowDoubleClick($event)"
    (selectionChange)="onSelectionChange($event)"
    (deleteRows)="onDeleteQuotes($event)"
    [ariaLabel]="'offertes.list.title' | translate"
  />

  @if (selectionStats(); as stats) {
    <div class="stats-float-bar">
      <div class="stats-float-bar__header">
        <span class="stats-float-bar__count">
          <lucide-icon name="trending-up" class="h-3.5 w-3.5"></lucide-icon>
          {{ stats.count }}&nbsp;{{ stats.count === 1 ? ('offertes.stats.selected' | translate) : ('offertes.stats.selectedPlural' | translate) }}
        </span>
        <div class="stats-float-bar__totals">
          @if (stats.byStatus.Accepted > 0) {
            <span class="stats-float-bar__kv">
              <span class="stats-float-bar__dot stats-float-bar__dot--accepted"></span>
              {{ 'offertes.stats.accepted' | translate }}: <strong>{{ formatCurrency(stats.acceptedValue) }}</strong>
              <span class="stats-float-bar__kv--muted">({{ 'offertes.stats.acceptedExclVat' | translate }}: {{ formatCurrency(stats.acceptedExclVat) }})</span>
              <span
                class="stats-float-bar__kpi"
                [class.stats-float-bar__kpi--high]="stats.acceptedCountShare >= 70"
                [class.stats-float-bar__kpi--medium]="stats.acceptedCountShare >= 40 && stats.acceptedCountShare < 70"
                [class.stats-float-bar__kpi--low]="stats.acceptedCountShare < 40"
              >
                {{ 'offertes.stats.acceptedCountShare' | translate }}: {{ stats.acceptedCountShare }}%
              </span>
              <span
                class="stats-float-bar__kpi"
                [class.stats-float-bar__kpi--high]="stats.acceptedValueShare >= 70"
                [class.stats-float-bar__kpi--medium]="stats.acceptedValueShare >= 40 && stats.acceptedValueShare < 70"
                [class.stats-float-bar__kpi--low]="stats.acceptedValueShare < 40"
              >
                {{ 'offertes.stats.acceptedValueShare' | translate }}: {{ stats.acceptedValueShare }}%
              </span>
            </span>
          }
          <span class="stats-float-bar__kv">{{ 'offertes.stats.exclVat' | translate }}: <strong>{{ formatCurrency(stats.totalExclVat) }}</strong></span>
          <span class="stats-float-bar__kv stats-float-bar__kv--muted">{{ 'offertes.stats.vat' | translate }}: <strong>{{ formatCurrency(stats.totalVat) }}</strong></span>
          <span class="stats-float-bar__kv">{{ 'offertes.stats.inclVat' | translate }}: <strong>{{ formatCurrency(stats.totalInclVat) }}</strong></span>
          <span class="stats-float-bar__kv stats-float-bar__kv--muted">Ø {{ formatCurrency(stats.avgValue) }}</span>
        </div>
      </div>

      <div class="stats-float-bar__track">
        @for (seg of stats.segments; track seg.status) {
          @if (seg.count > 0) {
            <div
              class="stats-float-bar__seg"
              [class.stats-float-bar__seg--draft]="seg.status === 'Draft'"
              [class.stats-float-bar__seg--sent]="seg.status === 'Sent'"
              [class.stats-float-bar__seg--accepted]="seg.status === 'Accepted'"
              [class.stats-float-bar__seg--rejected]="seg.status === 'Rejected'"
              [class.stats-float-bar__seg--expired]="seg.status === 'Expired'"
              [style.width.%]="seg.width"
              [title]="seg.label + ': ' + seg.count"
            ></div>
          }
        }
      </div>

      <div class="stats-float-bar__legend">
        @for (seg of stats.segments; track seg.status) {
          @if (seg.count > 0) {
            <span class="stats-float-bar__legend-item">
              <span
                class="stats-float-bar__legend-dot"
                [class.stats-float-bar__legend-dot--draft]="seg.status === 'Draft'"
                [class.stats-float-bar__legend-dot--sent]="seg.status === 'Sent'"
                [class.stats-float-bar__legend-dot--accepted]="seg.status === 'Accepted'"
                [class.stats-float-bar__legend-dot--rejected]="seg.status === 'Rejected'"
                [class.stats-float-bar__legend-dot--expired]="seg.status === 'Expired'"
              ></span>
              {{ seg.label }} ({{ seg.count }})
            </span>
          }
        }
      </div>
    </div>
  }

  <shared-confirm-dialog
    [isOpen]="isDeleteDialogOpen()"
    [title]="'offertes.list.deleteTitle' | translate"
    [message]="'offertes.list.deleteMessage' | translate:{count: deleteCount()}"
    [confirmText]="'offertes.list.deleteConfirm' | translate"
    [cancelText]="'offertes.list.deleteCancel' | translate"
    confirmVariant="danger"
    [confirmDisabled]="deleteInProgress()"
    (confirm)="confirmDelete()"
    (cancelled)="closeDeleteDialog()"
  />
</shared-page-layout>
