<shared-page-layout
  [title]="'catalog.products.title' | translate"
  [subtitle]="'catalog.products.subtitle' | translate"
  [error]="error()"
  [removeMobilePadding]="true"
>
  <shared-button
    actions
    variant="primary"
    (clicked)="createProduct()"
    [ariaLabel]="'catalog.products.newProduct' | translate"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
    </svg>
    {{ 'catalog.products.newProduct' | translate }}
  </shared-button>
  <shared-data-grid
    [columns]="gridColumns()"
    [data]="gridData()"
    [totalItems]="total()"
    [loading]="loading()"
    [error]="error() ?? ''"
    [config]="gridConfigAdapter"
    [serverSide]="true"
    [fetchData]="gridFetchDataFn"
    (dataRequest)="onDataRequest($event)"
    (deleteRows)="onGridDeleteRows($event)"
    (saveRows)="onGridSaveRows($event)"
    (rowDoubleClick)="onGridRowDoubleClick($event)"
    [ariaLabel]="'catalog.products.title' | translate"
  />

  <!-- Delete Confirmation Dialog -->
  <shared-confirm-dialog
    [isOpen]="isDeleteDialogOpen()"
    [title]="'catalog.products.deleteTitle' | translate"
    [message]="'catalog.products.deleteMessage' | translate:{title: pendingDeleteProduct()?.title}"
    [confirmText]="'catalog.products.deleteConfirm' | translate"
    [cancelText]="'catalog.products.deleteCancel' | translate"
    confirmVariant="danger"
    [confirmDisabled]="deleteInProgress()"
    (confirm)="deleteProduct()"
    (cancelled)="closeDeleteDialog()"
  />
</shared-page-layout>
