                      [hint]="channelVarsKey('email') | translate"
                      [variables]="variablesForTrigger(selectedAction())"
                      [value]="channelTemplate('email')"
                      (valueChange)="updateChannelTemplate('email', $event)"
                      [minHeight]="180"
                      [placeholder]="'organization.settings.workflows.templatePlaceholder' | translate"
                    />
                  }
                } @else {
                  <p class="text-sm text-zinc-500">
                    {{ 'organization.settings.workflows.channelUnavailable' | translate }}
                  </p>
                }
              </div>
            </shared-card>
          </div>
        </div>
      </shared-card>

      <shared-card>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            @if (successMessage()) {
              <p class="text-sm font-bold text-emerald-600 flex items-center gap-2">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {{ successMessage() }}
              </p>
            }
          </div>

          <shared-button
            variant="primary"
            [disabled]="!canSave() || isSaving()"
            [loading]="isSaving()"
            (clicked)="save()"
          >
            {{ 'organization.settings.save' | translate }}
          </shared-button>
        </div>
      </shared-card>
    </div>
  }
</shared-page-layout>
