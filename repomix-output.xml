<div class="flex flex-col gap-6 p-4 sm:p-6 max-w-3xl mx-auto pb-16 sm:pb-6">
  <header>
    <h1 class="text-base sm:text-xl font-bold uppercase tracking-tight text-black">{{ 'appointments.availability.title' | translate }}</h1>
    <p class="text-sm text-zinc-500 mt-1">{{ 'appointments.availability.description' | translate }}</p>
  </header>

  @if (error()) {
    <div class="bg-red-50 border border-red-500 text-red-900 p-4 rounded text-sm font-medium flex items-start gap-3">
      <span class="font-bold uppercase text-red-600 shrink-0">{{ 'common.error' | translate }}</span>
      <span>{{ error() }}</span>
    </div>
  }

  <!-- Timezone Selection -->
  <shared-card padding="default">
    <div class="flex items-center gap-4 flex-wrap">
      <div class="flex-1 min-w-48">
        <shared-select
          [label]="'appointments.availability.timezone.label' | translate"
          [options]="timezoneOptions()"
          [value]="selectedTimezone()"
          (valueChange)="selectedTimezone.set($event ?? selectedTimezone())"
        />
      </div>
      <p class="text-xs text-zinc-500 max-w-sm">{{ 'appointments.availability.timezone.description' | translate }}</p>
    </div>
  </shared-card>

  <!-- Recurring Rules Section -->
  <shared-card padding="default">
    <div class="flex items-center justify-between gap-4 flex-wrap mb-4">
      <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">{{ 'appointments.availability.rules.title' | translate }}</h2>
      <div class="flex gap-2">
        <shared-button variant="secondary" size="compact" (clicked)="openQuickSetup()">
          <lucide-icon name="zap" class="h-4 w-4 mr-1" aria-hidden="true"></lucide-icon>
          {{ 'appointments.availability.quickSetup.button' | translate }}
        </shared-button>
        <shared-button variant="primary" size="compact" (clicked)="openRuleForm()">
          <lucide-icon name="plus" class="h-4 w-4 mr-1" aria-hidden="true"></lucide-icon>
          {{ 'appointments.availability.rules.add' | translate }}
        </shared-button>
      </div>
    </div>

    @if (loading()) {
      <div class="flex justify-center py-8">
        <div class="animate-spin h-6 w-6 border-2 border-zinc-300 border-t-black rounded-full"></div>
      </div>
    } @else if (sortedRules().length === 0) {
      <div class="text-center py-8 text-zinc-500 text-sm">
        <p>{{ 'appointments.availability.rules.empty' | translate }}</p>
      </div>
    } @else {
      <div class="flex flex-col gap-2">
        @for (rule of sortedRules(); track rule.id) {
          <div class="flex items-center justify-between gap-4 p-3 bg-zinc-50 border border-zinc-200 rounded">
            <div class="flex items-center gap-4 flex-wrap">
              <span class="font-medium text-sm text-black min-w-25">{{ getWeekdayLabel(rule.weekday) }}</span>
              <span class="text-sm text-zinc-600">{{ rule.startTime }} - {{ rule.endTime }}</span>
              <span class="text-xs text-zinc-400">({{ rule.timezone }})</span>
            </div>
            <div class="flex gap-1">
              <shared-button
                type="button"
                variant="ghost"
                size="compact"
                [iconOnly]="true"
                [fullWidth]="false"
                (clicked)="editRule(rule)"
                [attr.aria-label]="'common.edit' | translate"
              >
                <lucide-icon name="pencil" class="h-4 w-4" aria-hidden="true"></lucide-icon>
              </shared-button>
              <shared-button
                type="button"
                variant="ghost"
                size="compact"
                [iconOnly]="true"
                [fullWidth]="false"
                (clicked)="promptDeleteRule(rule.id)"
                [attr.aria-label]="'common.delete' | translate"
                class="text-red-600 hover:text-red-700"
              >
                <lucide-icon name="trash-2" class="h-4 w-4" aria-hidden="true"></lucide-icon>
              </shared-button>
            </div>
          </div>
        }
      </div>
    }
  </shared-card>

  <!-- Date Overrides Section -->
  <shared-card padding="default">
    <div class="flex items-center justify-between gap-4 flex-wrap mb-4">
      <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">{{ 'appointments.availability.overrides.title' | translate }}</h2>
      <shared-button variant="secondary" size="compact" (clicked)="openOverrideForm()">
        <lucide-icon name="plus" class="h-4 w-4 mr-1" aria-hidden="true"></lucide-icon>
        {{ 'appointments.availability.overrides.add' | translate }}
      </shared-button>
    </div>

    @if (!loading() && sortedOverrides().length === 0) {
      <div class="text-center py-8 text-zinc-500 text-sm">
        <p>{{ 'appointments.availability.overrides.empty' | translate }}</p>
      </div>
    } @else if (!loading()) {
      <div class="flex flex-col gap-2">
        @for (override of sortedOverrides(); track override.id) {
          <div 
            class="flex items-center justify-between gap-4 p-3 border rounded"
            [class.bg-zinc-50]="override.isAvailable"
            [class.border-zinc-200]="override.isAvailable"
            [class.bg-red-50]="!override.isAvailable"
            [class.border-red-200]="!override.isAvailable"
          >
            <div class="flex items-center gap-4 flex-wrap">
              <span class="font-medium text-sm text-black min-w-25">{{ override.date | date:'mediumDate' }}</span>
              @if (override.isAvailable) {
                <span class="text-sm text-zinc-600">{{ override.startTime }} - {{ override.endTime }}</span>
              } @else {
                <span class="text-sm font-medium text-red-700">{{ 'appointments.availability.overrides.unavailable' | translate }}</span>
              }
            </div>
            <div class="flex gap-1">
              <shared-button
                type="button"
                variant="ghost"
                size="compact"
                [iconOnly]="true"
                [fullWidth]="false"
                (clicked)="editOverride(override)"
                [attr.aria-label]="'common.edit' | translate"
              >
                <lucide-icon name="pencil" class="h-4 w-4" aria-hidden="true"></lucide-icon>
              </shared-button>
              <shared-button
                type="button"
                variant="ghost"
                size="compact"
                [iconOnly]="true"
                [fullWidth]="false"
                (clicked)="promptDeleteOverride(override.id)"
                [attr.aria-label]="'common.delete' | translate"
                class="text-red-600 hover:text-red-700"
              >
                <lucide-icon name="trash-2" class="h-4 w-4" aria-hidden="true"></lucide-icon>
              </shared-button>
            </div>
          </div>
        }
      </div>
    }
  </shared-card>

  <!-- Rule Form Modal -->
  @if (showRuleForm()) {
    <button 
      type="button"
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 cursor-default"
      [attr.aria-label]="'common.close' | translate"
      (click)="closeRuleForm()" 
      (keydown.escape)="closeRuleForm()"
    >
      <dialog 
        class="relative w-full max-w-md rounded-lg bg-white p-6 shadow-xl"
        [open]="true"
        tabindex="0"
        (click)="$event.stopPropagation()"
        (keydown.escape)="closeRuleForm()"
      >
        <h3 class="text-lg font-bold uppercase tracking-tight text-black mb-5">
          {{ (editingRuleId() ? 'appointments.availability.rules.edit' : 'appointments.availability.rules.add') | translate }}
        </h3>
        <form (ngSubmit)="saveRule()" class="space-y-4">
          <shared-select
            [label]="'appointments.availability.rules.weekday' | translate"
            [options]="weekdaySelectOptions()"
            [value]="ruleWeekday()"
            (valueChange)="ruleWeekday.set($event ?? '1')"
            [required]="true"
          />
          
          <div class="grid grid-cols-2 gap-4">
            <shared-input
              type="time"
              [label]="'appointments.availability.rules.startTime' | translate"
              [value]="ruleStartTime()"
              (valueChange)="ruleStartTime.set($event)"
              [required]="true"
              [clearable]="false"
            />
            <shared-input
              type="time"
              [label]="'appointments.availability.rules.endTime' | translate"
              [value]="ruleEndTime()"
              (valueChange)="ruleEndTime.set($event)"
              [required]="true"
              [clearable]="false"
            />
          </div>
          
          <div class="flex justify-end gap-3 pt-4 border-t border-zinc-200">
            <shared-button variant="secondary" type="button" (clicked)="closeRuleForm()">
              {{ 'common.cancel' | translate }}
            </shared-button>
            <shared-button variant="primary" type="submit" [disabled]="!canSaveRule()">
              {{ 'common.save' | translate }}
            </shared-button>
          </div>
        </form>
      </dialog>
    </button>
  }

  <!-- Override Form Modal -->
  @if (showOverrideForm()) {
    <button 
      type="button"
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 cursor-default"
      [attr.aria-label]="'common.close' | translate"
      (click)="closeOverrideForm()" 
      (keydown.escape)="closeOverrideForm()"
    >
      <dialog 
        class="relative w-full max-w-md rounded-lg bg-white p-6 shadow-xl"
        [open]="true"
        tabindex="0"
        (click)="$event.stopPropagation()"
        (keydown.escape)="closeOverrideForm()"
      >
        <h3 class="text-lg font-bold uppercase tracking-tight text-black mb-5">
          {{ (editingOverrideId() ? 'appointments.availability.overrides.edit' : 'appointments.availability.overrides.add') | translate }}
        </h3>
        <form (ngSubmit)="saveOverride()" class="space-y-4">
          <shared-input
            type="date"
            [label]="'appointments.availability.overrides.date' | translate"
            [value]="overrideDate()"
            (valueChange)="overrideDate.set($event)"
            [required]="true"
            [clearable]="false"
          />
          
          <shared-checkbox
            [label]="'appointments.availability.overrides.isAvailable' | translate"
            [checked]="overrideIsAvailable()"
            (checkedChange)="overrideIsAvailable.set($event)"
          />
          
          @if (overrideIsAvailable()) {
            <div class="grid grid-cols-2 gap-4">
              <shared-input
                type="time"
                [label]="'appointments.availability.overrides.startTime' | translate"
                [value]="overrideStartTime()"
                (valueChange)="overrideStartTime.set($event)"
                [clearable]="false"
              />
              <shared-input
                type="time"
                [label]="'appointments.availability.overrides.endTime' | translate"
                [value]="overrideEndTime()"
                (valueChange)="overrideEndTime.set($event)"
                [clearable]="false"
              />
            </div>
          }
          
          <div class="flex justify-end gap-3 pt-4 border-t border-zinc-200">
            <shared-button variant="secondary" type="button" (clicked)="closeOverrideForm()">
              {{ 'common.cancel' | translate }}
            </shared-button>
            <shared-button variant="primary" type="submit" [disabled]="!canSaveOverride()">
              {{ 'common.save' | translate }}
            </shared-button>
          </div>
        </form>
      </dialog>
    </button>
  }

  <!-- Quick Setup Modal -->
  @if (showQuickSetup()) {
    <button 
      type="button"
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 cursor-default"
      [attr.aria-label]="'common.close' | translate"
      (click)="closeQuickSetup()" 
      (keydown.escape)="closeQuickSetup()"
    >
      <dialog 
        class="relative w-full max-w-md rounded-lg bg-white p-6 shadow-xl"
        [open]="true"
        tabindex="0"
        (click)="$event.stopPropagation()"
        (keydown.escape)="closeQuickSetup()"
      >
        <h3 class="text-lg font-bold uppercase tracking-tight text-black mb-2">
          {{ 'appointments.availability.quickSetup.title' | translate }}
        </h3>
        <p class="text-sm text-zinc-500 mb-5">
          {{ 'appointments.availability.quickSetup.description' | translate }}
        </p>
        
        <div class="space-y-4">
          <!-- Day Selection -->
          <div>
            <span class="block text-sm font-medium text-zinc-700 mb-2">
              {{ 'appointments.availability.quickSetup.selectDays' | translate }}
            </span>
            <div class="flex flex-wrap gap-2">
              @for (day of weekdays(); track day.value) {
                <button
                  type="button"
                  class="px-3 py-1.5 text-sm font-medium rounded border transition-colors"
                  [class.bg-black]="isQuickSetupDaySelected(day.value)"
                  [class.text-white]="isQuickSetupDaySelected(day.value)"
                  [class.border-black]="isQuickSetupDaySelected(day.value)"
                  [class.bg-white]="!isQuickSetupDaySelected(day.value)"
                  [class.text-zinc-700]="!isQuickSetupDaySelected(day.value)"
                  [class.border-zinc-300]="!isQuickSetupDaySelected(day.value)"
                  [class.hover:border-zinc-400]="!isQuickSetupDaySelected(day.value)"
                  (click)="toggleQuickSetupDay(day.value)"
                >
                  {{ day.label | slice:0:3 }}
                </button>
              }
            </div>
          </div>
          
          <!-- Time Inputs -->
          <div class="grid grid-cols-2 gap-4">
            <shared-input
              type="time"
              [label]="'appointments.availability.rules.startTime' | translate"
              [value]="quickSetupStartTime()"
              (valueChange)="quickSetupStartTime.set($event)"
              [required]="true"
              [clearable]="false"
            />
            <shared-input
              type="time"
              [label]="'appointments.availability.rules.endTime' | translate"
              [value]="quickSetupEndTime()"
              (valueChange)="quickSetupEndTime.set($event)"
              [required]="true"
              [clearable]="false"
            />
          </div>
          
          <p class="text-xs text-zinc-500">
            {{ 'appointments.availability.quickSetup.timezoneNote' | translate:{ timezone: selectedTimezone() } }}
          </p>
          
          @if (quickSetupDays().length > 0) {
            <div class="bg-amber-50 border border-amber-200 rounded p-3">
              <p class="text-sm text-amber-800">
                <lucide-icon name="circle-alert" class="h-4 w-4 inline mr-1" aria-hidden="true"></lucide-icon>
                {{ 'appointments.availability.quickSetup.warning' | translate }}
              </p>
            </div>
          }
          
          <div class="flex justify-end gap-3 pt-4 border-t border-zinc-200">
            <shared-button variant="secondary" type="button" (clicked)="closeQuickSetup()">
              {{ 'common.cancel' | translate }}
            </shared-button>
            <shared-button 
              variant="primary" 
              type="button" 
              [disabled]="quickSetupDays().length === 0 || quickSetupInProgress()"
              (clicked)="applyQuickSetup()"
            >
              @if (quickSetupInProgress()) {
                <div class="animate-spin h-4 w-4 border-2 border-white border-t-transparent rounded-full mr-2"></div>
              }
              {{ 'appointments.availability.quickSetup.apply' | translate }}
            </shared-button>
          </div>
        </div>
      </dialog>
    </button>
  }

  <!-- Delete Confirmation Dialog -->
  <shared-confirm-dialog
    [isOpen]="isDeleteDialogOpen()"
    [title]="'appointments.availability.delete.title' | translate"
    [message]="'appointments.availability.delete.message' | translate"
    [confirmText]="'common.delete' | translate"
    [cancelText]="'common.cancel' | translate"
    confirmVariant="danger"
    [confirmDisabled]="deleteInProgress()"
    (confirm)="confirmDelete()"
    (cancelled)="closeDeleteDialog()"
  />
</div>
</file>

