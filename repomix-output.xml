<shared-page-layout
  [title]="'organization.settings.ai.title' | translate"
  [subtitle]="'organization.settings.ai.subtitle' | translate"
  [error]="errorMessage()"
>
  @if (isLoading()) {
    <div class="mx-auto w-full max-w-4xl flex flex-col gap-6 py-6">
      <shared-skeleton height="12rem" width="100%" />
    </div>
  } @else {
    <div class="mx-auto w-full max-w-4xl flex flex-col gap-6 py-6">
      <shared-card>
        <h4 class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-6">
          {{ 'organization.settings.ai.sectionTitle' | translate }}
        </h4>

        <div class="grid grid-cols-1 gap-5">
          <shared-checkbox
            [label]="'organization.settings.ai.autoDisqualifyJunk' | translate"
            [hint]="'organization.settings.ai.autoDisqualifyJunkHint' | translate"
            [(checked)]="aiAutoDisqualifyJunk"
          />

          <shared-checkbox
            [label]="'organization.settings.ai.autoEstimate' | translate"
            [hint]="'organization.settings.ai.autoEstimateHint' | translate"
            [(checked)]="aiAutoEstimate"
          />

          <shared-checkbox
            [label]="'organization.settings.ai.autoDispatch' | translate"
            [hint]="'organization.settings.ai.autoDispatchHint' | translate"
            [(checked)]="aiAutoDispatch"
          />

          <shared-checkbox
            [label]="'organization.settings.ai.confidenceGateEnabled' | translate"
            [hint]="'organization.settings.ai.confidenceGateEnabledHint' | translate"
            [(checked)]="aiConfidenceGateEnabled"
          />

          <shared-checkbox
            [label]="'organization.settings.ai.adaptiveReasoningEnabled' | translate"
            [hint]="'organization.settings.ai.adaptiveReasoningEnabledHint' | translate"
            [(checked)]="aiAdaptiveReasoningEnabled"
          />

          <shared-checkbox
            [label]="'organization.settings.ai.experienceMemoryEnabled' | translate"
            [hint]="'organization.settings.ai.experienceMemoryEnabledHint' | translate"
            [(checked)]="aiExperienceMemoryEnabled"
          />

          <shared-checkbox
            [label]="'organization.settings.ai.councilEnabled' | translate"
            [hint]="'organization.settings.ai.councilEnabledHint' | translate"
            [(checked)]="aiCouncilEnabled"
          />

          <shared-select
            [label]="'organization.settings.ai.councilConsensusMode' | translate"
            [hint]="'organization.settings.ai.councilConsensusModeHint' | translate"
            [options]="councilConsensusModeOptions()"
            [value]="aiCouncilConsensusMode()"
            (valueChange)="aiCouncilConsensusMode.set($event ?? 'weighted')"
          />

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <shared-number-input
              [label]="'organization.settings.ai.catalogGapThreshold' | translate"
              [(value)]="catalogGapThreshold"
              [min]="1"
              [max]="1000"
              [step]="1"
            />
            <shared-number-input
              [label]="'organization.settings.ai.catalogGapLookbackDays' | translate"
              [(value)]="catalogGapLookbackDays"
              [min]="1"
              [max]="365"
              [step]="1"
              suffix="dagen"
            />
          </div>

          <shared-checkbox
            [label]="'organization.settings.ai.photoAnalysisPreprocessingEnabled' | translate"
            [hint]="'organization.settings.ai.photoAnalysisPreprocessingEnabledHint' | translate"
            [(checked)]="photoAnalysisPreprocessingEnabled"
          />

          <shared-checkbox
            [label]="'organization.settings.ai.photoAnalysisOcrAssistEnabled' | translate"
            [hint]="'organization.settings.ai.photoAnalysisOcrAssistEnabledHint' | translate"
            [(checked)]="photoAnalysisOcrAssistEnabled"
          />

          <shared-textarea
            [label]="'organization.settings.ai.photoAnalysisOcrAssistServiceTypes' | translate"
            [hint]="'organization.settings.ai.photoAnalysisServiceTypesHint' | translate"
            [rows]="3"
            [(value)]="photoAnalysisOcrAssistServiceTypes"
          />

          <shared-checkbox
            [label]="'organization.settings.ai.photoAnalysisLensCorrectionEnabled' | translate"
            [hint]="'organization.settings.ai.photoAnalysisLensCorrectionEnabledHint' | translate"
            [(checked)]="photoAnalysisLensCorrectionEnabled"
          />

          <shared-textarea
            [label]="'organization.settings.ai.photoAnalysisLensCorrectionServiceTypes' | translate"
            [hint]="'organization.settings.ai.photoAnalysisServiceTypesHint' | translate"
            [rows]="3"
            [(value)]="photoAnalysisLensCorrectionServiceTypes"
          />

          <shared-checkbox
            [label]="'organization.settings.ai.photoAnalysisPerspectiveNormalizationEnabled' | translate"
            [hint]="'organization.settings.ai.photoAnalysisPerspectiveNormalizationEnabledHint' | translate"
            [(checked)]="photoAnalysisPerspectiveNormalizationEnabled"
          />

          <shared-textarea
            [label]="'organization.settings.ai.photoAnalysisPerspectiveNormalizationServiceTypes' | translate"
            [hint]="'organization.settings.ai.photoAnalysisServiceTypesHint' | translate"
            [rows]="3"
            [(value)]="photoAnalysisPerspectiveNormalizationServiceTypes"
          />
        </div>
      </shared-card>

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-2">
        <div>
          @if (successMessage()) {
            <p class="text-sm font-bold text-emerald-600 flex items-center gap-2">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              {{ successMessage() }}
            </p>
          }
        </div>

        <shared-button variant="primary" [disabled]="!canSave() || isSaving()" [loading]="isSaving()" (clicked)="save()">
          {{ 'organization.settings.save' | translate }}
        </shared-button>
      </div>
    </div>
  }
</shared-page-layout>
