<shared-card>
  <section class="flex flex-col font-sans gap-6">
  
    <header class="flex items-start justify-between">
      <div class="flex flex-col gap-1">
        <h2 class="text-sm font-semibold text-slate-900">
          {{ 'leads.detail.energyLabel.title' | translate }}
        </h2>
        <p class="text-xs text-slate-500">
          {{ 'leads.detail.energyLabel.subtitle' | translate }}
        </p>
      </div>
  
      @if (energyLabel()?.energieklasse) {
        <div
          [class]="badgeClasses()"
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md text-xs font-bold ring-1 ring-inset"
          [class.ring-slate-200]="!badgeClasses()"
          [class.bg-slate-50]="!badgeClasses()"
          [class.text-slate-700]="!badgeClasses()"
        >
          {{ energyLabel()?.energieklasse }}
        </div>
      }
    </header>
  
    @if (energyLabel(); as label) {
  
      <dl class="grid grid-cols-2 gap-x-4 gap-y-6">
  
        <div class="flex flex-col gap-1">
          <dt class="text-xs text-slate-500">
            {{ 'leads.detail.energyLabel.validUntil' | translate }}
          </dt>
