<file path="../portal_final/src/app/shared/components/call-logger-dialog/call-logger-dialog.component.html">
@if (isOpen()) {
  <button
    type="button"
    class="fixed inset-0 bg-black/50 z-60"
    (click)="onBackdropClick()"
    aria-label="Close dialog"
  ></button>
}

<dialog
  [attr.open]="isOpen() ? '' : null"
  class="fixed inset-0 z-70 m-auto w-[calc(100%-2rem)] max-w-2xl border border-zinc-200 bg-white p-0"
  [attr.aria-modal]="true"
  [attr.aria-labelledby]="titleId()"
  [attr.aria-describedby]="descriptionId()"
  tabindex="-1"
  (keydown.escape)="onCancelClick()"
>
  <div class="flex flex-col gap-5 p-6">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-zinc-100 pb-4 -mx-6 px-6">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center bg-blue-600">
          <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <div>
          <h2 class="text-base font-semibold text-zinc-900" [id]="titleId()">
            {{ 'leads.callLogger.title' | translate }}
          </h2>
          <p class="text-sm text-zinc-500">{{ 'leads.callLogger.subtitle' | translate }}</p>
        </div>
      </div>
      <button
        type="button"
        class="p-2 hover:bg-zinc-100 transition-colors text-zinc-400 hover:text-zinc-600"
        (click)="onCancelClick()"
        [disabled]="isProcessing()"
        aria-label="Close dialog"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    @if (!showResult()) {
      <!-- Missing Information Prompts -->
      @if (hasMissingInfo()) {
        <div class="p-3 bg-amber-50 border border-amber-200">
          <div class="flex items-center gap-2 mb-2">
            <svg class="h-4 w-4 text-amber-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <span class="text-sm font-medium text-amber-800">{{ 'leads.callLogger.missingInfoTitle' | translate }}</span>
          </div>
          <ul class="list-disc list-inside space-y-1 text-sm text-amber-700">
            @for (item of missingInformation(); track item) {
              <li>{{ item }}</li>
            }
          </ul>
        </div>
      }

      <!-- Input Form -->
      <div [id]="descriptionId()">
        <label for="summaryTextarea" class="block text-sm font-medium text-zinc-700 mb-2">
          {{ 'leads.callLogger.description' | translate }}
        </label>
        <textarea
          #summaryTextarea
          id="summaryTextarea"
          class="w-full h-28 px-3 py-2 border border-zinc-200 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 disabled:bg-zinc-50 disabled:text-zinc-500 placeholder:text-zinc-400"
          [placeholder]="'leads.callLogger.placeholder' | translate"
          [value]="summaryText()"
          (input)="summaryText.set($any($event.target).value)"
          (keydown)="onKeydown($event)"
          [disabled]="isProcessing()"
          [attr.maxLength]="maxSummaryLength"
        ></textarea>
        <div class="flex items-center justify-between mt-1">
          <span class="text-xs text-zinc-400">{{ summaryRemaining() }} characters left</span>
          @if (summaryTooLong()) {
            <span class="text-xs text-red-600">{{ summaryError() }}</span>
          }
        </div>
      </div>

      <!-- Email Confirmation Option -->
      <div class="flex items-center gap-2">
        <input
          type="checkbox"
          id="sendConfirmationEmail"
          [checked]="sendConfirmationEmail()"
          (change)="toggleEmailConfirmation()"
          [disabled]="isProcessing()"
          class="h-4 w-4 border-zinc-300 text-blue-600 focus:ring-blue-500 disabled:opacity-50"
        />
        <label for="sendConfirmationEmail" class="text-sm text-zinc-600 cursor-pointer select-none">
          {{ 'leads.callLogger.sendConfirmationEmail' | translate }}
        </label>
      </div>

      <!-- Availability Checker - Week View -->
      <div class="border border-zinc-200 overflow-hidden">
        <button
          type="button"
          class="w-full flex items-center justify-between px-4 py-3 bg-zinc-50 hover:bg-zinc-100 transition-colors text-left"
          (click)="toggleAvailabilityPanel()"
          [disabled]="isProcessing()"
        >
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center bg-green-100">
              <svg class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
            </div>
            <div>
              <span class="text-sm font-medium text-zinc-800">{{ 'leads.callLogger.checkAvailability' | translate }}</span>
              <p class="text-xs text-zinc-500">{{ 'leads.callLogger.viewWeekSlots' | translate }}</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            @if (selectedSlot()) {
              <span class="text-xs font-medium text-green-600 bg-green-100 px-2 py-0.5">1 selected</span>
            }
            <svg
              class="h-5 w-5 text-zinc-400 transition-transform duration-200"
              [class.rotate-180]="showAvailabilityPanel()"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </button>

        @if (showAvailabilityPanel()) {
          <div class="border-t border-zinc-200 bg-white">
            <!-- Week Navigation -->
            <div class="flex items-center justify-between px-4 py-2 bg-zinc-50 border-b border-zinc-100">
              <button
                type="button"
                class="p-1.5 hover:bg-zinc-200 disabled:opacity-30 disabled:cursor-not-allowed transition-colors"
                [disabled]="!canGoPrevWeek() || slotsLoading()"
                (click)="goToPrevWeek()"
                aria-label="Previous week"
              >
                <svg class="h-5 w-5 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                </svg>
              </button>
              <div class="text-center">
                <span class="text-sm font-semibold text-zinc-800">
                  {{ weekLabel().start | date:'MMMM d' }} - {{ weekLabel().end | date:'d, yyyy' }}
                </span>
              </div>
              <button
                type="button"
                class="p-1.5 hover:bg-zinc-200 disabled:opacity-30 transition-colors"
                [disabled]="slotsLoading()"
                (click)="goToNextWeek()"
                aria-label="Next week"
              >
                <svg class="h-5 w-5 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                </svg>
              </button>
            </div>

            <!-- Week Grid -->
            @if (slotsLoading()) {
              <div class="flex items-center justify-center py-8">
                <svg class="h-6 w-6 text-blue-500 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
              </div>
            } @else if (slotsError()) {
              <div class="text-sm text-red-600 py-4 text-center">{{ slotsError() }}</div>
            } @else {
              <div class="grid grid-cols-5 divide-x divide-zinc-100">
                @for (day of weekDays(); track day.toISOString()) {
                  <div class="min-w-0">
                    <!-- Day Header -->
                    <div
                      class="px-2 py-3 text-center border-b border-zinc-100 transition-colors"
                      [class.bg-blue-50]="isToday(day)"
                      [class.bg-zinc-50/50]="!isToday(day)"
                    >
                      <div class="text-xs font-medium text-zinc-400 uppercase tracking-wide">
                        {{ day | date:'EEE' }}
                      </div>
                      <div
                        class="text-lg font-bold mt-0.5"
                        [class.text-blue-600]="isToday(day)"
                        [class.text-zinc-800]="!isToday(day)"
                      >
                        {{ day | date:'d' }}
                      </div>
                      @if (isToday(day)) {
                        <div class="text-[10px] font-medium text-blue-500 uppercase">Today</div>
                      }
                    </div>
                    <!-- Time Slots -->
                    <div class="p-1.5 space-y-1 max-h-48 overflow-y-auto scrollbar-thin">
                      @for (slot of getSlotsForDate(day); track slot.startTime) {
                        <button
                          type="button"
                          class="w-full px-2 py-1.5 text-xs font-medium transition-colors"
                          [class.bg-green-50]="!isSlotSelected(day, slot)"
                          [class.text-green-700]="!isSlotSelected(day, slot)"
                          [class.border]="!isSlotSelected(day, slot)"
                          [class.border-green-200]="!isSlotSelected(day, slot)"
                          [class.hover:bg-green-100]="!isSlotSelected(day, slot)"
                          [class.bg-blue-600]="isSlotSelected(day, slot)"
                          [class.text-white]="isSlotSelected(day, slot)"
                          (click)="selectSlot(day, slot)"
                        >
                          {{ formatTime(slot.startTime) }}
                        </button>
                      } @empty {
                        <div class="flex flex-col items-center justify-center py-4 text-zinc-300">
                          <svg class="h-6 w-6 mb-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                          </svg>
                          <span class="text-xs">No slots</span>
                        </div>
                      }
                    </div>
                  </div>
                }
              </div>
            }

            <!-- Selected Slot Indicator -->
            @if (selectedSlot()) {
              <div class="px-4 py-2 bg-blue-50 border-t border-blue-100 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                  <span class="text-sm text-blue-800">
                    {{ selectedSlot()?.date | date:'EEE, MMM d' }} {{ 'leads.callLogger.at' | translate }} {{ formatTime(selectedSlot()?.slot?.startTime ?? '') }}
                  </span>
                </div>
                <button
                  type="button"
                  class="p-1 hover:bg-blue-100 text-blue-400 hover:text-blue-600 transition-colors"
                  (click)="selectedSlot.set(null)"
                  aria-label="Clear selection"
                >
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
            }
          </div>
        }
      </div>

      <!-- Actions -->
      <div class="flex justify-end gap-3 pt-2">
        <shared-button
          variant="secondary"
          [disabled]="isProcessing()"
          (clicked)="onCancelClick()"
          ariaLabel="Cancel"
        >
          {{ 'common.cancel' | translate }}
        </shared-button>
        <shared-button
          variant="primary"
          [disabled]="!canSubmit()"
          [loading]="isProcessing()"
          (clicked)="onSubmitClick()"
          ariaLabel="Process call summary"
        >
          @if (isProcessing()) {
            {{ 'leads.callLogger.processing' | translate }}
          } @else {
            {{ 'leads.callLogger.submit' | translate }}
          }
        </shared-button>
      </div>
    } @else {
      <!-- Result -->
      <div [id]="descriptionId()" class="space-y-4">
        <div class="flex items-start gap-3 p-3 bg-green-50 border border-green-200">
          <svg class="h-5 w-5 text-green-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-green-800">{{ 'leads.callLogger.success' | translate }}</p>
            <p class="text-sm text-green-700 mt-1">{{ result()?.message }}</p>
          </div>
        </div>

        <!-- Action summary -->
        <div class="space-y-2">
          @if (result()?.noteCreated) {
            <div class="flex items-center gap-2 text-sm text-zinc-600">
              <svg class="h-4 w-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
              <span>{{ 'leads.callLogger.result.noteCreated' | translate }}</span>
            </div>
          }
          @if (result()?.statusUpdated) {
            <div class="flex items-center gap-2 text-sm text-zinc-600">
              <svg class="h-4 w-4 text-purple-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5" />
              </svg>
              <span>{{ 'leads.callLogger.result.statusUpdated' | translate }} <strong>{{ result()?.statusUpdated }}</strong></span>
            </div>
          }
          @if (result()?.appointmentBooked) {
            <div class="flex items-center gap-2 text-sm text-zinc-600">
              <svg class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
              <span>{{ 'leads.callLogger.result.appointmentBooked' | translate }}</span>
            </div>
          }
        </div>
      </div>

      <!-- Close button -->
      <div class="flex justify-end pt-2">
        <shared-button
          variant="primary"
          (clicked)="onCancelClick()"
          ariaLabel="Close"
        >
          {{ 'common.close' | translate }}
        </shared-button>
      </div>
    }
  </div>
</dialog>
