                [placeholder]="'webhook.fields.domainsPlaceholder' | translate"
                [hint]="'webhook.fields.domainsHint' | translate"
                [(value)]="webhookKeyDomains"
              />

              <div class="flex justify-end">
                <shared-button
                  variant="primary"
                  size="compact"
                  [fullWidth]="false"
                  [loading]="isWebhookKeySaving()"
                  [disabled]="!webhookKeyName().trim()"
