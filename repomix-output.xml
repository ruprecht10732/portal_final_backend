<div class="flex flex-col w-full pb-16 sm:pb-0">
  <div class="border-b border-zinc-200">
    <shared-page-header
      [title]="serviceType()?.name || ('services.detail.loading' | translate)"
      [subtitle]="serviceType()?.slug || '—'"
      [backAriaLabel]="'common.back' | translate"
      (back)="goBack()"
    >
      @if (serviceType()) {
        <div actions class="flex items-center gap-2">
          <shared-button
            type="button"
            variant="danger"
            size="compact"
            [fullWidth]="false"
            (clicked)="openDeleteDialog()"
          >
            <lucide-icon name="trash-2" class="h-4 w-4 mr-2" aria-hidden="true"></lucide-icon>
            {{ 'services.detail.delete' | translate }}
          </shared-button>
        </div>
      }
    </shared-page-header>
  </div>

  <!-- Mobile action -->
  @if (serviceType()) {
    <div class="sm:hidden border-b border-gray-100 bg-white px-5 py-3">
      <shared-button variant="danger" size="compact" [fullWidth]="true" (clicked)="openDeleteDialog()">
        <lucide-icon name="trash-2" class="h-4 w-4"></lucide-icon>
        {{ 'services.detail.delete' | translate }}
      </shared-button>
    </div>
  }

  <!-- Error Alert -->
  @if (error()) {
    <div class="bg-red-50 border-b border-red-500 text-red-900 p-4 text-sm font-medium flex items-start gap-3">
      <span class="font-bold uppercase text-red-600 shrink-0">{{ 'services.detail.errorLabel' | translate }}</span>
      <span>{{ error() }}</span>
    </div>
  }

  <!-- Loading State -->
  @if (loading()) {
    <div class="flex-1 flex flex-col items-center justify-center p-12 gap-4">
      <div class="animate-spin h-10 w-10 border-4 border-zinc-100 border-t-black"></div>
      <p class="text-xs font-mono uppercase text-zinc-400">{{ 'services.detail.loading' | translate }}</p>
    </div>
  } @else if (serviceType(); as item) {
    <div class="flex-1 overflow-y-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 w-full border-b border-zinc-200">
        <!-- Section A: Basics -->
        <section class="p-4 sm:p-6 border-b md:border-b-0 md:border-r border-zinc-200">
          <div class="flex items-center gap-3 mb-6">
            <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">A</span>
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
              {{ 'services.detail.sections.basics' | translate }}
            </h2>
          </div>

          <dl class="space-y-5">
            <div>
              <dt class="text-xs font-bold uppercase tracking-wider text-zinc-400">
                {{ 'services.detail.fields.name' | translate }}
              </dt>
              <dd class="mt-1 text-sm font-medium text-zinc-900">
                {{ item.name }}
              </dd>
            </div>

            <div>
              <dt class="text-xs font-bold uppercase tracking-wider text-zinc-400">
                {{ 'services.detail.fields.slug' | translate }}
              </dt>
              <dd class="mt-1 text-sm font-mono text-zinc-600">
                {{ item.slug }}
              </dd>
            </div>

            @if (item.description) {
              <div>
                <dt class="text-xs font-bold uppercase tracking-wider text-zinc-400">
                  {{ 'services.detail.fields.description' | translate }}
                </dt>
                <dd class="mt-1 text-sm text-zinc-700 whitespace-pre-wrap">
                  {{ item.description }}
                </dd>
              </div>
            }

            @if (item.intakeGuidelines) {
              <div>
                <dt class="text-xs font-bold uppercase tracking-wider text-zinc-400">
                  {{ 'services.detail.fields.intakeGuidelines' | translate }}
                </dt>
                <dd class="mt-1 text-sm text-zinc-700 whitespace-pre-wrap">
                  {{ item.intakeGuidelines }}
                </dd>
              </div>
            }

            @if (item.estimationGuidelines) {
              <div>
                <dt class="text-xs font-bold uppercase tracking-wider text-zinc-400">
                  {{ 'services.detail.fields.estimationGuidelines' | translate }}
                </dt>
                <dd class="mt-1 text-sm text-zinc-700 whitespace-pre-wrap">
                  {{ item.estimationGuidelines }}
                </dd>
              </div>
            }
          </dl>
        </section>

        <!-- Section B: Configuration -->
        <section class="p-4 sm:p-6">
          <div class="flex items-center gap-3 mb-6">
            <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">B</span>
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
              {{ 'services.detail.sections.configuration' | translate }}
            </h2>
          </div>

          <dl class="space-y-5">
            <div>
              <dt class="text-xs font-bold uppercase tracking-wider text-zinc-400">
                {{ 'services.detail.fields.status' | translate }}
              </dt>
              <dd class="mt-2">
                <span
                  class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold"
                  [class.bg-emerald-100]="isActive()"
                  [class.text-emerald-700]="isActive()"
                  [class.bg-zinc-200]="!isActive()"
                  [class.text-zinc-600]="!isActive()"
                >
                  {{ isActive() ? ('services.detail.status.active' | translate) : ('services.detail.status.inactive' | translate) }}
                </span>
              </dd>
            </div>

            <div>
              <dt class="text-xs font-bold uppercase tracking-wider text-zinc-400">
                {{ 'services.detail.fields.icon' | translate }}
              </dt>
              <dd class="mt-2">
                @if (item.icon) {
                  <div class="flex items-center gap-2 text-sm text-zinc-700">
                    <lucide-icon [name]="item.icon" class="h-4 w-4" aria-hidden="true"></lucide-icon>
                    <span class="font-mono">{{ item.icon }}</span>
                  </div>
                } @else {
                  <span class="text-sm text-zinc-500">—</span>
                }
              </dd>
            </div>

            <div>
              <dt class="text-xs font-bold uppercase tracking-wider text-zinc-400">
                {{ 'services.detail.fields.color' | translate }}
              </dt>
              <dd class="mt-2">
                @if (item.color) {
                  <div class="flex items-center gap-2 text-sm text-zinc-700">
