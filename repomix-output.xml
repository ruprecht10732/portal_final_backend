<main class="min-h-screen bg-zinc-50 flex flex-col">
  <section class="flex-1 flex items-center justify-center px-4 py-10">
    <div class="w-full max-w-2xl bg-white border border-zinc-200 p-6 sm:p-8 space-y-6">
      <header class="space-y-4 text-left">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div class="space-y-2">
            <p class="text-[10px] uppercase tracking-[0.35em] text-zinc-400 font-semibold">
              {{ 'onboarding.title' | translate }}
            </p>
            <h1 class="text-2xl sm:text-3xl font-bold uppercase tracking-tight">{{ stepTitle() }}</h1>
            <p class="text-sm text-zinc-500">{{ stepSubtitle() }}</p>
          </div>

          @if (totalSteps() > 1) {
            <div class="shrink-0 rounded-full border border-zinc-200 bg-zinc-50 px-3 py-1 text-[11px] uppercase tracking-[0.3em] text-zinc-500">
              {{ 'onboarding.stepLabel' | translate:{ current: currentStep(), total: totalSteps() } }}
            </div>
          }
        </div>

        @if (totalSteps() > 1) {
          <div class="h-1.5 w-full rounded-full bg-zinc-100 overflow-hidden">
            <div
              class="h-full rounded-full bg-zinc-900 transition-all duration-300 ease-out"
              [style.width]="progressWidth()"
            ></div>
          </div>
        }
      </header>

      @if (globalError()) {
        <div
          role="alert"
          aria-live="polite"
          class="border border-red-200 bg-red-50 px-4 py-3 text-xs uppercase tracking-widest font-semibold text-red-600"
        >
          {{ globalError() }}
        </div>
      }

      <form class="space-y-6" (submit)="handleSubmit(); $event.preventDefault();">
        @if (currentStep() === 1) {
          <div class="grid gap-4 sm:grid-cols-2">
            <shared-input
              [(value)]="firstName"
              [label]="'onboarding.fields.firstName.label' | translate"
              [placeholder]="'onboarding.fields.firstName.placeholder' | translate"
              [required]="true"
              [error]="firstNameError()"
            />
            <shared-input
              [(value)]="lastName"
              [label]="'onboarding.fields.lastName.label' | translate"
              [placeholder]="'onboarding.fields.lastName.placeholder' | translate"
              [required]="true"
              [error]="lastNameError()"
            />
          </div>
        }

        @if (needsOrganization() && currentStep() === 2) {
          <div class="space-y-4">
            <shared-input
              [(value)]="organizationName"
              [label]="'onboarding.fields.organizationName.label' | translate"
              [placeholder]="'onboarding.fields.organizationName.placeholder' | translate"
              [required]="true"
              [error]="organizationNameError()"
            />
            <div class="grid gap-4 sm:grid-cols-2">
              <shared-input
                [(value)]="organizationEmail"
                [label]="'onboarding.fields.organizationEmail.label' | translate"
                [placeholder]="'onboarding.fields.organizationEmail.placeholder' | translate"
                [type]="'email'"
                [required]="true"
                [error]="organizationEmailError()"
              />
              <shared-input
                [(value)]="organizationPhone"
                [label]="'onboarding.fields.organizationPhone.label' | translate"
                [placeholder]="'onboarding.fields.organizationPhone.placeholder' | translate"
                [type]="'tel'"
                [required]="true"
                [error]="organizationPhoneError()"
              />
            </div>
          </div>
        }

        @if (needsOrganization() && currentStep() === 3) {
          <div class="space-y-4">
            <div class="grid gap-4 sm:grid-cols-2">
              <shared-input
                [(value)]="vatNumber"
                [label]="'onboarding.fields.vatNumber.label' | translate"
                [placeholder]="'onboarding.fields.vatNumber.placeholder' | translate"
                [hint]="'common.optional' | translate"
                [error]="vatNumberError()"
              />
              <shared-input
                [(value)]="kvkNumber"
                [label]="'onboarding.fields.kvkNumber.label' | translate"
                [placeholder]="'onboarding.fields.kvkNumber.placeholder' | translate"
                [hint]="'common.optional' | translate"
                [error]="kvkNumberError()"
              />
            </div>
            <shared-input
              [(value)]="addressLine1"
              [label]="'onboarding.fields.addressLine1.label' | translate"
              [placeholder]="'onboarding.fields.addressLine1.placeholder' | translate"
              [hint]="'common.optional' | translate"
            />
            <shared-input
              [(value)]="addressLine2"
              [label]="'onboarding.fields.addressLine2.label' | translate"
              [placeholder]="'onboarding.fields.addressLine2.placeholder' | translate"
              [hint]="'common.optional' | translate"
            />
            <div class="grid gap-4 sm:grid-cols-2">
              <shared-input
                [(value)]="postalCode"
                [label]="'onboarding.fields.postalCode.label' | translate"
                [placeholder]="'onboarding.fields.postalCode.placeholder' | translate"
                [hint]="'common.optional' | translate"
                [error]="postalCodeError()"
              />
              <shared-input
                [(value)]="city"
                [label]="'onboarding.fields.city.label' | translate"
                [placeholder]="'onboarding.fields.city.placeholder' | translate"
                [hint]="'common.optional' | translate"
              />
            </div>
            <shared-input
              [(value)]="country"
              [label]="'onboarding.fields.country.label' | translate"
              [placeholder]="'onboarding.fields.country.placeholder' | translate"
              [hint]="'common.optional' | translate"
            />
          </div>
        }

        @if (currentStep() === smtpStep()) {
          <div class="space-y-6">
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-xs text-zinc-600">
              <p class="font-semibold uppercase tracking-widest text-zinc-500">
                {{ 'onboarding.smtp.optionalTitle' | translate }}
              </p>
              <p class="mt-2">{{ 'onboarding.smtp.optionalBody' | translate }}</p>
            </div>

            @if (smtpSuccessMessage()) {
              <div class="border border-emerald-200 bg-emerald-50 px-4 py-3 text-xs uppercase tracking-widest font-semibold text-emerald-700">
                {{ smtpSuccessMessage() }}
              </div>
            }

            @if (smtpErrorMessage()) {
              <div class="border border-red-200 bg-red-50 px-4 py-3 text-xs uppercase tracking-widest font-semibold text-red-600">
                {{ smtpErrorMessage() }}
              </div>
            }

            <!-- Auto-detect status banners -->
            @if (isSmtpDetecting()) {
              <div class="flex items-center gap-3 rounded-lg border border-blue-200 bg-blue-50 px-4 py-3">
                <svg class="h-5 w-5 shrink-0 animate-spin text-blue-500" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-widest text-blue-700">
                    {{ 'onboarding.smtp.detectingTitle' | translate }}
                  </p>
                  <p class="mt-0.5 text-xs text-blue-600">
                    {{ 'onboarding.smtp.detectingBody' | translate }}
                  </p>
                </div>
              </div>
            }

            @if (!isSmtpDetecting() && smtpDetectedHost()) {
              <div class="flex items-start gap-3 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3">
                <svg class="h-5 w-5 shrink-0 text-emerald-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-widest text-emerald-700">
                    {{ 'onboarding.smtp.detectedTitle' | translate }}
                  </p>
                  <p class="mt-0.5 text-xs text-emerald-600">
                    {{ 'onboarding.smtp.detectedBody' | translate:{ host: smtpDetectedHost(), port: smtpDetectedPort() } }}
                  </p>
                </div>
              </div>
            }

            @if (!isSmtpDetecting() && smtpDetectionFailed()) {
              <div class="flex items-start gap-3 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
                <svg class="h-5 w-5 shrink-0 text-amber-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-widest text-amber-700">
                    {{ 'onboarding.smtp.detectFailedTitle' | translate }}
                  </p>
                  <p class="mt-0.5 text-xs text-amber-600">
                    {{ 'onboarding.smtp.detectFailedBody' | translate }}
                  </p>
                </div>
              </div>
            }

            <!-- Primary fields: email, name, password -->
            <div class="space-y-4">
              <shared-input
                [(value)]="smtpFromEmail"
                [label]="'onboarding.smtp.fromEmail' | translate"
                [placeholder]="'onboarding.smtp.fromEmailPlaceholder' | translate"
                [type]="'email'"
              />
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <shared-input
                  [(value)]="smtpFromName"
                  [label]="'onboarding.smtp.fromName' | translate"
                  [placeholder]="'onboarding.smtp.fromNamePlaceholder' | translate"
                />
                <shared-input
                  [(value)]="smtpPassword"
                  [label]="'onboarding.smtp.password' | translate"
                  [placeholder]="'onboarding.smtp.passwordPlaceholder' | translate"
                  [type]="'password'"
                  [passwordToggle]="true"
                />
              </div>
            </div>

            <!-- Advanced: host, port, username -->
            <div>
              <button
                type="button"
                class="text-xs font-semibold text-zinc-500 hover:text-zinc-700 uppercase tracking-widest flex items-center gap-1"
                (click)="showSmtpAdvanced.set(!showSmtpAdvanced())"
              >
                <svg class="h-3 w-3 transition-transform" [class.rotate-90]="showSmtpAdvanced()" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
                {{ 'onboarding.smtp.advanced' | translate }}
              </button>
              @if (showSmtpAdvanced()) {
                <div class="mt-3 grid grid-cols-1 gap-4 sm:grid-cols-2">
                  <shared-input
                    [(value)]="smtpHost"
                    [label]="'onboarding.smtp.host' | translate"
                    [placeholder]="'onboarding.smtp.hostPlaceholder' | translate"
                  />
                  <shared-number-input
                    [(value)]="smtpPort"
                    [label]="'onboarding.smtp.port' | translate"
                    [min]="1"
                    [max]="65535"
                    [step]="1"
                  />
                  <shared-input
                    [(value)]="smtpUsername"
                    [label]="'onboarding.smtp.username' | translate"
                    [placeholder]="'onboarding.smtp.usernamePlaceholder' | translate"
                  />
                </div>
              }
            </div>
          </div>
        }

        @if (currentStep() === whatsAppStep()) {
          <div class="space-y-6">
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-xs text-zinc-600">
              <p class="font-semibold uppercase tracking-widest text-zinc-500">
                {{ 'onboarding.whatsapp.optionalTitle' | translate }}
              </p>
              <p class="mt-2">{{ 'onboarding.whatsapp.optionalBody' | translate }}</p>
            </div>

            @if (whatsAppSuccessMessage()) {
              <div class="border border-emerald-200 bg-emerald-50 px-4 py-3 text-xs uppercase tracking-widest font-semibold text-emerald-700">
                {{ whatsAppSuccessMessage() }}
              </div>
            }

            @if (whatsAppErrorMessage()) {
              <div class="border border-red-200 bg-red-50 px-4 py-3 text-xs uppercase tracking-widest font-semibold text-red-600">
                {{ whatsAppErrorMessage() }}
              </div>
            }

            <div class="flex flex-col gap-3">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-zinc-900">{{ 'onboarding.whatsapp.statusLabel' | translate }}</p>
                  <p class="text-xs text-zinc-500">
                    {{ whatsAppStatus()?.message || ('onboarding.whatsapp.statusHint' | translate) }}
                  </p>
                </div>
                <div
                  class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-semibold"
                  [class.bg-emerald-100]="isWhatsAppConnected()"
                  [class.text-emerald-700]="isWhatsAppConnected()"
                  [class.bg-amber-100]="!isWhatsAppConnected() && !isWhatsAppUnregistered()"
                  [class.text-amber-700]="!isWhatsAppConnected() && !isWhatsAppUnregistered()"
                  [class.bg-zinc-100]="isWhatsAppUnregistered()"
                  [class.text-zinc-600]="isWhatsAppUnregistered()"
                >
                  {{ whatsAppStateLabel() }}
                </div>
              </div>

              <div class="flex flex-wrap items-center gap-3">
                @if (isWhatsAppUnregistered()) {
                  <shared-button
                    variant="primary"
                    [disabled]="isWhatsAppAction()"
                    [loading]="isWhatsAppAction()"
                    [fullWidth]="false"
                    (clicked)="connectWhatsApp()"
                  >
                    {{ 'onboarding.whatsapp.connect' | translate }}
                  </shared-button>
                } @else {
                  <shared-button
                    variant="secondary"
                    [disabled]="isWhatsAppAction()"
                    [loading]="isWhatsAppAction()"
                    [fullWidth]="false"
                    (clicked)="reconnectWhatsApp()"
                  >
                    {{ 'onboarding.whatsapp.reconnect' | translate }}
                  </shared-button>
                }
              </div>

              @if (!isWhatsAppUnregistered()) {
                <div class="grid gap-3 rounded-2xl border border-zinc-200 bg-zinc-50 p-4 sm:grid-cols-2">
                  <div class="flex flex-col gap-1 min-w-0">
                    <p class="text-[11px] font-bold uppercase tracking-[0.24em] text-zinc-500">
                      {{ 'onboarding.whatsapp.providerDeviceIdLabel' | translate }}
                    </p>
                    <p class="break-all font-mono text-sm text-zinc-900">
                      {{ whatsAppProviderDeviceId() }}
                    </p>
                    <p class="text-xs text-zinc-500">
                      {{ 'onboarding.whatsapp.providerDeviceIdHint' | translate }}
                    </p>
                  </div>

                  <div class="flex flex-col gap-1 min-w-0">
                    <p class="text-[11px] font-bold uppercase tracking-[0.24em] text-zinc-500">
                      {{ 'onboarding.whatsapp.accountJidLabel' | translate }}
                    </p>
                    @if (whatsAppPairedAccountJid()) {
                      <p class="break-all font-mono text-sm text-zinc-900">
                        {{ whatsAppPairedAccountJid() }}
                      </p>
                    } @else {
                      <p class="text-sm font-semibold text-amber-700">
                        {{ 'onboarding.whatsapp.accountJidPending' | translate }}
                      </p>
                    }
                    <p class="text-xs text-zinc-500">
                      {{ 'onboarding.whatsapp.accountJidHint' | translate }}
                    </p>
                  </div>
                </div>
              }

              @if (!isWhatsAppUnregistered()) {
                <div class="mt-2 grid gap-4 sm:grid-cols-[minmax(0,1fr)_220px] items-start">
                  <div class="flex flex-col gap-2">
                    <p class="text-sm font-semibold text-zinc-900">{{ 'onboarding.whatsapp.qrTitle' | translate }}</p>
                    <p class="text-xs text-zinc-500">{{ 'onboarding.whatsapp.qrHint' | translate }}</p>
                    <shared-button
                      variant="ghost"
                      [disabled]="isWhatsAppAction()"
                      [fullWidth]="false"
                      (clicked)="refreshQr()"
                    >
                      {{ 'onboarding.whatsapp.refreshQr' | translate }}
                    </shared-button>
                  </div>

                  @if (qrUrl()) {
                    <div class="whatsapp-qr">
                      <img
                        [src]="qrUrl()"
                        [alt]="'onboarding.whatsapp.qrAlt' | translate"
                        class="whatsapp-qr__image"
                      />
                    </div>
                  }
                </div>
              }
            </div>
          </div>
        }

        @if (currentStep() === serviceTypeStep()) {
          <div class="space-y-6">
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-xs text-zinc-600">
              <p class="font-semibold uppercase tracking-widest text-zinc-500">
                {{ 'onboarding.service.whyTitle' | translate }}
              </p>
              <p class="mt-2">{{ 'onboarding.service.whyBody' | translate }}</p>
            </div>

            @if (serviceTypeError()) {
              <div
                role="alert"
                aria-live="polite"
                class="border border-red-200 bg-red-50 px-4 py-3 text-xs uppercase tracking-widest font-semibold text-red-600"
              >
                {{ serviceTypeError() }}
              </div>
            }

            <div class="space-y-4">
              <shared-input
                [(value)]="serviceTypeName"
                [label]="'onboarding.service.nameLabel' | translate"
                [placeholder]="'onboarding.service.namePlaceholder' | translate"
                [required]="true"
                [error]="serviceTypeNameError()"
              />

              <shared-textarea
                [(value)]="serviceTypeDescription"
                [label]="'onboarding.service.descriptionLabel' | translate"
                [placeholder]="'onboarding.service.descriptionPlaceholder' | translate"
                [rows]="3"
                [hint]="'common.optional' | translate"
              />
            </div>

            <div class="space-y-3">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-zinc-900">{{ 'onboarding.service.intakeLabel' | translate }}</p>
                  <p class="text-xs text-zinc-500">
                    {{ 'onboarding.service.intakeHint' | translate }}
                  </p>
                </div>
                <shared-button
                  [type]="'button'"
                  [variant]="'secondary'"
                  [fullWidth]="false"
                  (clicked)="showIntakeExamples.set(!showIntakeExamples())"
                >
                  {{ showIntakeExamples() ? ('onboarding.service.hideExamples' | translate) : ('onboarding.service.showExamples' | translate) }}
                </shared-button>
              </div>

              <shared-textarea
                [(value)]="intakeGuidelines"
                label=""
                [placeholder]="'onboarding.service.intakePlaceholder' | translate"
                [rows]="10"
                [required]="true"
                [error]="intakeGuidelinesError()"
              />

              <p class="text-[11px] text-zinc-400">
                {{ intakeGuidelines().length }} / 10000
              </p>
            </div>

            <div class="space-y-3">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-zinc-900">{{ 'onboarding.service.estimationLabel' | translate }}</p>
                  <p class="text-xs text-zinc-500">
                    {{ 'onboarding.service.estimationHint' | translate }}
                  </p>
                </div>
              </div>

              <shared-textarea
                [(value)]="estimationGuidelines"
                label=""
                [placeholder]="'onboarding.service.estimationPlaceholder' | translate"
                [rows]="10"
                [required]="true"
                [error]="estimationGuidelinesError()"
              />

              <p class="text-[11px] text-zinc-400">
                {{ estimationGuidelines().length }} / 10000
              </p>
            </div>

            @if (showIntakeExamples()) {
              <div class="space-y-4 rounded-lg border border-zinc-200 bg-white p-4">
                <p class="text-xs font-semibold uppercase tracking-widest text-zinc-500">{{ 'onboarding.service.examplesTitle' | translate }}</p>
                <div class="space-y-4">
                  @for (example of intakeExamples(); track example.title) {
                    <div class="rounded-md border border-zinc-200 bg-zinc-50 p-3">
                      <p class="text-xs font-semibold text-zinc-700">{{ example.title }}</p>
                      <pre class="mt-2 whitespace-pre-wrap text-xs text-zinc-600 font-mono">{{ example.content }}</pre>
                    </div>
                  }
                </div>
              </div>
            }

            <div class="grid gap-4 sm:grid-cols-2">
              <shared-icon-picker
                [(value)]="serviceTypeIcon"
                [label]="'onboarding.service.iconLabel' | translate"
                [placeholder]="'onboarding.service.iconPlaceholder' | translate"
                [hint]="'common.optional' | translate"
              />
              <shared-color-picker
                [(value)]="serviceTypeColor"
                [label]="'onboarding.service.colorLabel' | translate"
                placeholder="#3B82F6"
                [hint]="'common.optional' | translate"
              />
            </div>
          </div>
        }

        @if (currentStep() === productStep()) {
          <div class="space-y-6">
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-xs text-zinc-600">
              <p class="font-semibold uppercase tracking-widest text-zinc-500">{{ 'onboarding.product.infoTitle' | translate }}</p>
              <p class="mt-2">{{ 'onboarding.product.infoBody' | translate }}</p>
            </div>

            @if (productError()) {
              <div
                role="alert"
                aria-live="polite"
                class="border border-red-200 bg-red-50 px-4 py-3 text-xs uppercase tracking-widest font-semibold text-red-600"
              >
                {{ productError() }}
              </div>
            }

            <div class="grid gap-4 sm:grid-cols-2">
              <shared-input
                [(value)]="productTitle"
                [label]="'onboarding.product.titleLabel' | translate"
                [placeholder]="'onboarding.product.titlePlaceholder' | translate"
                [required]="true"
                [error]="productTitleError()"
              />
              <shared-input
                [(value)]="productReference"
                [label]="'onboarding.product.referenceLabel' | translate"
                [placeholder]="'onboarding.product.referencePlaceholder' | translate"
                [required]="true"
                [error]="productReferenceError()"
              />
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <shared-number-input
                [(value)]="productPrice"
                [label]="'onboarding.product.priceLabel' | translate"
                [placeholder]="'onboarding.product.pricePlaceholder' | translate"
                [prefix]="'€'"
                [required]="true"
                [min]="0"
                [step]="0.01"
                [error]="productPriceError()"
              />
              <shared-select
                [(value)]="productVatRateId"
                [options]="vatRateOptions()"
                [label]="'onboarding.product.vatLabel' | translate"
                [placeholder]="'onboarding.product.vatPlaceholder' | translate"
                [required]="true"
                [error]="productVatRateError()"
              />
            </div>

            <shared-select
              [(value)]="productType"
              [options]="productTypeOptions()"
              [label]="'onboarding.product.typeLabel' | translate"
              [placeholder]="'onboarding.product.typePlaceholder' | translate"
              [required]="true"
              [error]="productTypeError()"
            />

            @if (vatRatesLoading()) {
              <p class="text-xs text-zinc-400">{{ 'onboarding.product.vatLoading' | translate }}</p>
            }
          </div>
        }

        <div class="flex flex-wrap items-center justify-between gap-3">
          @if (totalSteps() > 1 && currentStep() > 1) {
            <shared-button
              [type]="'button'"
              [variant]="'secondary'"
              [fullWidth]="false"
              (clicked)="goBack()"
            >
              {{ 'onboarding.actions.back' | translate }}
            </shared-button>
          }
          @if (currentStep() === smtpStep()) {
            <shared-button
              [type]="'button'"
              [variant]="'secondary'"
              [fullWidth]="false"
              (clicked)="handleSmtpSkip()"
            >
              {{ 'onboarding.actions.skip' | translate }}
            </shared-button>
          }
          @if (currentStep() === whatsAppStep()) {
            <shared-button
              [type]="'button'"
              [variant]="'secondary'"
              [fullWidth]="false"
              (clicked)="handleWhatsAppSkip()"
            >
              {{ 'onboarding.actions.skip' | translate }}
            </shared-button>
          }
          @if (currentStep() === serviceTypeStep()) {
            <shared-button
              [type]="'button'"
              [variant]="'secondary'"
              [fullWidth]="false"
              (clicked)="handleServiceTypeSkip()"
            >
              {{ 'onboarding.actions.skip' | translate }}
            </shared-button>
          }
          @if (currentStep() === productStep()) {
            <shared-button
              [type]="'button'"
              [variant]="'secondary'"
              [fullWidth]="false"
              (clicked)="handleProductSkip()"
            >
              {{ 'onboarding.actions.skip' | translate }}
            </shared-button>
          }
          <shared-button
            [type]="'submit'"
            [loading]="isSaving() || isSmtpSaving() || serviceTypeCreating() || productCreating()"
            [fullWidth]="false"
            [ariaLabel]="'onboarding.actions.finish' | translate"
          >
            {{ primaryLabel() }}
          </shared-button>
        </div>
      </form>
    </div>
  </section>
</file>

