          <div class="relative min-h-screen flex flex-col bg-slate-50">
            <app-quote-proposal-mobile-header
                [quoteNumber]="q.quoteNumber"
                (share)="shareQuote()"
              />

            <!-- Adjusted bottom padding to perfectly fit the new pill footer -->
            <main class="flex-1" [class.pb-[calc(10rem+env(safe-area-inset-bottom))]]="!isFinalized() && !isReadOnly()" [class.pb-[calc(2rem+env(safe-area-inset-bottom))]]="isFinalized() || isReadOnly()">

              <!-- Hero Card -->
              <div class="bg-white px-5 pt-6 pb-8 rounded-b-[2.5rem] shadow-sm ring-1 ring-slate-900/5 mb-6">
                <div class="mb-6 flex items-start justify-between">
                  <div class="flex items-center gap-4">
                    <div class="h-16 w-16 overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm flex-shrink-0">
