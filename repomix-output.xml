<file path="../portal_final/src/app/routes/leads/lead-detail/lead-detail-appointments-tab.component.html">
<div class="flex flex-col gap-6">
  <div class="flex items-center justify-between">
    <div>
      <h3 class="text-lg font-semibold">{{ 'leads.detail.appointments.sectionTitle' | translate }}</h3>
      <p class="text-sm text-zinc-500">{{ 'leads.detail.appointments.sectionSubtitle' | translate }}</p>
    </div>
    <shared-button
      variant="primary"
      size="compact"
      [uppercase]="false"
      [fullWidth]="false"
      (clicked)="toggleAppointmentForm.emit()"
    >
      {{ showAppointmentForm() ? ('leads.detail.appointments.hideForm' | translate) : ('leads.detail.appointments.newAppointment' | translate) }}
    </shared-button>
  </div>

  @if (appointmentsError()) {
    <div role="alert" class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-sm">
      {{ appointmentsError() }}
    </div>
  }

  @if (showAppointmentForm()) {
    <div class="grid gap-4 rounded-xl border border-zinc-200 p-4">
      <div class="grid gap-4 md:grid-cols-3">
        <label class="flex flex-col gap-2 text-sm font-medium">
          {{ 'leads.detail.appointments.date' | translate }}
          <input
            type="date"
            class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
            [min]="minDate() ?? ''"
            [value]="appointmentDate()"
            (input)="setAppointmentDate.emit($any($event.target).value)"
          />
        </label>
        <label class="flex flex-col gap-2 text-sm font-medium">
          {{ 'leads.detail.appointments.time' | translate }}
          <input
            type="time"
            class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
            [value]="appointmentTime()"
            (input)="setAppointmentTime.emit($any($event.target).value)"
          />
        </label>
        <label class="flex flex-col gap-2 text-sm font-medium">
          {{ 'leads.detail.appointments.duration' | translate }}
          <input
            type="number"
            min="15"
            step="5"
            class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
            [value]="appointmentDurationMinutes()"
            (input)="setAppointmentDurationMinutes.emit($any($event.target).value)"
          />
        </label>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <label class="flex flex-col gap-2 text-sm font-medium">
          {{ 'leads.detail.appointments.titleField' | translate }}
          <input
            type="text"
            class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
            [placeholder]="'leads.detail.appointments.titlePlaceholder' | translate"
            [value]="appointmentTitle()"
            (input)="setAppointmentTitle.emit($any($event.target).value)"
          />
        </label>
        <label class="flex flex-col gap-2 text-sm font-medium">
          {{ 'leads.detail.appointments.location' | translate }}
          <input
            type="text"
            class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
            [placeholder]="'leads.detail.appointments.locationPlaceholder' | translate"
            [value]="appointmentLocation()"
            (input)="setAppointmentLocation.emit($any($event.target).value)"
          />
        </label>
      </div>
      <label class="flex flex-col gap-2 text-sm font-medium">
        {{ 'leads.detail.appointments.notes' | translate }}
        <textarea
          rows="3"
          class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
          [placeholder]="'leads.detail.appointments.notesPlaceholder' | translate"
          [value]="appointmentNotes()"
          (input)="setAppointmentNotes.emit($any($event.target).value)"
        ></textarea>
      </label>
      <div class="flex justify-end">
        <shared-button
          variant="primary"
          size="compact"
          [uppercase]="false"
          [fullWidth]="false"
          [disabled]="!canSaveAppointment()"
          (clicked)="createAppointment.emit()"
        >
          {{ appointmentSaving() ? ('leads.detail.appointments.saving' | translate) : ('leads.detail.appointments.createAppointment' | translate) }}
        </shared-button>
      </div>
    </div>
  }

  <div class="grid gap-4 lg:grid-cols-[1fr_1.2fr]">
    <div class="flex flex-col gap-3">
      <h4 class="text-sm font-semibold text-zinc-700">{{ 'leads.detail.appointments.scheduledVisits' | translate }}</h4>
      @if (appointmentsLoading()) {
        <div class="flex items-center gap-2 text-sm text-zinc-500">
          <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-black" aria-hidden="true"></div>
          {{ 'leads.detail.appointments.loadingAppointments' | translate }}
        </div>
      } @else if (appointments().length === 0) {
        <p class="text-sm text-zinc-500">{{ 'leads.detail.appointments.noAppointments' | translate }}</p>
      } @else {
        <div class="flex flex-col gap-2">
          @for (appointment of appointments(); track appointment.id) {
            <button
              type="button"
              class="w-full rounded-lg border px-3 py-3 text-left"
              [class.border-black]="appointment.id === selectedAppointmentId()"
              [class.bg-black]="appointment.id === selectedAppointmentId()"
              [class.text-white]="appointment.id === selectedAppointmentId()"
              [class.border-zinc-200]="appointment.id !== selectedAppointmentId()"
              (click)="selectAppointment.emit(appointment.id)"
            >
              <div class="flex items-center justify-between">
                <span class="text-sm font-semibold">{{ appointment.title }}</span>
                <span
                  class="text-xs uppercase tracking-wide px-2 py-0.5 rounded-full"
                  [class.bg-amber-100]="appointment.status === 'requested'"
                  [class.text-amber-800]="appointment.status === 'requested'"
                  [class.bg-blue-100]="appointment.status === 'scheduled'"
                  [class.text-blue-800]="appointment.status === 'scheduled'"
                  [class.bg-green-100]="appointment.status === 'completed'"
                  [class.text-green-800]="appointment.status === 'completed'"
                  [class.bg-zinc-100]="appointment.status === 'cancelled' || appointment.status === 'no_show'"
                  [class.text-zinc-600]="appointment.status === 'cancelled' || appointment.status === 'no_show'"
                >{{ appointment.status }}</span>
              </div>
              <div class="mt-1 text-xs opacity-80">
                {{ formatHumanDateTime()(appointment.startTime) }}
              </div>
              @if (appointment.status === 'requested') {
                <div class="mt-2 flex justify-end">
                  <button
                    type="button"
                    class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm transition-colors hover:bg-emerald-700 active:scale-95 disabled:opacity-50"
                    [disabled]="approvingAppointmentId() === appointment.id"
                    (click)="$event.stopPropagation(); approveAppointment.emit(appointment.id)"
                  >
                    @if (approvingAppointmentId() === appointment.id) {
                      <div class="animate-spin h-3 w-3 border-2 border-white border-t-transparent rounded-full" aria-hidden="true"></div>
                    }
                    {{ 'leads.detail.appointments.approve' | translate }}
                  </button>
                </div>
              }
            </button>
          }
        </div>
      }
    </div>

    <div class="flex flex-col gap-4">
      <h4 class="text-sm font-semibold text-zinc-700">{{ 'leads.detail.appointments.visitReport' | translate }}</h4>
      @if (!selectedAppointment()) {
        <p class="text-sm text-zinc-500">{{ 'leads.detail.appointments.selectAppointment' | translate }}</p>
      } @else {
        <div class="rounded-xl border border-zinc-200 p-4">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold">{{ selectedAppointment()?.title }}</p>
              <p class="text-xs text-zinc-500">{{ formatHumanDateTime()(selectedAppointment()?.startTime) }}</p>
            </div>
            <span class="text-xs uppercase tracking-wide text-zinc-500">{{ selectedAppointment()?.status }}</span>
          </div>

          @if (selectedAppointment()?.status !== 'completed') {
            <p class="mt-3 text-xs text-zinc-500">
              {{ 'leads.detail.appointments.prepareReport' | translate }}
            </p>
          }

          <div class="mt-4 grid gap-3">
            <label class="flex flex-col gap-2 text-sm font-medium">
              {{ 'leads.detail.appointments.measurements' | translate }}
              <textarea
                rows="3"
                class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                [value]="reportMeasurements()"
                [disabled]="!canEditReport()"
                (input)="setReportMeasurements.emit($any($event.target).value)"
              ></textarea>
            </label>
            <label class="flex flex-col gap-2 text-sm font-medium">
              {{ 'leads.detail.appointments.accessDifficulty' | translate }}
              <select
                class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                [value]="reportAccessDifficulty() ?? ''"
                [disabled]="!canEditReport()"
                (change)="setAccessDifficulty.emit($any($event.target).value)"
              >
                <option value="">{{ 'leads.detail.appointments.selectOption' | translate }}</option>
                @for (option of accessDifficultyOptions(); track option.value) {
                  <option [value]="option.value">{{ option.label }}</option>
                }
              </select>
            </label>
            <label class="flex flex-col gap-2 text-sm font-medium">
              {{ 'leads.detail.appointments.notes' | translate }}
              <textarea
                rows="3"
                class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                [value]="reportNotes()"
                [disabled]="!canEditReport()"
                (input)="setReportNotes.emit($any($event.target).value)"
              ></textarea>
            </label>
            <div class="flex justify-end">
              <shared-button
                variant="primary"
                size="compact"
                [uppercase]="false"
                [fullWidth]="false"
                [disabled]="!canEditReport()"
                (clicked)="saveVisitReport.emit()"
              >
                {{ reportSaving() ? ('leads.detail.appointments.saving' | translate) : ('leads.detail.appointments.saveReport' | translate) }}
              </shared-button>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-zinc-200 p-4">
          <div class="flex items-center justify-between">
            <div>
              <h5 class="text-sm font-semibold">{{ 'leads.detail.appointments.attachments' | translate }}</h5>
              <p class="text-xs text-zinc-500">{{ 'leads.detail.appointments.attachmentsDescription' | translate }}</p>
            </div>
          </div>

          @if (attachmentsLoading()) {
            <p class="mt-3 text-sm text-zinc-500">{{ 'leads.detail.appointments.loadingAttachments' | translate }}</p>
          } @else if (attachments().length === 0) {
            <p class="mt-3 text-sm text-zinc-500">{{ 'leads.detail.appointments.noAttachments' | translate }}</p>
          } @else {
            <div class="mt-3 flex flex-col gap-2">
              @for (attachment of attachments(); track attachment.id) {
                <div class="flex items-center justify-between rounded-lg bg-zinc-50 px-3 py-2 text-xs">
                  <div>
                    <p class="font-semibold">{{ attachment.fileName }}</p>
                    <p class="text-zinc-500">{{ attachment.fileKey }}</p>
                  </div>
                  <div class="text-zinc-500">
                    {{ attachment.sizeBytes ?? 0 }} bytes
                  </div>
                </div>
              }
            </div>
          }

          <div class="mt-4 grid gap-3">
            <div class="grid gap-3 md:grid-cols-2">
              <label class="flex flex-col gap-2 text-sm font-medium">
                {{ 'leads.detail.appointments.fileKey' | translate }}
                <input
                  type="text"
                  class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                  [value]="attachmentFileKey()"
                  (input)="setAttachmentFileKey.emit($any($event.target).value)"
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-medium">
                {{ 'leads.detail.appointments.fileName' | translate }}
                <input
                  type="text"
                  class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                  [value]="attachmentFileName()"
                  (input)="setAttachmentFileName.emit($any($event.target).value)"
                />
              </label>
            </div>
            <div class="grid gap-3 md:grid-cols-2">
              <label class="flex flex-col gap-2 text-sm font-medium">
                {{ 'leads.detail.appointments.contentType' | translate }}
                <input
                  type="text"
                  class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                  [placeholder]="'leads.detail.appointments.contentTypePlaceholder' | translate"
                  [value]="attachmentContentType()"
                  (input)="setAttachmentContentType.emit($any($event.target).value)"
                />
              </label>
              <label class="flex flex-col gap-2 text-sm font-medium">
                {{ 'leads.detail.appointments.sizeBytes' | translate }}
                <input
                  type="number"
                  min="0"
                  class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                  [value]="attachmentSizeBytes()"
                  (input)="setAttachmentSizeBytes.emit($any($event.target).value)"
                />
              </label>
            </div>
            <div class="flex justify-end">
              <shared-button
                variant="primary"
                size="compact"
                [uppercase]="false"
                [fullWidth]="false"
                [disabled]="!canAddAttachment()"
                (clicked)="addAttachment.emit()"
              >
                {{ attachmentSaving() ? ('leads.detail.appointments.saving' | translate) : ('leads.detail.appointments.addAttachment' | translate) }}
              </shared-button>
            </div>
          </div>
        </div>
      }
    </div>
  </div>
</div>
