<file path="../portal_final/src/app/routes/partners/partners-create/partners-create.component.html">
<div class="flex flex-col w-full pb-16 sm:pb-0">
  <shared-page-header
    [title]="'partners.form.newPartner' | translate"
    [subtitle]="'partners.form.subtitle' | translate"
    [backAriaLabel]="'partners.form.goBack' | translate"
    (back)="cancel()"
  ></shared-page-header>

  @if (error()) {
    <div class="bg-red-50 border-b border-red-500 text-red-900 p-4 text-sm font-medium flex items-start gap-3">
      <span class="font-bold uppercase text-red-600 shrink-0">{{ 'partners.form.errorLabel' | translate }}</span>
      <span>{{ error() }}</span>
    </div>
  }

  <form [formGroup]="form" (ngSubmit)="save()" class="flex-1 flex flex-col">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-4 sm:p-6">
      <section class="space-y-4">
        <div class="flex items-center gap-3">
          <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">01</span>
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
            {{ 'partners.form.companyInfo' | translate }}
          </h2>
        </div>

        <shared-input
          [label]="'partners.form.businessName' | translate"
          [value]="form.controls.businessName.value ?? ''"
          (valueChange)="form.controls.businessName.setValue($event)"
          [required]="true"
          [error]="controlError('businessName', { maxLength: 200 })"
        />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <shared-input
            [label]="'partners.form.kvkNumber' | translate"
            [value]="form.controls.kvkNumber.value ?? ''"
            (valueChange)="form.controls.kvkNumber.setValue($event)"
            [required]="false"
            [error]="controlError('kvkNumber', { maxLength: 20, patternError: invalidKvkError() })"
          />
          <shared-input
            [label]="'partners.form.vatNumber' | translate"
            [value]="form.controls.vatNumber.value ?? ''"
            (valueChange)="form.controls.vatNumber.setValue($event)"
            [required]="false"
            [error]="controlError('vatNumber', { maxLength: 20, patternError: invalidVatError() })"
          />
        </div>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-3">
          <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">02</span>
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
            {{ 'partners.form.contactInfo' | translate }}
          </h2>
        </div>

        <shared-input
          [label]="'partners.form.contactName' | translate"
          [value]="form.controls.contactName.value ?? ''"
          (valueChange)="form.controls.contactName.setValue($event)"
          [required]="true"
          [error]="controlError('contactName', { maxLength: 120 })"
        />

        <shared-input
          [label]="'partners.form.contactEmail' | translate"
          type="email"
          [value]="form.controls.contactEmail.value ?? ''"
          (valueChange)="form.controls.contactEmail.setValue($event)"
          [required]="true"
          [error]="emailControlError()"
        />

        <shared-input
          [label]="'partners.form.contactPhone' | translate"
          type="tel"
          [value]="form.controls.contactPhone.value ?? ''"
          (valueChange)="form.controls.contactPhone.setValue($event)"
          (blur)="onContactPhoneBlur()"
          [required]="true"
          [error]="controlError('contactPhone', { maxLength: 50 })"
        />

        @if (isWhatsAppConfigured()) {
          <shared-checkbox
            [label]="'partners.form.whatsappOptedIn' | translate"
            [hint]="'partners.form.whatsappOptedInHelp' | translate"
            [checked]="form.controls.whatsappOptedIn.value ?? true"
            (checkedChange)="form.controls.whatsappOptedIn.setValue($event)"
          />
        } @else if (whatsAppStatus()) {
          <div class="flex items-start justify-between gap-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
            <div class="flex items-start gap-3">
              <svg class="h-5 w-5 shrink-0 text-amber-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
              </svg>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-amber-700">
                  {{ 'partners.form.whatsappNotConfiguredTitle' | translate }}
                </p>
                <p class="mt-0.5 text-xs text-amber-700">
                  {{ 'partners.form.whatsappNotConfiguredMessage' | translate }}
                </p>
              </div>
            </div>
            <shared-button
              variant="secondary"
              type="button"
              [fullWidth]="false"
              [uppercase]="false"
              (clicked)="goToSettings()"
            >
              {{ 'partners.form.whatsappSetupCta' | translate }}
            </shared-button>
          </div>
        }
      </section>

      <section class="space-y-4 md:col-span-2">
        <div class="flex items-center gap-3">
          <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">03</span>
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
            {{ 'partners.form.address' | translate }}
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <shared-autocomplete
            [label]="'partners.form.addressLine1' | translate"
            [value]="form.controls.addressLine1.value ?? ''"
            (valueChange)="onAddressLine1Change($event)"
            [options]="addressOptions()"
            [filterMode]="'manual'"
            [placeholder]="'partners.form.addressSearchPlaceholder' | translate"
            [required]="true"
            [error]="controlError('addressLine1', { maxLength: 200 })"
          />
          <shared-input
            [label]="'partners.form.houseNumber' | translate"
            [value]="form.controls.houseNumber.value ?? ''"
            (valueChange)="onHouseNumberChange($event)"
            [required]="true"
            [error]="controlError('houseNumber', { maxLength: 20 })"
          />
          <shared-input
            [label]="'partners.form.addressLine2' | translate"
            [value]="form.controls.addressLine2.value ?? ''"
            (valueChange)="form.controls.addressLine2.setValue($event)"
            [error]="optionalControlError('addressLine2', 200)"
          />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <shared-input
            [label]="'partners.form.postalCode' | translate"
            [value]="form.controls.postalCode.value ?? ''"
            (valueChange)="onPostalCodeChange($event)"
            [required]="true"
            [error]="controlError('postalCode', { maxLength: 20 })"
          />
          <shared-input
            [label]="'partners.form.city' | translate"
            [value]="form.controls.city.value ?? ''"
            (valueChange)="onCityChange($event)"
            [required]="true"
            [error]="controlError('city', { maxLength: 120 })"
          />
          <shared-input
            [label]="'partners.form.country' | translate"
            [value]="form.controls.country.value ?? ''"
            (valueChange)="onCountryChange($event)"
            [required]="true"
            [error]="controlError('country', { maxLength: 120 })"
          />
        </div>
      </section>

      <section class="space-y-4 md:col-span-2">
        <div class="flex items-center gap-3">
          <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">04</span>
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
            {{ 'partners.form.services' | translate }}
          </h2>
        </div>

        <shared-multiselect
          [label]="'partners.form.serviceTypes' | translate"
          [placeholder]="'partners.form.serviceTypesPlaceholder' | translate"
          [options]="serviceTypeOptions()"
          [value]="form.controls.serviceTypeIds.value ?? []"
          (valueChange)="form.controls.serviceTypeIds.setValue([...$event])"
          [disabled]="serviceTypesLoading()"
          [error]="serviceTypesError() || ''"
        />
      </section>

      <section class="space-y-4 md:col-span-2">
        <div class="flex items-center gap-3">
          <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">05</span>
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
            {{ 'partners.form.logo' | translate }}
          </h2>
        </div>

        @if (logoError()) {
          <div class="bg-red-50 border border-red-200 text-red-800 px-3 py-2 text-sm">
            {{ logoError() }}
          </div>
        }

        @if (logoPreviewUrl() && !logoImageError()) {
          <div class="flex items-center gap-4 rounded-xl border border-zinc-200 p-3">
            <img
              [src]="logoPreviewUrl()"
              [alt]="createdPartner()?.businessName ?? 'Partner logo'"
              class="h-16 w-16 rounded-lg object-cover border border-zinc-200"
              (error)="logoImageError.set(true)"
            />
            <div class="flex flex-col gap-1 text-sm">
              <span class="font-medium">{{ createdPartner()?.logoFileName }}</span>
              @if (logoPreviewUrl()) {
                <a class="text-blue-600 hover:underline" [href]="logoPreviewUrl()" target="_blank" rel="noopener">
                  {{ 'partners.form.logoDownload' | translate }}
                </a>
              }
            </div>
          </div>
        } @else if (createdPartner()) {
          <div class="flex items-center gap-4 rounded-xl border border-dashed border-zinc-200 p-3">
            <div class="h-16 w-16 rounded-lg bg-zinc-100 flex items-center justify-center text-sm font-semibold text-zinc-600">
              {{ logoInitials() }}
            </div>
            <div class="text-sm text-zinc-500">
              {{ 'partners.form.logoEmpty' | translate }}
            </div>
          </div>
        }

        <app-file-uploader
          [label]="'partners.form.logoSelect' | translate"
          [dropLabel]="'common.upload.dropHint' | translate"
          [helpText]="'partners.form.logoHelp' | translate"
          [accept]="'image/*'"
          [buttonLabel]="'partners.form.logoUpload' | translate"
          [uploadingLabel]="'partners.form.logoUploading' | translate"
          [errorFallback]="'partners.form.errors.logoUploadFailed' | translate"
          [maxSizeBytes]="5242880"
          [maxSizeError]="'partners.form.logoMaxSize' | translate"
          [disabled]="!createdPartner() || saving() || logoLoading()"
          [presign]="presignLogo"
          [finalize]="finalizeLogo"
        />
      </section>
    </div>

    <div class="p-4 sm:p-6 flex flex-col-reverse sm:flex-row sm:justify-end gap-3 sm:gap-4">
      @if (submitAttempted() && form.invalid) {
        <p class="text-xs font-semibold uppercase tracking-wide text-red-600 sm:mr-auto">
          {{ 'partners.form.validation.required' | translate }}
        </p>
      }
      <shared-button
        variant="secondary"
        type="button"
        (clicked)="cancel()"
        class="w-full sm:w-auto"
      >
        {{ 'partners.form.cancel' | translate }}
      </shared-button>

      <shared-button
        variant="primary"
        type="button"
        class="w-full sm:w-auto"
        [disabled]="saving()"
        [loading]="saving()"
        (clicked)="createdPartner() ? goToEdit() : save()"
      >
        @if (createdPartner()) {
          {{ 'partners.form.editPartner' | translate }}
        } @else {
          {{ saving() ? ('partners.form.saving' | translate) : ('partners.form.createPartner' | translate) }}
        }
      </shared-button>
    </div>
  </form>
</div>
</file>

