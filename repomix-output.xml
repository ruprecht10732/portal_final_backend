<shared-page-layout
  [title]="'organization.settings.workflows.title' | translate"
  [subtitle]="'organization.settings.workflows.subtitle' | translate"
  [error]="errorMessage()"
>
  @if (isLoading()) {
    <div class="mx-auto w-full max-w-7xl flex flex-col gap-6 py-6">
      <shared-skeleton height="12rem" width="100%" />
      <shared-skeleton height="12rem" width="100%" />
    </div>
  } @else {
    <div class="mx-auto w-full max-w-7xl flex flex-col gap-6 py-6">
      <shared-card>
        <div class="grid gap-4 md:grid-cols-2">
          <shared-select
            [label]="'organization.settings.workflows.activeWorkflowLabel' | translate"
            [options]="workflowOptions()"
            [value]="selectedWorkflowKey()"
            (valueChange)="updateSelectedWorkflow($event)"
            [placeholder]="'organization.settings.workflows.activeWorkflowPlaceholder' | translate"
          />

          <shared-select
            [label]="'organization.settings.workflows.defaultWorkflowLabel' | translate"
            [options]="workflowOptions()"
            [value]="selectedDefaultWorkflowKey()"
            (valueChange)="updateSelectedDefaultWorkflow($event)"
            [placeholder]="'organization.settings.workflows.defaultWorkflowPlaceholder' | translate"
          />
        </div>

        <div class="mt-4 grid gap-4 md:grid-cols-[1fr_auto_auto]">
          <shared-input
            [label]="'organization.settings.workflows.workflowNameLabel' | translate"
            [value]="selectedProfile()?.name ?? ''"
            (valueChange)="updateSelectedWorkflowName($event)"
          />

          <shared-checkbox
            class="self-end"
            [label]="'organization.settings.workflows.enabled' | translate"
            [checked]="selectedProfile()?.enabled ?? true"
            (checkedChange)="updateSelectedWorkflowEnabled($event)"
          />

          <div class="self-end flex gap-2">
            <shared-button
              variant="secondary"
              [fullWidth]="false"
              (clicked)="addWorkflow()"
            >
              {{ 'organization.settings.workflows.addWorkflow' | translate }}
            </shared-button>
            <shared-button
              variant="ghost"
              [fullWidth]="false"
              [disabled]="workflowOptions().length <= 1"
              (clicked)="removeSelectedWorkflow()"
            >
              {{ 'organization.settings.workflows.removeWorkflow' | translate }}
            </shared-button>
          </div>
        </div>
      </shared-card>

      <shared-card>
        <div class="flex flex-col gap-6">
          <div class="flex flex-col gap-3">
            <p class="text-xs font-bold uppercase tracking-widest text-zinc-400">
              {{ 'organization.settings.workflows.actionsLabel' | translate }}
            </p>
            <div class="workflow-actions-row">
              @for (action of actions; track action.id) {
                <button
                  type="button"
                  class="workflow-action-pill shrink-0 rounded-full border border-zinc-300 bg-white px-3.5 py-2 text-xs font-bold uppercase tracking-wide transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-zinc-900 focus-visible:ring-offset-1"
                  [class.text-zinc-800]="selectedAction() !== action.id"
                  [class.hover:border-zinc-400]="selectedAction() !== action.id"
                  [class.hover:bg-zinc-100]="selectedAction() !== action.id"
                  [class.hover:text-zinc-900]="selectedAction() !== action.id"
                  [class.border-zinc-950]="selectedAction() === action.id"
                  [class.bg-zinc-950]="selectedAction() === action.id"
                  [class.text-white]="selectedAction() === action.id"
                  (click)="updateSelectedAction(action.id)"
                >
                  {{ action.titleKey | translate }}
                </button>
              }
            </div>
          </div>

          <div class="grid gap-4 lg:grid-cols-2">
            <shared-card>
              <div class="flex flex-col gap-4">
                <h4 class="text-xs font-bold uppercase tracking-widest text-zinc-400">
                  {{ 'organization.settings.workflows.whatsappColumnTitle' | translate }}
                </h4>

                @if (isChannelAvailable('whatsapp')) {
                  @if (isMultiCardChannel('whatsapp')) {
                    @for (card of selectedChannelCardStates('whatsapp'); track card.key) {
                      <div class="flex flex-col gap-4 rounded-xl border border-zinc-200 p-4">
                        <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">
                          {{ card.titleKey | translate }}
                        </p>

                        <shared-checkbox
                          [label]="'organization.settings.workflows.enabled' | translate"
                          [checked]="card.state.enabled"
                          (checkedChange)="updateEnabled(card.key, $event)"
                        />

                        <shared-number-input
                          [label]="'organization.settings.workflows.delayLabel' | translate"
                          [hint]="card.hintKey | translate"
                          [value]="card.state.delayMinutes"
                          (valueChange)="updateDelay(card.key, $event)"
                          [min]="0"
                          [max]="1440"
                          [step]="1"
                          suffix="min"
                        />

                        <shared-rich-text-editor
                          [label]="'organization.settings.workflows.templateLabel' | translate"
                          [hint]="card.varsKey | translate"
                          [variables]="variablesForTrigger(selectedAction())"
                          [value]="card.state.templateText"
                          (valueChange)="updateTemplate(card.key, $event)"
                          [minHeight]="180"
                          [placeholder]="'organization.settings.workflows.templatePlaceholder' | translate"
                        />
                      </div>
                    }
                  } @else {
                    <shared-checkbox
                      [label]="'organization.settings.workflows.enabled' | translate"
                      [checked]="channelEnabled('whatsapp')"
                      (checkedChange)="updateChannelEnabled('whatsapp', $event)"
                    />

                    <shared-number-input
                      [label]="'organization.settings.workflows.delayLabel' | translate"
                      [hint]="channelHintKey('whatsapp') | translate"
                      [value]="channelDelay('whatsapp')"
                      (valueChange)="updateChannelDelay('whatsapp', $event)"
                      [min]="0"
                      [max]="1440"
                      [step]="1"
                      suffix="min"
                    />

                    <shared-rich-text-editor
                      [label]="'organization.settings.workflows.templateLabel' | translate"
                      [hint]="channelVarsKey('whatsapp') | translate"
                      [variables]="variablesForTrigger(selectedAction())"
                      [value]="channelTemplate('whatsapp')"
                      (valueChange)="updateChannelTemplate('whatsapp', $event)"
                      [minHeight]="180"
                      [placeholder]="'organization.settings.workflows.templatePlaceholder' | translate"
                    />
                  }
                } @else {
                  <p class="text-sm text-zinc-500">
                    {{ 'organization.settings.workflows.channelUnavailable' | translate }}
                  </p>
                }
              </div>
            </shared-card>

            <shared-card>
              <div class="flex flex-col gap-4">
                <h4 class="text-xs font-bold uppercase tracking-widest text-zinc-400">
                  {{ 'organization.settings.workflows.emailColumnTitle' | translate }}
                </h4>

                @if (isChannelAvailable('email')) {
                  @if (isMultiCardChannel('email')) {
                    @for (card of selectedChannelCardStates('email'); track card.key) {
                      <div class="flex flex-col gap-4 rounded-xl border border-zinc-200 p-4">
                        <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">
                          {{ card.titleKey | translate }}
                        </p>

                        <shared-checkbox
                          [label]="'organization.settings.workflows.enabled' | translate"
                          [checked]="card.state.enabled"
                          (checkedChange)="updateEnabled(card.key, $event)"
                        />

                        <shared-input
                          [label]="'organization.settings.workflows.subjectLabel' | translate"
                          [value]="card.state.templateSubject"
                          (valueChange)="updateSubject(card.key, $event)"
                          [placeholder]="'organization.settings.workflows.subjectPlaceholder' | translate"
                          [variables]="variablesForTrigger(selectedAction())"
                        />

                        <shared-number-input
                          [label]="'organization.settings.workflows.delayLabel' | translate"
                          [hint]="card.hintKey | translate"
                          [value]="card.state.delayMinutes"
                          (valueChange)="updateDelay(card.key, $event)"
                          [min]="0"
                          [max]="1440"
