                    >
                      <lucide-icon name="trash-2" class="h-4 w-4"></lucide-icon>
                    </button>
                  </div>
                }
              </div>
            }

            <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4">
              <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)_auto] sm:items-end">
                <shared-input
                  #urlLabel
                  [label]="'offertes.urlLabel' | translate"
                  [placeholder]="'offertes.urlPlaceholder' | translate"
                />
                <shared-input
                  #urlHref
                  [label]="'offertes.urlHref' | translate"
                  [placeholder]="'offertes.urlHrefPlaceholder' | translate"
                />
                <shared-button
                  variant="secondary"
                  [fullWidth]="false"
                  [disabled]="!urlLabel.value().trim() || !urlHref.value().trim()"
                  (clicked)="addUrl(urlLabel.value(), urlHref.value()); urlLabel.value.set(''); urlHref.value.set('')"
                >
                  <lucide-icon name="plus" class="mr-2 h-4 w-4"></lucide-icon>
                  {{ 'offertes.addUrl' | translate }}
                </shared-button>
              </div>
            </div>
          </div>
        </div>
      </details>
    </div>

    <aside class="w-full shrink-0 lg:w-80 xl:w-96 lg:sticky lg:top-[73px] lg:h-[calc(100dvh-73px)] lg:overflow-y-auto">
