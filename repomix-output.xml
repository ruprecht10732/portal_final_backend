<div class="appointments-calendar">
  <!-- Mobile layout -->
  <div class="sm:hidden flex flex-col pb-16">
    <nav class="sticky top-0 z-40 grid grid-cols-[40px_1fr_40px] items-center border-b border-gray-100 bg-white/70 px-4 py-4 backdrop-blur">
      <div></div>
      <div class="flex flex-col items-center">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">{{ 'appointments.calendar' | translate }}</span>
      </div>
      <button
        type="button"
        class="flex h-10 w-10 items-center justify-center rounded-full bg-indigo-600 text-white shadow-lg transition-transform active:scale-95"
        (click)="onCreateClick()"
        [attr.aria-label]="'appointments.createNew' | translate"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
      </button>
    </nav>

    <main>
      @if (loading()) {
        <div class="flex items-center justify-center py-12">
          <div class="h-8 w-8 animate-spin rounded-full border-[3px] border-zinc-200 border-t-black"></div>
        </div>
      } @else if (calendarEvents().length === 0) {
        <div class="flex flex-col items-center justify-center py-16 px-6">
          <div class="h-12 w-12 rounded-full bg-zinc-100 flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
          </div>
          <p class="text-sm font-semibold text-zinc-900">{{ 'appointments.calendar' | translate }}</p>
          <p class="text-xs text-zinc-400 mt-1">{{ 'appointments.calendarEmpty' | translate }}</p>
        </div>
      } @else {
        <div class="flex flex-col">
          @for (event of calendarEvents(); track event.id) {
            <button
              type="button"
              class="flex items-start gap-4 border-b border-gray-100 bg-white px-5 py-4 text-left transition-colors active:bg-zinc-50"
              (click)="onEventClick(event)"
            >
              <div class="flex flex-col items-center pt-0.5">
                <span
                  class="h-3 w-3 rounded-full"
                  [class]="
                    event.status === 'completed' ? 'bg-emerald-500' :
                    event.status === 'cancelled' ? 'bg-zinc-300' :
                    event.status === 'no_show' ? 'bg-amber-500' :
                    'bg-blue-500'
                  "
                ></span>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-slate-900 truncate">{{ event.title }}</h3>
                <p class="text-xs text-slate-500 mt-0.5">
                  {{ event.start | date:'EEE d MMM, HH:mm' }} – {{ event.end | date:'HH:mm' }}
                </p>
              </div>
              <svg class="h-4 w-4 text-zinc-300 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </button>
          }
        </div>
      }
    </main>
  </div>

  <!-- Desktop layout -->
  <div class="hidden sm:block relative">
    <shared-page-layout
      [title]="'appointments.calendar' | translate"
      [subtitle]="'appointments.list.subtitle' | translate"
      [error]="null"
      [removeMobilePadding]="true"
    >
      <shared-button actionsDesktop variant="primary" [fullWidth]="false" (clicked)="onCreateClick()">
        {{ 'appointments.createNew' | translate }}
      </shared-button>

      <div class="calendar-container">
        <shared-calendar-grid
          [events]="calendarEvents()"
          [(view)]="view"
          [maxVisibleEvents]="3"
          [showLegend]="false"
          [allowRange]="false"
          [dayViewStartHour]="8"
          [dayViewEndHour]="18"
          [dayViewTimeSlotMinutes]="30"
          (eventClick)="onEventClick($event)"
          (slotClick)="onSlotClick($event)"
        />
      </div>
    </shared-page-layout>
  </div>

  @if (loading()) {
    <div class="loading-overlay hidden sm:flex">
      <span class="loading-spinner"></span>
    </div>
  }

  <!-- Desktop create overlay -->
  @if (showOverlay() && !isMobileViewport()) {
    <div
      class="hidden sm:block fixed inset-0 z-60 bg-zinc-900/40 backdrop-blur-sm"
      (click)="onOverlayClosed()"
      (keydown.enter)="onOverlayClosed()"
      (keydown.space)="onOverlayClosed()"
      aria-hidden="true"
    ></div>

    <dialog
      [attr.open]="showOverlay() ? '' : null"
      class="hidden sm:block fixed inset-0 z-70 m-auto max-h-[92vh] w-[min(96vw,1200px)] overflow-hidden rounded-2xl border border-zinc-200 bg-white p-0 shadow-2xl focus:outline-none"
      [attr.aria-modal]="true"
      role="dialog"
      [attr.aria-label]="'appointments.form.title' | translate"
    >
      <div class="flex max-h-[92vh] flex-col">
        <div class="flex items-center justify-between border-b border-zinc-200 px-6 py-4">
          <h2 class="text-sm font-bold uppercase tracking-wider text-zinc-500">
            {{ 'appointments.form.title' | translate }}
          </h2>
          <button
            type="button"
            class="rounded-lg p-2 text-zinc-500 transition-colors hover:bg-zinc-100 hover:text-zinc-900"
            [attr.aria-label]="'common.close' | translate"
            (click)="onOverlayClosed()"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div class="flex-1 overflow-y-auto bg-zinc-50/60 p-4 md:p-6">
          <div class="mx-auto w-full max-w-6xl overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm">
            <app-appointment-form
              [isModal]="true"
              [initialDate]="overlayDate()"
              [initialTime]="overlayTime()"
              (formCreated)="onAppointmentCreated($event)"
              (formCancelled)="onOverlayClosed()"
            />
          </div>
        </div>
      </div>
    </dialog>
  }

  <!-- Mobile create overlay -->
  @if (isMobileViewport()) {
    <app-bottom-sheet
      [isOpen]="showOverlay()"
      [title]="'appointments.form.title' | translate"
      [maxHeight]="95"
      (closed)="onOverlayClosed()"
    >
      <app-appointment-form
        [isModal]="true"
        [initialDate]="overlayDate()"
        [initialTime]="overlayTime()"
        (formCreated)="onAppointmentCreated($event)"
        (formCancelled)="onOverlayClosed()"
      />
    </app-bottom-sheet>
  }
</div>
