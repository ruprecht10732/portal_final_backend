<file path="../portal_final/src/app/routes/leads/lead-detail/lead-detail-timeline-tab.component.html">
<div class="flex flex-col gap-6 font-sans text-slate-900">
  
  @if (timelineError()) {
    <div role="alert" class="rounded-lg bg-red-50 border border-red-100 p-3 text-sm text-red-700 flex items-center gap-2">
      <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
      {{ timelineError() }}
    </div>
  }

  @if (timelineLoading()) {
    <div class="flex items-center justify-center py-8 gap-2 text-sm text-slate-500">
      <div class="animate-spin h-4 w-4 border-2 border-indigo-200 border-t-indigo-600 rounded-full"></div>
      {{ t('leads.timeline.loading') }}
    </div>
  } @else if (timelineItems().length === 0) {
    <div class="flex flex-col items-center justify-center py-12 text-center border border-dashed border-slate-200 rounded-xl bg-slate-50/50">
      <p class="text-sm font-medium text-slate-900">{{ t('leads.timeline.empty') }}</p>
    </div>
  } @else {
    <div class="relative pl-4">
      <div class="absolute top-2 bottom-0 left-1.75 w-px bg-slate-200"></div>

      <div class="flex flex-col gap-0">
        @for (item of timelineItems(); track item.id) {
          <div class="group relative pl-8 pb-8 last:pb-0">
            
            <div 
              class="absolute left-0 top-1.5 z-10 h-4 w-4 rounded-full ring-2 ring-white flex items-center justify-center transition-colors"
              [class.bg-indigo-500]="item.type === 'ai'"
              [class.bg-emerald-500]="item.type === 'stage'"
              [class.bg-amber-500]="item.type === 'system'"
              [class.bg-slate-400]="item.type === 'user'"
            >
              <div class="h-1.5 w-1.5 rounded-full bg-white"></div>
            </div>

            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-1.5">
              <span class="text-xs font-mono text-slate-400">
                {{ formatHumanDateTime()(item.timestamp) }}
              </span>
              <span class="text-sm font-bold text-slate-900">
                {{ item.type === 'stage' ? getStageTitle(item) : item.title }}
              </span>
              
              @if (item.type !== 'stage') {
                <span 
                  class="inline-flex items-center rounded-md px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide ring-1 ring-inset"
                  [class.bg-indigo-50]="item.type === 'ai'"
                  [class.text-indigo-700]="item.type === 'ai'"
                  [class.ring-indigo-200]="item.type === 'ai'"

                  [class.bg-amber-50]="item.type === 'system'"
                  [class.text-amber-700]="item.type === 'system'"
                  [class.ring-amber-200]="item.type === 'system'"

                  [class.bg-slate-50]="item.type === 'user'"
                  [class.text-slate-600]="item.type === 'user'"
                  [class.ring-slate-200]="item.type === 'user'"
                >
                  {{ getTimelineTypeLabel()(item.type) }}
                </span>
              }
            </div>

            <p class="text-sm text-slate-600 leading-relaxed max-w-3xl">
              {{ item.summary }}
            </p>

            @if (getTimelineAppointmentApproval()(item); as approval) {
              <div class="mt-3">
                <shared-button
                  variant="primary"
                  size="compact"
                  [fullWidth]="false"
                  [uppercase]="false"
                  [disabled]="approvingAppointmentId() === approval.appointmentId"
                  (clicked)="approveAppointment.emit(approval.appointmentId)"
                  class="bg-emerald-600! text-white! hover:bg-emerald-700! border-emerald-600! shadow-sm"
                >
                  <span class="flex items-center gap-2">
                    @if (approvingAppointmentId() === approval.appointmentId) {
                      <span class="inline-flex h-3 w-3 animate-spin rounded-full border-2 border-white border-t-transparent"></span>
                    }
                    {{ t('leads.detail.appointments.approve') }}
                  </span>
                </shared-button>
              </div>
            }

            @if (getTimelinePartnerSummary()(item); as partnerSummary) {
              <div class="mt-2 flex items-center gap-1.5 text-xs font-medium text-cyan-700">
                <svg class="h-3.5 w-3.5 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
                {{ t('leads.detail.timeline.partnerMatches', { partners: partnerSummary }) }}
              </div>
            }

            @if (getTimelineEstimation()(item); as estimation) {
              <div class="mt-3 rounded-lg border border-amber-200 bg-amber-50/60 p-3 text-xs">
                <div class="grid gap-1.5 text-amber-900">
                  @if (estimation.priceRange) {
                    <div class="flex gap-2">
                      <span class="font-bold w-14 shrink-0">{{ t('leads.detail.timeline.estimationPriceLabel') }}</span>
                      <span>{{ t('leads.detail.timeline.priceRange', { value: estimation.priceRange }) }}</span>
                    </div>
                  }
                  @if (estimation.scope) {
                    <div class="flex gap-2">
                      <span class="font-bold w-14 shrink-0">{{ t('leads.detail.timeline.estimationScopeLabel') }}</span>
                      <span>{{ t('leads.detail.timeline.scope', { value: estimation.scope }) }}</span>
                    </div>
                  }
                  @if (estimation.notes) {
                    <div class="flex gap-2">
                      <span class="font-bold w-14 shrink-0">{{ t('leads.detail.timeline.estimationNotesLabel') }}</span>
                      <span class="text-amber-800 leading-relaxed" [innerHTML]="formatEstimationNotes(t('leads.detail.timeline.estimationNotes', { value: estimation.notes }))"></span>
                    </div>
                  }
                </div>
              </div>
            }

            @if (getTimelineMissingInformation()(item); as missingInformation) {
              @if (missingInformation.length > 0) {
                <div class="mt-3 rounded-lg border border-rose-200 bg-rose-50/60 p-3 text-xs">
                  <div class="mb-1.5 text-[10px] font-bold uppercase tracking-wide text-rose-700">
                    {{ t('leads.detail.timeline.missingInfo') }}
                  </div>
                  <ul class="space-y-1 text-rose-900">
                    @for (missingItem of missingInformation; track missingItem) {
                      <li class="flex items-start gap-1.5">
                        <span class="mt-px text-rose-400">•</span>
                        <span>{{ missingItem }}</span>
                      </li>
                    }
                  </ul>
                </div>
              }
            }

            @if (getTimelineResolvedInformation()(item); as resolvedInformation) {
              @if (resolvedInformation.length > 0) {
                <div class="mt-3 rounded-lg border border-emerald-200 bg-emerald-50/60 p-3 text-xs">
                  <div class="mb-1.5 text-[10px] font-bold uppercase tracking-wide text-emerald-700">
                    {{ t('leads.detail.timeline.resolvedInfo') }}
                  </div>
                  <ul class="space-y-1 text-emerald-950">
                    @for (resolvedItem of resolvedInformation; track resolvedItem) {
                      <li class="flex items-start gap-1.5">
                        <span class="mt-px text-emerald-500">•</span>
                        <span>{{ resolvedItem }}</span>
                      </li>
                    }
                  </ul>
                </div>
              }
            }

            @if (getTimelineExtractedFacts()(item); as extractedFacts) {
              @if (extractedFacts.length > 0) {
                <div class="mt-3 rounded-lg border border-sky-200 bg-sky-50/60 p-3 text-xs">
                  <div class="mb-2 text-[10px] font-bold uppercase tracking-wide text-sky-700">
                    {{ t('leads.detail.timeline.extractedFacts') }}
                  </div>
                  <dl class="grid gap-2 md:grid-cols-2">
                    @for (fact of extractedFacts; track fact.key) {
                      <div class="rounded-md border border-sky-100 bg-white/80 px-2.5 py-2">
                        <dt class="text-[10px] font-bold uppercase tracking-wide text-sky-700">{{ getFactLabel(fact.key) }}</dt>
                        <dd class="mt-1 whitespace-pre-wrap break-words text-slate-800">{{ fact.value }}</dd>
                      </div>
                    }
                  </dl>
                </div>
              }
            }

            @if (getTimelineDraftedQuote()(item); as draftQuote) {
              <div class="mt-3 flex flex-col gap-3 rounded-xl border border-indigo-200 bg-indigo-50/60 p-4">
                <div class="flex gap-3">
                  <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white text-indigo-600 shadow-sm ring-1 ring-inset ring-indigo-200">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-indigo-950">{{ t('leads.detail.timeline.draftQuoteTitle', { number: draftQuote.quoteNumber }) }}</h4>
                    <p class="text-xs text-indigo-700 mt-0.5">
                      {{ t('leads.detail.timeline.draftQuoteSummary', { itemCount: draftQuote.itemCount, catalogItems: draftQuote.catalogItems, adHocItems: draftQuote.adHocItems }) }}
                    </p>
                  </div>
                </div>
                
                <div class="pl-11">
                  <shared-button
                    variant="primary"
                    size="compact"
                    [fullWidth]="false"
                    [uppercase]="false"
                    (clicked)="viewDraftQuote.emit(draftQuote.quoteId)"
                    class="bg-indigo-600! text-white! hover:bg-indigo-700! border-indigo-600! shadow-sm"
                  >
                    <span class="flex items-center gap-2">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      {{ t('leads.detail.timeline.viewDraftQuote') }}
                    </span>
                  </shared-button>
                </div>
              </div>
            }

            @if (getTimelinePhotoAnalysis()(item); as pa) {
              <div class="mt-3 rounded-xl border border-purple-200 bg-purple-50/60 p-4 space-y-3">
                <div class="flex items-center gap-2.5">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white text-purple-600 shadow-sm ring-1 ring-inset ring-purple-200">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-purple-950">{{ t('leads.detail.timeline.photoTitle') }}</h4>
                    <p class="text-xs text-purple-700">{{ pa.photoCount }} {{ pa.photoCount === 1 ? t('leads.detail.timeline.photoSingular') : t('leads.detail.timeline.photoPlural') }} · {{ pa.confidenceLevel }} {{ t('leads.detail.timeline.photoConfidence') }}</p>
                  </div>
                </div>

                @if (pa.hasOcrEvidence || pa.hasOnsiteRequirement) {
                  <div class="flex flex-wrap gap-2">
                    @if (pa.hasOcrEvidence) {
                      <span
                        class="inline-flex items-center gap-1 rounded-full border border-emerald-200 bg-emerald-50 px-2 py-1 text-[10px] font-bold uppercase tracking-[0.08em] text-emerald-800"
                        [attr.aria-label]="t('leads.detail.timeline.photoBadgeOcrHint')"
                        [attr.title]="t('leads.detail.timeline.photoBadgeOcrHint')"
                      >
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                        {{ t('leads.detail.timeline.photoBadgeOcr') }}
                      </span>
                    }
                    @if (pa.hasOnsiteRequirement) {
                      <span
                        class="inline-flex items-center gap-1 rounded-full border border-sky-200 bg-sky-50 px-2 py-1 text-[10px] font-bold uppercase tracking-[0.08em] text-sky-800"
                        [attr.aria-label]="t('leads.detail.timeline.photoBadgeOnsiteHint')"
                        [attr.title]="t('leads.detail.timeline.photoBadgeOnsiteHint')"
                      >
                        <span class="h-1.5 w-1.5 rounded-full bg-sky-500"></span>
                        {{ t('leads.detail.timeline.photoBadgeOnsite') }}
                      </span>
                    }
                  </div>
                }

                <!-- Observations -->
                @if (pa.observations.length > 0) {
                  <div>
                    <h5 class="text-[10px] uppercase font-bold text-purple-600 mb-1">{{ t('leads.detail.timeline.photoObservations') }}</h5>
                    <ul class="space-y-0.5">
                      @for (obs of pa.observations; track obs) {
                        <li class="text-xs text-purple-900 flex items-start gap-1.5">
                          <span class="text-purple-400 mt-px">•</span>
                          <span>{{ obs }}</span>
                        </li>
                      }
                    </ul>
                  </div>
                }

                <!-- Scope + Cost row -->
                @if (pa.scopeAssessment || pa.costIndicators) {
                  <div class="grid grid-cols-2 gap-3">
                    @if (pa.scopeAssessment) {
                      <div>
                        <h5 class="text-[10px] uppercase font-bold text-purple-600 mb-0.5">{{ t('leads.detail.timeline.photoScope') }}</h5>
                        <p class="text-xs text-purple-900 leading-relaxed">{{ pa.scopeAssessment }}</p>
                      </div>
                    }
                    @if (pa.costIndicators) {
                      <div>
                        <h5 class="text-[10px] uppercase font-bold text-purple-600 mb-0.5">{{ t('leads.detail.timeline.photoCost') }}</h5>
                        <p class="text-xs text-purple-900 leading-relaxed">{{ pa.costIndicators }}</p>
                      </div>
                    }
                  </div>
                }

                <!-- Measurements -->
                @if (pa.measurements.length > 0) {
                  <div>
                    <h5 class="text-[10px] uppercase font-bold text-purple-600 mb-1">{{ t('leads.detail.timeline.photoMeasurements') }}</h5>
                    <div class="overflow-x-auto">
                      <table class="w-full text-xs">
                        <thead>
                          <tr class="text-[10px] text-purple-500 border-b border-purple-100">
                            <th class="py-1 pr-2 text-left font-semibold">{{ t('leads.detail.timeline.photoMeasDesc') }}</th>
                            <th class="py-1 pr-2 text-right font-semibold">{{ t('leads.detail.timeline.photoMeasValue') }}</th>
                            <th class="py-1 pr-2 text-left font-semibold">{{ t('leads.detail.timeline.photoMeasType') }}</th>
                            <th class="py-1 text-left font-semibold">{{ t('leads.detail.timeline.photoMeasConf') }}</th>
                          </tr>
                        </thead>
                        <tbody>
                          @for (m of pa.measurements; track m.description) {
                            <tr class="border-b border-purple-50">
                              <td class="py-1 pr-2 text-purple-900">{{ m.description }}</td>
                              <td class="py-1 pr-2 text-right font-mono text-purple-950">{{ m.value }} {{ m.unit }}</td>
                              <td class="py-1 pr-2">
                                <span class="inline-flex items-center px-1 py-px rounded text-[10px] font-bold bg-purple-100 text-purple-700">{{ m.type }}</span>
                              </td>
                              <td class="py-1">
                                <span class="text-[10px] font-medium" [class.text-green-600]="m.confidence === 'High'" [class.text-amber-600]="m.confidence === 'Medium'" [class.text-red-500]="m.confidence === 'Low'">{{ m.confidence }}</span>
                              </td>
                            </tr>
                          }
                        </tbody>
                      </table>
                    </div>
                  </div>
                }

                <!-- Safety Concerns -->
                @if (pa.safetyConcerns.length > 0) {
                  <div class="rounded-lg bg-amber-50 border border-amber-200 p-2.5">
                    <h5 class="text-[10px] uppercase font-bold text-amber-700 mb-1 flex items-center gap-1">
                      <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
                      {{ t('leads.detail.timeline.photoSafety') }}
                    </h5>
                    <ul class="space-y-0.5">
                      @for (c of pa.safetyConcerns; track c) {
                        <li class="text-xs text-amber-800 flex items-start gap-1.5"><span class="text-amber-500 mt-px">⚠</span> {{ c }}</li>
                      }
                    </ul>
                  </div>
                }

                <!-- Discrepancies -->
                @if (pa.discrepancies.length > 0) {
                  <div class="rounded-lg bg-red-50 border border-red-200 p-2.5">
                    <h5 class="text-[10px] uppercase font-bold text-red-700 mb-1 flex items-center gap-1">
                      <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
                      {{ t('leads.detail.timeline.photoDiscrepancies') }}
                    </h5>
                    <ul class="space-y-0.5">
                      @for (d of pa.discrepancies; track d) {
                        <li class="text-xs text-red-800 flex items-start gap-1.5"><span class="text-red-500 mt-px">⚠</span> {{ d }}</li>
                      }
                    </ul>
                  </div>
                }

                <!-- Needs On-site Measurement -->
                @if (pa.needsOnsiteMeasurement.length > 0) {
                  <div class="rounded-lg bg-blue-50 border border-blue-200 p-2.5">
                    <h5 class="text-[10px] uppercase font-bold text-blue-700 mb-1 flex items-center gap-1">
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
                      {{ t('leads.detail.timeline.photoNeedsOnsite') }}
                    </h5>
                    <ul class="space-y-0.5">
                      @for (r of pa.needsOnsiteMeasurement; track r) {
                        <li class="text-xs text-blue-800 flex items-start gap-1.5"><span class="text-blue-400 mt-px">📏</span> {{ r }}</li>
                      }
                    </ul>
                  </div>
                }

                <!-- Extracted Text -->
                @if (pa.extractedText.length > 0) {
                  <div>
                    <h5 class="text-[10px] uppercase font-bold text-purple-600 mb-1">{{ t('leads.detail.timeline.photoExtractedText') }}</h5>
                    <ul class="space-y-0.5">
                      @for (text of pa.extractedText; track text) {
                        <li class="text-xs text-purple-900 flex items-start gap-1.5">
                          <span class="text-purple-400 font-mono mt-px">"</span>
                          <span class="italic">{{ text }}</span>
                        </li>
                      }
                    </ul>
                  </div>
                }

                <!-- Suggested Search Terms -->
                @if (pa.suggestedSearchTerms.length > 0) {
                  <div>
                    <h5 class="text-[10px] uppercase font-bold text-purple-600 mb-1">{{ t('leads.detail.timeline.photoSearchTerms') }}</h5>
                    <div class="flex flex-wrap gap-1">
                      @for (term of pa.suggestedSearchTerms; track term) {
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-bold bg-purple-100 text-purple-800">{{ term }}</span>
                      }
                    </div>
                  </div>
                }
              </div>
            }

            @if (getTimelineRecommendedAction()(item); as action) {
              @if (action === 'CallImmediately') {
                <div class="mt-3 flex flex-col gap-3 rounded-xl border border-rose-200 bg-rose-50/60 p-4">
                  <div class="flex gap-3">
                    <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white text-rose-600 shadow-sm ring-1 ring-inset ring-rose-200">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                      </svg>
                    </div>
                    <div>
                      <h4 class="text-sm font-bold text-rose-950">{{ t('leads.detail.timeline.urgentAction') }}</h4>
                      <p class="text-xs font-medium text-rose-700 mt-0.5">{{ t('leads.detail.timeline.callRecommended') }}</p>
                    </div>
                  </div>
                  
                  <div class="pl-11">
                    <shared-button
                      variant="primary"
                      size="compact"
                      [fullWidth]="false"
                      [uppercase]="false"
                      (clicked)="openCallLogger.emit()"
                      class="bg-rose-600! text-white! hover:bg-rose-700! border-rose-600! shadow-sm"
                    >
                      <span class="flex items-center gap-2">
                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                        </svg>
                        {{ t('leads.callLogger.openButton') }}
                      </span>
                    </shared-button>
                  </div>
                </div>
              }
            }

            @if (getTimelineContactMessage()(item); as contact) {
              <div class="mt-3 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <div 
                  class="flex items-center justify-between px-3 py-2.5 border-b"
                  [class.bg-indigo-50]="contact.channel === 'Email'"
                  [class.border-indigo-100]="contact.channel === 'Email'"
                  [class.bg-emerald-50]="contact.channel === 'WhatsApp'"
                  [class.border-emerald-100]="contact.channel === 'WhatsApp'"
                >
                  <div class="flex items-center gap-2.5">
                    @if (contact.channel === 'WhatsApp') {
                      <div class="flex h-6 w-6 items-center justify-center rounded-full bg-white text-emerald-600 shadow-sm ring-1 ring-inset ring-emerald-200">
                        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                      </div>
                      <span class="text-xs font-bold text-emerald-900">WhatsApp</span>
                      @if (contact.status) {
                        <span
                          class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide"
                          [class.bg-emerald-100]="contact.status === 'sent'"
                          [class.text-emerald-700]="contact.status === 'sent'"
                          [class.bg-slate-200]="contact.status === 'draft'"
                          [class.text-slate-700]="contact.status === 'draft'"
                          [class.bg-rose-100]="contact.status === 'failed'"
                          [class.text-rose-700]="contact.status === 'failed'"
                        >
                          @if (contact.status === 'sent') { {{ t('leads.detail.timeline.whatsappStatusSent') }} }
                          @else if (contact.status === 'failed') { {{ t('leads.detail.timeline.whatsappStatusFailed') }} }
                          @else { {{ t('leads.detail.timeline.whatsappStatusDraft') }} }
                        </span>
                      }
                      @if (contact.phone) {
                        <span class="text-[10px] font-mono text-emerald-700">{{ contact.phone | phoneFormat }}</span>
                      }
                    } @else {
                      <div class="flex h-6 w-6 items-center justify-center rounded-full bg-white text-indigo-600 shadow-sm ring-1 ring-inset ring-indigo-200">
                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
                      </div>
                      <span class="text-xs font-bold text-indigo-900">Email</span>
                    }
                  </div>
                  
                  <button
                    class="group flex items-center gap-1.5 rounded-md px-2 py-1 transition-colors"
                    [class.hover:bg-emerald-100]="contact.channel === 'WhatsApp'"
                    [class.hover:bg-indigo-100]="contact.channel === 'Email'"
                    (clicked)="copyContactMessage.emit({ itemId: item.id, message: contact.message })"
                  >
                    @if (copiedContactMessage() === item.id) {
                       <span class="text-[10px] font-bold text-green-600">{{ t('leads.detail.timeline.copiedLabel') }}</span>
                    } @else {
                       <span class="text-[10px] font-medium text-slate-400 group-hover:text-slate-600">{{ t('leads.detail.timeline.copyLabel') }}</span>
                    }
                  </button>
                </div>

                <div class="p-3.5">
                  <p class="whitespace-pre-wrap text-sm leading-relaxed text-slate-700">{{ contact.message }}</p>
                  
                  <div class="mt-3 pt-3 border-t border-slate-50">
                    @if (contact.channel === 'WhatsApp' && contact.canSend) {
                      @if (whatsAppDeviceAvailable()) {
                        <button 
                          type="button"
                          [disabled]="sendingWhatsAppItemId() === contact.itemId"
                          class="text-xs font-bold text-emerald-600 hover:text-emerald-700 hover:underline inline-flex items-center gap-1"
                          (click)="sendWhatsApp.emit({ itemId: contact.itemId })"
                        >
                          @if (sendingWhatsAppItemId() === contact.itemId) {
                            {{ t('leads.detail.timeline.sendingWhatsApp') }}
                          } @else {
                            {{ t('leads.detail.timeline.sendWhatsApp') }}
                          }
                          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                        </button>
                      } @else {
                        <button
                          type="button"
                          class="text-xs font-bold text-amber-700 hover:text-amber-800 hover:underline inline-flex items-center gap-1"
                          (click)="connectWhatsAppDevice.emit()"
                        >
                          {{ t('leads.detail.timeline.connectWhatsAppDevice') }}
                          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                        </button>
                      }
                    } @else if (contact.channel === 'Email') {
                      <button
                        class="text-xs font-bold text-indigo-600 hover:text-indigo-700 hover:underline inline-flex items-center gap-1"
                        (click)="composeEmail.emit({ email: leadEmail() ?? undefined, message: contact.message })"
                      >
                        {{ t('leads.detail.timeline.replyEmail') }}
                         <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                      </button>
                    }
                  </div>
                </div>
              </div>
            }
          </div>
        }
      </div>
    </div>
  }
</div>
