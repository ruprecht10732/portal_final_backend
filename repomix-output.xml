<file path="../portal_final/src/app/routes/appointments/appointments-list/appointments-list.component.html">
<shared-page-layout
  [title]="'appointments.list.title' | translate"
  [subtitle]="'appointments.list.subtitle' | translate"
  [error]="error()"
  [removeMobilePadding]="true"
>
  <shared-fab-button
    actions
    class="hidden sm:flex"
    [ariaLabel]="'appointments.list.newAppointment' | translate"
    (clicked)="createAppointment()"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
    </svg>
    {{ 'appointments.list.newAppointment' | translate }}
  </shared-fab-button>

  <shared-data-grid
    [columns]="columns()"
    [data]="appointments()"
    [totalItems]="total()"
    [loading]="loading()"
    [config]="gridConfig"
    [serverSide]="true"
    [fetchData]="fetchDataFn"
    (dataRequest)="onDataRequest($event)"
    (deleteRows)="onDeleteAppointments($event)"
    (rowDoubleClick)="onAppointmentDoubleClick($event)"
    [ariaLabel]="'appointments.list.ariaLabel' | translate"
  />

  <shared-confirm-dialog
    [isOpen]="isDeleteDialogOpen()"
    [title]="'appointments.list.deleteTitle' | translate"
    [message]="'appointments.list.deleteMessage' | translate:{count: deleteCount()}"
    [confirmText]="'appointments.list.deleteConfirm' | translate"
    [cancelText]="'appointments.list.deleteCancel' | translate"
    confirmVariant="danger"
    [confirmDisabled]="deleteInProgress()"
    (confirm)="confirmDelete()"
    (cancelled)="closeDeleteDialog()"
  />
</shared-page-layout>
</file>

