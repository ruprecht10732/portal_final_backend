              <p class="mt-1 text-xs text-rose-600">{{ 'partners.offer.wizard.fieldRequired' | translate }}</p>
            }
          </div>
          <div>
            <label for="accept-business-name" class="block text-xs font-bold uppercase tracking-widest text-zinc-400">{{ 'partners.offer.wizard.businessName' | translate }}</label>
            <input id="accept-business-name" type="text" class="mt-2 w-full rounded-2xl border bg-zinc-50 px-4 py-3 text-sm font-semibold text-zinc-900 placeholder:text-zinc-400 focus:outline-none focus:ring-2" [class.border-red-400]="step2Attempted() && !signerBusinessName().trim()" [class.focus:ring-red-500/20]="step2Attempted() && !signerBusinessName().trim()" [class.focus:border-red-500]="step2Attempted() && !signerBusinessName().trim()" [class.border-zinc-200]="!step2Attempted() || signerBusinessName().trim()" [class.focus:ring-teal-500/20]="!step2Attempted() || signerBusinessName().trim()" [class.focus:border-teal-500]="!step2Attempted() || signerBusinessName().trim()" [placeholder]="'partners.offer.wizard.businessNamePlaceholder' | translate" [ngModel]="signerBusinessName()" (ngModelChange)="signerBusinessName.set($event)" />
            @if (step2Attempted() && !signerBusinessName().trim()) {
              <p class="mt-1 text-xs text-rose-600">{{ 'partners.offer.wizard.fieldRequired' | translate }}</p>
            }
          </div>
          <div>
            <label for="accept-address" class="block text-xs font-bold uppercase tracking-widest text-zinc-400">{{ 'partners.offer.wizard.address' | translate }}</label>
            <input id="accept-address" type="text" class="mt-2 w-full rounded-2xl border bg-zinc-50 px-4 py-3 text-sm font-semibold text-zinc-900 placeholder:text-zinc-400 focus:outline-none focus:ring-2" [class.border-red-400]="step2Attempted() && !signerAddress().trim()" [class.focus:ring-red-500/20]="step2Attempted() && !signerAddress().trim()" [class.focus:border-red-500]="step2Attempted() && !signerAddress().trim()" [class.border-zinc-200]="!step2Attempted() || signerAddress().trim()" [class.focus:ring-teal-500/20]="!step2Attempted() || signerAddress().trim()" [class.focus:border-teal-500]="!step2Attempted() || signerAddress().trim()" [placeholder]="'partners.offer.wizard.addressPlaceholder' | translate" [ngModel]="signerAddress()" (ngModelChange)="signerAddress.set($event)" />
            @if (step2Attempted() && !signerAddress().trim()) {
              <p class="mt-1 text-xs text-rose-600">{{ 'partners.offer.wizard.fieldRequired' | translate }}</p>
