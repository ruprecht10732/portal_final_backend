<section class="w-full space-y-6 bg-transparent border-none p-0 sm:bg-white sm:border sm:border-zinc-200 sm:p-6 sm:rounded-sm">
  <!-- Header -->
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="space-y-1">
      <h3 class="text-lg font-semibold text-zinc-900">{{ 'webhook.title' | translate }}</h3>
      <p class="text-sm text-zinc-500">{{ 'webhook.subtitle' | translate }}</p>
    </div>
    <shared-button
      variant="primary"
      size="compact"
      [ariaLabel]="'webhook.createKey' | translate"
      (clicked)="toggleCreateForm()"
    >
      @if (showCreateForm()) {
        {{ 'webhook.cancel' | translate }}
      } @else {
        {{ 'webhook.createKey' | translate }}
      }
    </shared-button>
  </div>

  <!-- Error -->
  @if (errorMessage()) {
    <div class="border-y border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 sm:border sm:rounded-sm">
      {{ errorMessage() }}
    </div>
  }

  <!-- Success -->
  @if (successMessage()) {
    <div class="border-y border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 sm:border sm:rounded-sm">
      {{ successMessage() }}
    </div>
  }

  <!-- GTM Config -->
  <div class="border border-zinc-200 rounded-sm p-4 sm:p-6 space-y-4 bg-white">
    <div class="space-y-1">
      <h4 class="text-sm font-semibold text-zinc-900">{{ 'webhook.whatsapp.title' | translate }}</h4>
      <p class="text-xs text-zinc-500">{{ 'webhook.whatsapp.subtitle' | translate }}</p>
    </div>

    <div class="space-y-2">
      <p class="block text-xs font-medium text-zinc-700">{{ 'webhook.whatsapp.endpoint' | translate }}</p>
      <div class="flex items-center gap-2">
        <code class="flex-1 rounded bg-zinc-50 border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
          {{ whatsAppWebhookUrl() }}
        </code>
        <shared-button
          variant="secondary"
          size="compact"
          [iconOnly]="true"
          shape="square"
          [fullWidth]="false"
          [ariaLabel]="'webhook.whatsapp.copyUrl' | translate"
          (clicked)="copyWebhookUrl()"
        >
          @if (urlCopied()) {
            <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
          } @else {
            <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
          }
        </shared-button>
      </div>
      <p class="text-xs text-zinc-500">{{ 'webhook.whatsapp.headerHint' | translate }}</p>
    </div>
  </div>

  <!-- GTM Config -->
  <div class="border border-zinc-200 rounded-sm p-4 sm:p-6 space-y-4 bg-white">
    <div class="space-y-1">
      <h4 class="text-sm font-semibold text-zinc-900">{{ 'webhook.gtm.title' | translate }}</h4>
      <p class="text-xs text-zinc-500">{{ 'webhook.gtm.subtitle' | translate }}</p>
    </div>

    @if (isGtmLoading()) {
      <div class="flex items-center gap-2 text-sm text-zinc-500">
        <div class="h-4 w-4 animate-spin rounded-full border-2 border-zinc-300 border-t-zinc-900"></div>
        <span>{{ 'webhook.gtm.loading' | translate }}</span>
      </div>
    } @else {
      <shared-input
        [label]="'webhook.gtm.fields.containerId' | translate"
        [placeholder]="'webhook.gtm.fields.containerIdPlaceholder' | translate"
        [hint]="'webhook.gtm.fields.containerIdHint' | translate"
        [(value)]="gtmContainerId"
      />

      <div class="flex justify-end gap-2">
        <shared-button
          variant="secondary"
          size="compact"
          [fullWidth]="false"
          [disabled]="isGtmSaving() || !gtmContainerId()"
          (clicked)="clearGTMConfig()"
        >
          {{ 'webhook.gtm.clear' | translate }}
        </shared-button>
        <shared-button
          variant="primary"
          size="compact"
          [loading]="isGtmSaving()"
          [disabled]="isGtmSaving() || !gtmContainerId()"
          (clicked)="saveGTMConfig()"
        >
          {{ 'webhook.gtm.save' | translate }}
        </shared-button>
      </div>
    }
  </div>

  <!-- Create Form -->
  @if (showCreateForm()) {
    <div class="border border-zinc-200 rounded-sm p-4 sm:p-6 space-y-4 bg-zinc-50">
      <h4 class="text-sm font-semibold text-zinc-900">{{ 'webhook.newKey' | translate }}</h4>

      <shared-input
        [label]="'webhook.fields.name' | translate"
        [placeholder]="'webhook.fields.namePlaceholder' | translate"
        [(value)]="newKeyName"
        [required]="true"
      />

      <shared-input
        [label]="'webhook.fields.domains' | translate"
        [placeholder]="'webhook.fields.domainsPlaceholder' | translate"
        [hint]="'webhook.fields.domainsHint' | translate"
        [(value)]="newKeyDomains"
      />

      <div class="flex justify-end">
        <shared-button
          variant="primary"
          size="compact"
          [loading]="isSaving()"
          [disabled]="!newKeyName()"
          (clicked)="createKey()"
        >
          {{ 'webhook.generate' | translate }}
        </shared-button>
      </div>
    </div>
  }

  <!-- Newly Created Key (show once) -->
  @if (createdKey(); as created) {
    <div class="border border-amber-300 rounded-sm bg-amber-50 p-4 sm:p-6 space-y-5">
      <div class="flex items-start gap-3">
        <lucide-icon name="triangle-alert" class="h-5 w-5 text-amber-600 shrink-0 mt-0.5"></lucide-icon>
        <div class="space-y-1">
          <h4 class="text-sm font-semibold text-amber-900">{{ 'webhook.keyCreated' | translate }}</h4>
          <p class="text-xs text-amber-700">{{ 'webhook.keyCreatedWarning' | translate }}</p>
        </div>
      </div>

      <!-- API Key -->
      <div class="space-y-2">
        <p class="block text-xs font-medium text-zinc-700">{{ 'webhook.fields.apiKey' | translate }}</p>
        <div class="flex items-center gap-2">
          <code class="flex-1 rounded bg-white border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
            {{ created.key }}
          </code>
          <shared-button
            variant="secondary"
            size="compact"
            [iconOnly]="true"
            shape="square"
            [fullWidth]="false"
            [ariaLabel]="'webhook.copyKey' | translate"
            (clicked)="copyApiKey()"
          >
            @if (keyCopied()) {
              <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
            } @else {
              <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
            }
          </shared-button>
        </div>
      </div>

      <div class="space-y-2">
        <p class="block text-xs font-medium text-zinc-700">{{ 'webhook.whatsapp.providerEndpoint' | translate }}</p>
        <div class="flex items-center gap-2">
          <code class="flex-1 rounded bg-white border border-zinc-200 px-3 py-2 text-sm font-mono text-zinc-900 break-all select-all">
            {{ whatsAppProviderWebhookUrl() }}
          </code>
          <shared-button
            variant="secondary"
            size="compact"
            [iconOnly]="true"
            shape="square"
            [fullWidth]="false"
            [ariaLabel]="'webhook.whatsapp.copyUrl' | translate"
            (clicked)="copyWebhookUrl()"
          >
            @if (urlCopied()) {
              <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
            } @else {
              <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
            }
          </shared-button>
        </div>
        <p class="text-xs text-zinc-500">{{ 'webhook.whatsapp.providerHint' | translate }}</p>
      </div>

      <!-- SDK Snippet -->
      <div class="space-y-2">
        <p class="block text-xs font-medium text-zinc-700">{{ 'webhook.fields.snippet' | translate }}</p>
        <div class="flex items-start gap-2">
          <pre class="flex-1 rounded bg-zinc-900 text-emerald-400 px-4 py-3 text-xs font-mono overflow-x-auto whitespace-pre-wrap break-all select-all"><code>{{ sdkSnippet() }}</code></pre>
          <shared-button
            variant="secondary"
            size="compact"
            [iconOnly]="true"
            shape="square"
            [fullWidth]="false"
            [ariaLabel]="'webhook.copySnippet' | translate"
            (clicked)="copySnippet()"
          >
            @if (snippetCopied()) {
              <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
            } @else {
              <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
            }
          </shared-button>
        </div>
      </div>

      <div class="space-y-2">
        <p class="block text-xs font-medium text-zinc-700">{{ 'webhook.whatsapp.exampleRequest' | translate }}</p>
        <div class="flex items-start gap-2">
          <pre class="flex-1 rounded bg-zinc-900 text-sky-300 px-4 py-3 text-xs font-mono overflow-x-auto whitespace-pre-wrap break-all select-all"><code>{{ whatsAppCurlSnippet() }}</code></pre>
          <shared-button
            variant="secondary"
            size="compact"
            [iconOnly]="true"
            shape="square"
            [fullWidth]="false"
            [ariaLabel]="'webhook.whatsapp.copyExample' | translate"
            (clicked)="copyWhatsAppCurl()"
          >
            @if (curlCopied()) {
              <lucide-icon name="check" class="h-4 w-4 text-emerald-600"></lucide-icon>
            } @else {
              <lucide-icon name="copy" class="h-4 w-4"></lucide-icon>
            }
          </shared-button>
        </div>
      </div>

      <!-- Integration Instructions -->
      <div class="space-y-3 border-t border-amber-200 pt-4">
        <h5 class="text-xs font-semibold text-zinc-700 uppercase tracking-wider">{{ 'webhook.instructions.title' | translate }}</h5>
        <ol class="list-decimal list-inside space-y-2 text-sm text-zinc-700">
          <li>{{ 'webhook.instructions.step1' | translate }}</li>
          <li>{{ 'webhook.instructions.step2' | translate }}</li>
          <li>{{ 'webhook.instructions.step3' | translate }}</li>
        </ol>
        <div class="rounded bg-white border border-zinc-200 p-3 space-y-2">
          <p class="text-xs font-medium text-zinc-600">{{ 'webhook.instructions.optionsTitle' | translate }}</p>
          <ul class="text-xs text-zinc-600 space-y-1.5">
            <li><code class="bg-zinc-100 px-1 py-0.5 rounded text-[11px]">data-selector</code> — {{ 'webhook.instructions.optionSelector' | translate }}</li>
            <li><code class="bg-zinc-100 px-1 py-0.5 rounded text-[11px]">data-success-url</code> — {{ 'webhook.instructions.optionSuccess' | translate }}</li>
            <li><code class="bg-zinc-100 px-1 py-0.5 rounded text-[11px]">data-rac-ignore</code> — {{ 'webhook.instructions.optionIgnore' | translate }}</li>
          </ul>
        </div>
      </div>

      <div class="flex justify-end">
        <div class="flex gap-2">
          @if (rotateSourceKey(); as rotating) {
            <shared-button variant="danger" size="compact" (clicked)="confirmRevoke(rotating)">
              {{ 'webhook.rotate.revokePrevious' | translate }}
            </shared-button>
          }
          <shared-button variant="secondary" size="compact" (clicked)="dismissCreatedKey()">
            {{ 'webhook.dismiss' | translate }}
          </shared-button>
        </div>
      </div>
    </div>
  }

  <!-- Loading -->
  @if (isLoading()) {
    <div class="flex items-center justify-center py-12">
      <div class="h-6 w-6 animate-spin rounded-full border-2 border-zinc-300 border-t-zinc-900"></div>
    </div>
  }

  <!-- Active Keys List -->
  @if (!isLoading()) {
    @if (activeKeys().length === 0 && revokedKeys().length === 0) {
      <div class="text-center py-12 space-y-2">
        <lucide-icon name="key-round" class="h-10 w-10 text-zinc-300 mx-auto"></lucide-icon>
        <p class="text-sm text-zinc-500">{{ 'webhook.empty' | translate }}</p>
        <p class="text-xs text-zinc-400">{{ 'webhook.emptyHint' | translate }}</p>
      </div>
    } @else {
      <div class="space-y-3">
        @for (key of activeKeys(); track key.id) {
          <div class="flex flex-col sm:flex-row sm:items-center gap-3 rounded-sm border border-zinc-200 bg-white p-4">
            <div class="flex items-center gap-3 flex-1 min-w-0">
              <div class="flex h-9 w-9 items-center justify-center rounded-md bg-emerald-50 text-emerald-600 shrink-0">
                <lucide-icon name="key-round" class="h-4 w-4"></lucide-icon>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-medium text-zinc-900 truncate">{{ key.name }}</p>
                <p class="text-xs text-zinc-500">
                  <span class="font-mono">{{ key.keyPrefix }}•••</span>
                  · {{ formatDate(key.createdAt) }}
                </p>
              </div>
            </div>

            @if (key.allowedDomains.length > 0) {
              <div class="flex flex-wrap gap-1 sm:mr-4">
                @for (domain of key.allowedDomains; track domain) {
                  <span class="inline-flex items-center rounded-full bg-zinc-100 px-2 py-0.5 text-[11px] text-zinc-600 font-mono">
                    {{ domain }}
                  </span>
                }
              </div>
            }

            <shared-button
              variant="secondary"
              size="compact"
              [fullWidth]="false"
              [disabled]="isSaving()"
              (clicked)="rotateKey(key)"
            >
              {{ 'webhook.rotate.action' | translate }}
            </shared-button>

            <shared-button
              variant="danger"
              size="compact"
              [fullWidth]="false"
              [disabled]="isSaving()"
              (clicked)="confirmRevoke(key)"
            >
              {{ 'webhook.revoke' | translate }}
            </shared-button>
          </div>
        }
      </div>

      <!-- Revoked Keys -->
      @if (revokedKeys().length > 0) {
        <div class="space-y-2 mt-6">
          <h4 class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">{{ 'webhook.revokedKeys' | translate }}</h4>
          @for (key of revokedKeys(); track key.id) {
            <div class="flex items-center gap-3 rounded-sm border border-zinc-100 bg-zinc-50 p-3 opacity-60">
              <div class="flex h-8 w-8 items-center justify-center rounded-md bg-zinc-100 text-zinc-400 shrink-0">
                <lucide-icon name="key-round" class="h-4 w-4"></lucide-icon>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm text-zinc-500 truncate">{{ key.name }}</p>
                <p class="text-xs text-zinc-400 font-mono">{{ key.keyPrefix }}•••</p>
              </div>
              <span class="text-xs text-red-400 font-medium">{{ 'webhook.statusRevoked' | translate }}</span>
            </div>
          }
        </div>
      }
    }
  }
</section>

<!-- Revoke Confirm Dialog -->
<shared-confirm-dialog
  [isOpen]="showRevokeDialog()"
  [title]="'webhook.revokeConfirm.title' | translate"
  [message]="'webhook.revokeConfirm.message' | translate"
  [confirmText]="'webhook.revokeConfirm.confirm' | translate"
  [cancelText]="'webhook.revokeConfirm.cancel' | translate"
  confirmVariant="danger"
  (confirm)="executeRevoke()"
  (cancelled)="cancelRevoke()"
/>
</file>

