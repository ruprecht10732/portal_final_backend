<file path="../portal_final/src/app/routes/catalog/catalog-edit/catalog-edit.component.html">
<div class="flex flex-col w-full">
  <shared-page-header
    [title]="'catalog.products.editTitle' | translate"
    [subtitle]="product()?.reference ?? ''"
    [backAriaLabel]="'catalog.products.goBack' | translate"
    (back)="cancel()"
  ></shared-page-header>

  <!-- Error Alert -->
  @if (error()) {
    <div class="bg-red-50 border-b border-red-500 text-red-900 p-4 text-sm font-medium flex items-start gap-3">
      <span class="font-bold uppercase text-red-600 shrink-0">{{ 'catalog.products.errorLabel' | translate }}</span>
      <span>{{ error() }}</span>
    </div>
  }

  <!-- Loading State -->
  @if (loading()) {
    <div class="flex-1 flex flex-col items-center justify-center p-12 gap-4">
      <div class="animate-spin h-10 w-10 border-4 border-zinc-100 border-t-black"></div>
      <p class="text-xs font-mono uppercase text-zinc-400">{{ 'catalog.products.loading' | translate }}</p>
    </div>
  } @else if (product()) {
    <!-- Tabs (if service type) -->
    @if (showMaterialsTab() || showAssetsTab()) {
      <div class="border-b border-zinc-200 px-4 sm:px-6">
        <nav class="flex gap-6" aria-label="Tabs">
          <button
            type="button"
            (click)="setActiveTab('details')"
            class="py-3 text-sm font-bold uppercase tracking-wider border-b-2 transition-colors"
            [class.border-black]="activeTab() === 'details'"
            [class.text-black]="activeTab() === 'details'"
            [class.border-transparent]="activeTab() !== 'details'"
            [class.text-zinc-500]="activeTab() !== 'details'"
            [class.hover:text-zinc-700]="activeTab() !== 'details'"
          >
            {{ 'catalog.products.tabs.details' | translate }}
          </button>
          @if (showMaterialsTab()) {
            <button
              type="button"
              (click)="setActiveTab('materials')"
              class="py-3 text-sm font-bold uppercase tracking-wider border-b-2 transition-colors"
              [class.border-black]="activeTab() === 'materials'"
              [class.text-black]="activeTab() === 'materials'"
              [class.border-transparent]="activeTab() !== 'materials'"
              [class.text-zinc-500]="activeTab() !== 'materials'"
              [class.hover:text-zinc-700]="activeTab() !== 'materials'"
            >
              {{ 'catalog.products.tabs.materials' | translate }}
              @if (materials().length > 0) {
                <span class="ml-2 bg-zinc-200 text-zinc-600 px-1.5 py-0.5 text-xs font-bold rounded-sm">
                  {{ materials().length }}
                </span>
              }
            </button>
          }
          <button
            type="button"
            (click)="setActiveTab('assets')"
            class="py-3 text-sm font-bold uppercase tracking-wider border-b-2 transition-colors"
            [class.border-black]="activeTab() === 'assets'"
            [class.text-black]="activeTab() === 'assets'"
            [class.border-transparent]="activeTab() !== 'assets'"
            [class.text-zinc-500]="activeTab() !== 'assets'"
            [class.hover:text-zinc-700]="activeTab() !== 'assets'"
          >
            {{ 'catalog.products.tabs.assets' | translate }}
          </button>
        </nav>
      </div>
    }

    <!-- Details Tab -->
    @if (activeTab() === 'details') {
      <catalog-form
        [vatRates]="vatRates()"
        [initialValue]="formInitialValue()"
        [saving]="saving()"
        [submitLabel]="'catalog.products.saveChanges' | translate"
        [cancelLabel]="'catalog.products.cancel' | translate"
        (typeChanged)="handleTypeChange($event)"
        (submitted)="save($event)"
        (cancelled)="cancel()"
      ></catalog-form>
    }

    <!-- Materials Tab -->
    @if (activeTab() === 'materials') {
      <div class="flex-1 flex flex-col p-4 sm:p-6">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-sm font-bold uppercase tracking-wider text-zinc-900">
              {{ 'catalog.products.linkedMaterials' | translate }}
            </h2>
            <p class="text-xs text-zinc-500 mt-1">
              {{ 'catalog.products.linkedMaterialsDescription' | translate }}
            </p>
          </div>
          <shared-button
            variant="secondary"
            size="compact"
            [fullWidth]="false"
            (clicked)="openAddMaterialDialog()"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            {{ 'catalog.products.addMaterial' | translate }}
          </shared-button>
        </div>

        @if (materialsLoading()) {
          <div class="flex items-center justify-center p-12">
            <div class="animate-spin h-8 w-8 border-4 border-zinc-200 border-t-black rounded-full"></div>
          </div>
        } @else if (materials().length === 0) {
          <div class="border border-dashed border-zinc-300 rounded-lg p-12 text-center">
            <svg class="mx-auto h-12 w-12 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <h3 class="mt-4 text-sm font-semibold text-zinc-900">{{ 'catalog.products.noMaterials' | translate }}</h3>
            <p class="mt-1 text-sm text-zinc-500">{{ 'catalog.products.noMaterialsDescription' | translate }}</p>
          </div>
        } @else {
          <div class="border border-zinc-200 bg-white divide-y divide-zinc-100">
            @for (material of materials(); track material.id) {
              <div class="flex items-center justify-between p-4 hover:bg-zinc-50 transition-colors">
                <div class="flex items-center gap-4">
                  <div>
                    <p class="text-sm font-medium text-zinc-900">{{ material.title }}</p>
                    <p class="text-xs text-zinc-500 font-mono">{{ material.reference }}</p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <select
                    class="rounded border border-zinc-300 bg-white px-2 py-1.5 text-xs text-zinc-700"
                    [value]="material.pricingMode ?? 'additional'"
                    (change)="updateMaterialPricingMode(material.id, $any($event.target).value)"
                    [disabled]="updatingMaterialModeId() === material.id"
                  >
                    <option value="included">{{ 'catalog.products.materialPricingModeOptions.included' | translate }}</option>
                    <option value="additional">{{ 'catalog.products.materialPricingModeOptions.additional' | translate }}</option>
                    <option value="optional">{{ 'catalog.products.materialPricingModeOptions.optional' | translate }}</option>
                  </select>
                  <span class="text-sm font-medium text-zinc-900">{{ formatPrice(material.priceCents) }}</span>
                  <button
                    type="button"
                    (click)="removeMaterial(material.id)"
                    [disabled]="removingMaterialId() === material.id"
                    class="p-2 text-zinc-500 hover:text-red-600 hover:bg-red-50 rounded transition-colors disabled:opacity-50"
                    [attr.aria-label]="'catalog.products.removeMaterial' | translate"
                  >
                    @if (removingMaterialId() === material.id) {
                      <div class="animate-spin h-4 w-4 border-2 border-red-200 border-t-red-600 rounded-full"></div>
                    } @else {
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                    }
                  </button>
                </div>
              </div>
            }
          </div>
        }
      </div>
    }
    @if (activeTab() === 'assets') {
      <div class="flex-1 flex flex-col p-4 sm:p-6 gap-6">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-sm font-bold uppercase tracking-wider text-zinc-900">
              {{ 'catalog.products.assets.title' | translate }}
            </h2>
            <p class="text-xs text-zinc-500 mt-1">
              {{ 'catalog.products.assets.subtitle' | translate }}
            </p>
          </div>
        </div>

        @if (assetsError()) {
          <div role="alert" class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-sm">
            {{ assetsError() }}
          </div>
        }

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div class="rounded-xl border border-zinc-200 p-4">
            <h3 class="text-sm font-semibold mb-3">{{ 'catalog.products.assets.images' | translate }}</h3>
            <app-file-uploader
              [label]="'catalog.products.assets.selectImage' | translate"
              [dropLabel]="'common.upload.dropHint' | translate"
              [accept]="'image/*'"
              [multiple]="true"
              [buttonLabel]="'catalog.products.assets.uploadImage' | translate"
              [uploadingLabel]="'catalog.products.assets.uploading' | translate"
              [errorFallback]="'catalog.products.errors.uploadAsset' | translate"
              [disabled]="assetUploading()"
              [presign]="presignImageAsset"
              [finalize]="finalizeImageAsset"
              (uploaded)="handleAssetUploaded($any($event))"
              (uploadError)="handleAssetError($event)"
              (uploadingChange)="imageUploading.set($event)"
            />
          </div>

          <div class="rounded-xl border border-zinc-200 p-4">
            <h3 class="text-sm font-semibold mb-3">{{ 'catalog.products.assets.documents' | translate }}</h3>
            <app-file-uploader
              [label]="'catalog.products.assets.selectDocument' | translate"
              [dropLabel]="'common.upload.dropHint' | translate"
              [accept]="'application/pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.csv,.txt'"
              [multiple]="true"
              [buttonLabel]="'catalog.products.assets.uploadDocument' | translate"
              [uploadingLabel]="'catalog.products.assets.uploading' | translate"
              [errorFallback]="'catalog.products.errors.uploadAsset' | translate"
              [disabled]="assetUploading()"
              [presign]="presignDocumentAsset"
              [finalize]="finalizeDocumentAsset"
              (uploaded)="handleAssetUploaded($any($event))"
              (uploadError)="handleAssetError($event)"
              (uploadingChange)="documentUploading.set($event)"
            />
          </div>
        </div>

        <div class="rounded-xl border border-zinc-200 p-4">
          <h3 class="text-sm font-semibold mb-3">{{ 'catalog.products.assets.termsTitle' | translate }}</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <label class="flex flex-col gap-2 text-sm font-medium">
              {{ 'catalog.products.assets.termsUrl' | translate }}
              <input
                type="url"
                class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                [value]="termsUrl()"
                (input)="termsUrl.set($any($event.target).value)"
                placeholder="https://..."
              />
            </label>
            <label class="flex flex-col gap-2 text-sm font-medium">
              {{ 'catalog.products.assets.termsLabel' | translate }}
              <input
                type="text"
                class="w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm"
                [value]="termsLabel()"
                (input)="termsLabel.set($any($event.target).value)"
                placeholder="{{ 'catalog.products.assets.optionalLabel' | translate }}"
              />
            </label>
          </div>
          <div class="flex justify-end mt-3">
            <shared-button
              variant="secondary"
              size="compact"
              [uppercase]="false"
              [fullWidth]="false"
              [disabled]="!termsUrl().trim() || assetUploading()"
              (clicked)="createTermsUrl()"
            >
              {{ 'catalog.products.assets.addTerms' | translate }}
            </shared-button>
          </div>
        </div>

        <div class="rounded-xl border border-zinc-200 p-4">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold">{{ 'catalog.products.assets.libraryTitle' | translate }}</h3>
            <span class="text-xs text-zinc-500">{{ assets().length }} {{ 'catalog.products.items' | translate }}</span>
          </div>
          @if (assetsLoading()) {
            <div class="flex items-center gap-2 text-sm text-zinc-500">
              <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-black" aria-hidden="true"></div>
              {{ 'catalog.products.assets.loading' | translate }}
            </div>
          } @else if (assets().length === 0) {
            <p class="text-sm text-zinc-500">{{ 'catalog.products.assets.empty' | translate }}</p>
          } @else {
            <div class="flex flex-col gap-2">
              @for (asset of assets(); track asset.id) {
                <div class="flex items-center justify-between rounded-lg bg-zinc-50 px-3 py-3">
                  <div class="min-w-0">
                    <p class="text-sm font-medium truncate">{{ formatAssetLabel(asset) }}</p>
                    <p class="text-xs text-zinc-500">{{ getAssetTypeLabel(asset.assetType) }} · {{ formatFileSize(asset.sizeBytes) }}</p>
                  </div>
                  <div class="flex items-center gap-2">
                    <button
                      type="button"
                      class="p-1.5 text-zinc-500 hover:text-black hover:bg-zinc-100 rounded"
                      [attr.aria-label]="'Open ' + formatAssetLabel(asset)"
                      (click)="openAsset(asset)"
                    >
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6" />
                      </svg>
                    </button>
                    <button
                      type="button"
                      class="p-1.5 text-zinc-500 hover:text-red-600 hover:bg-red-50 rounded"
                      [disabled]="assetDeletingId() === asset.id"
                      [attr.aria-label]="'Delete ' + formatAssetLabel(asset)"
                      (click)="deleteAsset(asset)"
                    >
                      @if (assetDeletingId() === asset.id) {
                        <div class="animate-spin h-4 w-4 border-2 border-red-200 border-t-red-600 rounded-full"></div>
                      } @else {
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                      }
                    </button>
                  </div>
                </div>
              }
            </div>
          }
        </div>
      </div>
    }
  }

  <!-- Add Material Dialog -->
  <shared-confirm-dialog
    [isOpen]="showAddMaterialDialog()"
    [title]="'catalog.products.addMaterialTitle' | translate"
    [confirmText]="'catalog.products.addSelected' | translate"
    [cancelText]="'catalog.products.cancel' | translate"
    confirmVariant="primary"
    [confirmDisabled]="addingMaterials() || selectedMaterialIds().length === 0"
    (confirm)="addSelectedMaterials()"
    (cancelled)="closeAddMaterialDialog()"
  >
    <div class="max-h-64 overflow-y-auto">
      @if (availableMaterials().length === 0) {
        <p class="text-sm text-zinc-500 py-4 text-center">
          {{ 'catalog.products.noAvailableMaterials' | translate }}
        </p>
      } @else {
        <div class="divide-y divide-zinc-100">
          @for (material of availableMaterials(); track material.id) {
            <label class="flex items-center gap-3 p-3 hover:bg-zinc-50 cursor-pointer transition-colors">
              <input
                type="checkbox"
                [checked]="isMaterialSelected(material.id)"
                (change)="toggleMaterialSelection(material.id)"
                class="h-4 w-4 text-black border-zinc-300 rounded focus:ring-black"
              />
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-zinc-900 truncate">{{ material.title }}</p>
                <p class="text-xs text-zinc-500 font-mono">{{ material.reference }}</p>
                <div class="mt-2">
                  <p class="text-xs text-zinc-500">{{ 'catalog.products.materialPricingMode' | translate }}</p>
                  <select
                    class="mt-1 w-full rounded border border-zinc-300 bg-white px-2 py-1.5 text-xs"
                    [value]="getSelectedMaterialMode(material.id)"
                    (change)="setSelectedMaterialMode(material.id, $any($event.target).value)"
                    [disabled]="!isMaterialSelected(material.id)"
                  >
                    <option value="included">{{ 'catalog.products.materialPricingModeOptions.included' | translate }}</option>
                    <option value="additional">{{ 'catalog.products.materialPricingModeOptions.additional' | translate }}</option>
                    <option value="optional">{{ 'catalog.products.materialPricingModeOptions.optional' | translate }}</option>
                  </select>
                </div>
              </div>
              <span class="text-sm font-medium text-zinc-600">{{ formatPrice(material.priceCents) }}</span>
            </label>
          }
        </div>
      }
    </div>
  </shared-confirm-dialog>
</div>
