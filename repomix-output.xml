                      {{ 'catalog.products.materialPricingMode' | translate }}
                      <select
                        class="mt-1 w-full border border-zinc-300 bg-white px-3 py-2 text-sm font-normal focus:border-black focus:outline-none"
                        [value]="row.pricingMode"
                        (change)="updateMaterialField(row.id, 'pricingMode', $any($event.target).value)"
                      >
                        <option value="included">{{ 'catalog.products.materialPricingModeOptions.included' | translate }}</option>
                        <option value="additional">{{ 'catalog.products.materialPricingModeOptions.additional' | translate }}</option>
                        <option value="optional">{{ 'catalog.products.materialPricingModeOptions.optional' | translate }}</option>
                      </select>
                    </label>
                  </div>

                  <div class="grid grid-cols-1 gap-3 border-t border-zinc-200 p-4 md:grid-cols-3">
                    <label class="text-xs font-semibold uppercase tracking-wide text-zinc-600">
                      {{ 'catalog.products.inlineMaterials.priceType' | translate }}
                      <select
                        class="mt-1 w-full border border-zinc-300 bg-white px-3 py-2 text-sm font-normal focus:border-black focus:outline-none"
                        [value]="row.priceType"
                        (change)="updateMaterialField(row.id, 'priceType', $any($event.target).value)"
