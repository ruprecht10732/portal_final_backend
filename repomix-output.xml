<shared-page-layout
  [title]="'navigation.whatsapp' | translate"
  subtitle="Live inbox"
  [removeMobilePadding]="true"
>
  <shared-button
    actionsDesktop
    class="hidden sm:flex"
    variant="secondary"
    [fullWidth]="false"
    [ariaLabel]="'Ververs gesprekken'"
    (clicked)="loadConversations()"
  >
    <lucide-icon name="refresh-cw" class="mr-2 h-4 w-4"></lucide-icon>
    Ververs
  </shared-button>

  <main class="flex min-h-0 flex-1 flex-col overflow-hidden bg-[#fdfbf7] px-0 pb-0 sm:-mx-6 sm:px-3 sm:pb-4">
    @if (deviceStatus.needsReconnectBanner() || deviceStatus.needsDeviceConnection()) {
