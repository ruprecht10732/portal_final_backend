                <div class="flex gap-3">
                  <dt class="text-xs font-semibold uppercase tracking-wider text-zinc-500 w-24 shrink-0">
                    {{ 'appointments.detail.meetingLink' | translate }}
                  </dt>
                  <dd class="text-sm">
                    <a
                      class="text-blue-600 hover:text-blue-800 underline"
                      [href]="appointment()!.meetingLink"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {{ appointment()!.meetingLink }}
                    </a>
                  </dd>
                </div>
              }

              @if (appointment()!.lead) {
                <div class="flex gap-3">
                  <dt class="text-xs font-semibold uppercase tracking-wider text-zinc-500 w-24 shrink-0">
                    {{ 'appointments.detail.lead' | translate }}
                  </dt>
                  <dd class="text-sm">
                    {{ appointment()!.lead!.firstName }} {{ appointment()!.lead!.lastName }}
                    <span class="block text-xs text-zinc-400">{{ appointment()!.lead!.phone }}</span>
                  </dd>
                </div>
              }
            </dl>
          </shared-card>

          <!-- Visit Report Section (for lead_visit type) -->
          @if (appointment()!.type === 'lead_visit') {
            <div class="border border-zinc-200 rounded">
              <button
                type="button"
                class="w-full flex items-center justify-between p-4 text-left hover:bg-zinc-50 transition-colors"
                (click)="toggleVisitReport()"
              >
                <span class="text-xs font-bold uppercase tracking-widest text-zinc-500">
                  {{ 'appointments.detail.visitReport.title' | translate }}
                </span>
                <lucide-icon
                  name="chevron-down"
                  class="h-4 w-4 text-zinc-400 transition-transform"
                  [class.rotate-180]="showVisitReport()"
                ></lucide-icon>
              </button>

              @if (showVisitReport()) {
                <form (ngSubmit)="saveVisitReport()" class="p-4 pt-0 space-y-4">
                  <shared-textarea
                    [label]="'appointments.detail.visitReport.measurements' | translate"
                    [rows]="2"
                    [value]="reportMeasurements()"
                    (valueChange)="reportMeasurements.set($event)"
                  />

                  <shared-select
                    [label]="'appointments.detail.visitReport.accessDifficulty' | translate"
                    [options]="accessDifficultySelectOptions()"
                    [value]="reportAccessDifficulty()"
                    (valueChange)="reportAccessDifficulty.set($event ?? '')"
                    [placeholder]="'common.select' | translate"
                  />

                  <shared-textarea
                    [label]="'appointments.detail.visitReport.notes' | translate"
                    [rows]="3"
                    [value]="reportNotes()"
                    (valueChange)="reportNotes.set($event)"
                  />

                  <shared-button variant="primary" type="submit" [disabled]="saving()">
                    {{ 'appointments.detail.visitReport.save' | translate }}
                  </shared-button>
                </form>
              }
            </div>
          }
        }
      </div>
    </div>
  }

  <!-- Delete Confirmation -->
  <shared-confirm-dialog
    [isOpen]="showDeleteDialog()"
    [title]="'appointments.detail.deleteTitle' | translate"
    [message]="'appointments.detail.deleteMessage' | translate"
    [confirmText]="'common.delete' | translate"
    [cancelText]="'common.cancel' | translate"
    confirmVariant="danger"
    [confirmDisabled]="deleteInProgress()"
    (confirm)="confirmDelete()"
    (cancelled)="closeDeleteDialog()"
  />
</div>
