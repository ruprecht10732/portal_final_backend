          {{ 'partners.offer.actions.confirmReject' | translate }}
        }
      </button>
      <button type="button" class="h-12 w-full rounded-[18px] border border-zinc-200 text-sm font-semibold text-zinc-500" (click)="cancelForm()">
        {{ 'partners.offer.actions.cancel' | translate }}
      </button>
    </div>
  </div>
</app-bottom-sheet>
