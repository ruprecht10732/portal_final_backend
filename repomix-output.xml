              </div>
            </button>
          } @else {
            <button type="button" class="group flex flex-col p-4 bg-white border-2 border-dashed border-[#137fec]/30 rounded-xl hover:border-[#137fec] transition-all cursor-pointer text-left" (click)="openUploadSheet()">
              <div class="flex justify-between items-start mb-3 w-full">
                <div class="size-10 rounded-lg bg-[#137fec]/10 flex items-center justify-center text-[#137fec]">
                  <span class="material-symbols-outlined">photo_camera</span>
                </div>
                <span class="material-symbols-outlined text-amber-500 text-lg">error</span>
              </div>
              <p class="text-[#111418] text-sm font-bold">Foto's</p>
              <p class="text-[#617589] text-[11px] leading-tight mt-1">Upload foto's van je project.</p>
              <div class="mt-3 flex items-center text-[#137fec] text-[11px] font-bold uppercase tracking-wider">
                <span>Toevoegen</span>
                <span class="material-symbols-outlined text-sm ml-1 group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </div>
            </button>
          }
        </div>
      </div>

      <!-- Appointment & Quote Section -->
      <div class="px-4 pt-8">
        <h3 class="text-[#111418] text-lg font-bold leading-tight tracking-[-0.015em] mb-1">Volgende stap</h3>
        <p class="text-[#617589] text-sm mb-4">Afspraak en offerte informatie.</p>

        <div class="flex flex-col gap-4">
          <!-- Appointment tile -->
          <div class="flex flex-col gap-3 p-4 rounded-xl border border-gray-100 bg-white ios-shadow">
            <div class="flex justify-between items-start">
              <div class="flex items-center gap-3">
                <div class="size-10 rounded-lg bg-[#137fec]/10 flex items-center justify-center text-[#137fec]">
                  <span class="material-symbols-outlined">event</span>
                </div>
                <div>
                  <p class="text-[#111418] text-sm font-bold">Afspraak</p>
                  @if (appointmentList().length > 0) {
                    <p class="text-[#617589] text-[11px] leading-tight mt-0.5">{{ appointmentList().length }} afspraak(pen)</p>
                  } @else {
                    <p class="text-[#617589] text-[11px] leading-tight mt-0.5">Nog niet gepland</p>
                  }
                </div>
              </div>
              @if (hasScheduledAppointment()) {
                <span class="material-symbols-outlined text-green-500 text-lg">check_circle</span>
              } @else if (hasRequestedAppointment()) {
                <span class="material-symbols-outlined text-amber-500 text-lg">schedule</span>
              } @else {
                <span class="material-symbols-outlined text-[#617589] text-lg">schedule</span>
              }
            </div>
            @if (appointmentList().length > 0) {
              <div class="flex flex-col gap-2 ml-13">
                @for (appt of appointmentList(); track appt.id) {
                  <div class="flex items-start gap-2 text-sm text-[#617589]">
                    <span class="material-symbols-outlined text-sm">calendar_today</span>
                    <div class="flex flex-col">
                      <span class="text-[11px] font-semibold uppercase tracking-wider text-[#617589]">
                        {{ appt.status === 'scheduled' ? 'Bevestigd' : 'Aanvraag' }}
                      </span>
                      <span>
                        {{ appt.startTime | date:'d MMMM yyyy':'':'nl' }} ·
                        {{ appt.startTime | date:'HH:mm' }} - {{ appt.endTime | date:'HH:mm' }}
                      </span>
                      @if (appt.status === 'scheduled') {
                        <a
                          class="mt-1 text-[11px] font-bold uppercase tracking-wider text-[#137fec]"
                          [href]="calendarIcsHref(appt)"
                          download="afspraak.ics"
                        >
                          Voeg toe aan kalender
                        </a>
                      }
                    </div>
                  </div>
                }
              </div>
            }
          </div>

          <!-- Quote tile -->
          <div class="flex flex-col gap-3 p-4 rounded-xl border border-gray-100 bg-white ios-shadow">
            <div class="flex justify-between items-start">
              <div class="flex items-center gap-3">
                <div class="size-10 rounded-lg bg-[#137fec]/10 flex items-center justify-center text-[#137fec]">
                  <span class="material-symbols-outlined">description</span>
                </div>
                <div>
                  <p class="text-[#111418] text-sm font-bold">Offerte</p>
                  @if (d.quote.available) {
                    <p class="text-[#617589] text-[11px] leading-tight mt-0.5">Status: {{ d.quote.status }}</p>
                  } @else {
                    <p class="text-[#617589] text-[11px] leading-tight mt-0.5">Nog niet beschikbaar</p>
                  }
                </div>
              </div>
              @if (d.quote.available) {
                <span class="material-symbols-outlined text-green-500 text-lg">check_circle</span>
              } @else {
                <span class="material-symbols-outlined text-[#617589] text-lg">pending</span>
              }
            </div>
            @if (d.quote.available) {
              <div class="flex items-center gap-3 ml-13">
                @if (d.quote.link) {
                  <a class="bg-[#137fec] px-4 py-2 text-center text-xs font-bold text-white rounded-lg hover:bg-[#137fec]/90 transition-colors" [href]="d.quote.link">Bekijk offerte</a>
                }
                @if (d.quote.downloadLink && d.quote.status === 'Accepted') {
                  <a class="text-xs font-bold text-[#137fec]" [href]="d.quote.downloadLink">Download PDF</a>
                }
              </div>
            }
          </div>
        </div>
      </div>

      <!-- Help Section -->
      <div class="mt-4 px-4 pb-6">
        <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
          <div class="flex-1">
            <p class="text-[#111418] text-sm font-bold">Hulp nodig bij je aanvraag?</p>
            <p class="text-[#617589] text-xs">Ons team staat klaar om je te helpen.</p>
          </div>
          @if (whatsappUrl()) {
            <a
              class="shrink-0 bg-[#25d366] text-white text-xs font-bold px-4 py-2 rounded-lg hover:bg-[#1ebe5d] transition-colors"
              [href]="whatsappUrl()"
              target="_blank"
              rel="noopener"
            >
              WhatsApp
            </a>
          } @else {
            <button type="button" class="shrink-0 bg-gray-200 text-xs font-bold px-4 py-2 rounded-lg text-[#617589]" disabled>
              WhatsApp
            </button>
          }
        </div>
      </div>

      <!-- Bottom spacer for fixed nav -->
      <div class="h-20"></div>

    </div>
  </div>

  <!-- Fixed Bottom Navigation Bar -->
  <nav class="fixed inset-x-0 bottom-0 z-40 mx-auto max-w-2xl bottom-nav-glass">
    <div class="flex items-center justify-around px-2 py-2 pb-safe-nav">
      <!-- Overzicht -->
      <button type="button" class="bottom-nav-item" (click)="scrollToTop()">
        <span class="material-symbols-outlined text-[22px]">home</span>
        <span class="text-[10px] font-semibold">Overzicht</span>
      </button>

      <!-- Upload (primary) -->
      <button type="button" class="relative -mt-5" (click)="openUploadSheet()">
        <div class="flex size-14 items-center justify-center rounded-full bg-[#137fec] text-white shadow-lg shadow-[#137fec]/30 transition-transform active:scale-95">
          <span class="material-symbols-outlined text-[26px]">add_photo_alternate</span>
        </div>
        @if (imageAttachments().length > 0) {
          <span class="absolute -right-1 -top-1 flex size-5 items-center justify-center rounded-full bg-[#111418] text-[10px] font-bold text-white">{{ imageAttachments().length }}</span>
        }
      </button>

      <!-- WhatsApp -->
      @if (whatsappUrl()) {
        <a class="bottom-nav-item" [href]="whatsappUrl()" target="_blank" rel="noopener">
          <span class="material-symbols-outlined text-[22px]">chat_bubble_outline</span>
          <span class="text-[10px] font-semibold">WhatsApp</span>
        </a>
      } @else {
        <button type="button" class="bottom-nav-item" disabled>
          <span class="material-symbols-outlined text-[22px]">chat_bubble_outline</span>
          <span class="text-[10px] font-semibold">WhatsApp</span>
        </button>
      }
    </div>
  </nav>

  <!-- Preference Bottom Sheet -->
  @if (activePreferenceSheet(); as sheetType) {
    <div class="fixed inset-0 z-50 flex items-end justify-center">
      <button
        type="button"
        class="absolute inset-0 w-full bg-black/40 sheet-backdrop cursor-default"
        (click)="closePreferenceSheet()"
        aria-label="Sluiten"
      ></button>

      <div class="relative z-10 w-full max-w-2xl rounded-t-2xl bg-white pb-safe sheet-enter">
        <div class="flex justify-center pt-3 pb-1">
          <div class="h-1 w-10 rounded-full bg-gray-300"></div>
        </div>

        <div class="flex items-center justify-between border-b border-gray-100 px-6 pb-4 pt-2">
          <div>
            @if (sheetType === 'budget') {
              <h3 class="text-[#111418] text-lg font-bold">Budget instellen</h3>
              <p class="text-[#617589] text-sm">Wat is je prijsklasse voor dit project?</p>
            } @else if (sheetType === 'availability') {
              <h3 class="text-[#111418] text-lg font-bold">Inspectie afspraak</h3>
              <p class="text-[#617589] text-sm">Kies een moment voor de offerte inspectie afspraak.</p>
            } @else if (sheetType === 'timeframe') {
              <h3 class="text-[#111418] text-lg font-bold">Tijdspad</h3>
              <p class="text-[#617589] text-sm">Wanneer wil je het project laten uitvoeren?</p>
            } @else if (sheetType === 'extraNotes') {
              <h3 class="text-[#111418] text-lg font-bold">Extra opmerkingen</h3>
              <p class="text-[#617589] text-sm">Alles wat we moeten weten.</p>
            }
          </div>
          <button
            type="button"
            class="flex size-9 items-center justify-center rounded-full bg-gray-100 text-[#617589] transition hover:bg-gray-200"
            (click)="closePreferenceSheet()"
            aria-label="Sluiten"
          >
            <span class="material-symbols-outlined text-xl">close</span>
          </button>
        </div>

        <form class="flex flex-col gap-4 p-6" [formGroup]="preferencesForm" (ngSubmit)="submitPreferenceAndClose()">
          @if (sheetType === 'budget') {
            <div class="flex items-center gap-2">
              <div class="relative flex-1">
                <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-[#617589]">€</span>
                <input type="number" inputmode="numeric" min="0" step="100"
                  class="w-full rounded-xl border border-gray-200 py-3.5 pl-9 pr-4 text-sm text-[#111418] placeholder:text-[#617589] focus:border-[#137fec] focus:outline-none focus:ring-2 focus:ring-[#137fec]/20 [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
                  formControlName="budgetMin" placeholder="Min" />
              </div>
              <span class="text-[#617589] text-sm font-medium">–</span>
              <div class="relative flex-1">
                <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-sm font-semibold text-[#617589]">€</span>
                <input type="number" inputmode="numeric" min="0" step="100"
                  class="w-full rounded-xl border border-gray-200 py-3.5 pl-9 pr-4 text-sm text-[#111418] placeholder:text-[#617589] focus:border-[#137fec] focus:outline-none focus:ring-2 focus:ring-[#137fec]/20 [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
                  formControlName="budgetMax" placeholder="Max" />
              </div>
            </div>
          } @else if (sheetType === 'availability') {
            @if (loadingSlots() || slotDates().length > 0 || data()?.slotsAvailable) {
              <div class="flex flex-col gap-4">
                <div>
                  <p class="text-[11px] font-bold uppercase tracking-wider text-[#617589] mb-2">Selecteer datum</p>
                  <div class="-mx-1 flex gap-2 overflow-x-auto pb-2 px-1">
                    @for (date of slotDates(); track date) {
                      <button
                        type="button"
                        class="flex min-w-18 flex-col items-center gap-0.5 rounded-xl border px-3 py-2 text-center transition"
                        [class.border-[#137fec]]="isSlotDateSelected(date)"
                        [class.bg-[#137fec]]="isSlotDateSelected(date)"
                        [class.text-white]="isSlotDateSelected(date)"
                        [class.border-gray-200]="!isSlotDateSelected(date)"
                        [class.text-[#111418]]="!isSlotDateSelected(date)"
                        [class.opacity-40]="!dayHasSlots(date)"
                        [disabled]="!dayHasSlots(date)"
                        (click)="selectSlotDate(date)"
                      >
                        <span class="text-[10px] uppercase tracking-wider">{{ slotDisplayWeekday(date) }}</span>
                        <span class="text-base font-bold">{{ slotDisplayDay(date) }}</span>
                        <span class="text-[10px] uppercase tracking-wider">{{ slotDisplayMonth(date) }}</span>
                      </button>
                    }
                  </div>
                </div>

                @if (loadingSlots()) {
                  <div class="flex items-center gap-2 rounded-xl bg-[#137fec]/5 px-4 py-3">
                    <span class="material-symbols-outlined text-[#137fec] text-lg animate-spin">progress_activity</span>
                    <span class="text-sm font-medium text-[#137fec]">Tijden laden...</span>
                  </div>
                } @else if (selectedDaySlots().length > 0) {
                  <div class="grid grid-cols-2 gap-2">
                    @for (slot of selectedDaySlots(); track slot.startTime) {
                      <button
                        type="button"
                        class="rounded-xl border px-3 py-2 text-sm font-semibold transition"
                        [class.border-[#137fec]]="selectedSlot()?.startTime === slot.startTime"
                        [class.bg-[#137fec]/10]="selectedSlot()?.startTime === slot.startTime"
                        [class.text-[#137fec]]="selectedSlot()?.startTime === slot.startTime"
                        [class.border-gray-200]="selectedSlot()?.startTime !== slot.startTime"
                        [class.text-[#111418]]="selectedSlot()?.startTime !== slot.startTime"
                        (click)="selectSlot(slot)"
                      >
                        {{ slot.startTime | date:'HH:mm' }} - {{ slot.endTime | date:'HH:mm' }}
                      </button>
                    }
                  </div>
                } @else {
                  <div class="rounded-xl border border-dashed border-gray-200 bg-gray-50/60 p-4 text-sm text-[#617589]">
                    Geen beschikbare tijden voor deze dag.
                  </div>
                }

                @if (slotError(); as errText) {
                  <p class="text-xs text-red-600">{{ errText }}</p>
                }
              </div>
            } @else {
              <textarea class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-[#111418] placeholder:text-[#617589] focus:border-[#137fec] focus:outline-none focus:ring-2 focus:ring-[#137fec]/20"
                formControlName="availability" rows="3" placeholder="Bijv. ma, wo, vr tussen 09:00 en 17:00"></textarea>
            }
          } @else if (sheetType === 'timeframe') {
            <div class="flex flex-col gap-3">
              <p class="text-[11px] font-bold uppercase tracking-wider text-[#617589]">Kies een optie</p>
              <div class="grid grid-cols-1 gap-2">
                @for (option of timeframeOptions; track option) {
                  <button
                    type="button"
                    class="flex w-full items-center justify-between rounded-xl border px-4 py-3 text-left text-sm font-semibold transition"
                    [class.border-[#137fec]]="timeframeSelection() === option"
                    [class.bg-[#137fec]/10]="timeframeSelection() === option"
                    [class.text-[#137fec]]="timeframeSelection() === option"
                    [class.border-gray-200]="timeframeSelection() !== option"
                    [class.text-[#111418]]="timeframeSelection() !== option"
                    (click)="selectTimeframe(option)"
                  >
                    <span>{{ option }}</span>
                    @if (timeframeSelection() === option) {
                      <span class="material-symbols-outlined text-lg">check_circle</span>
                    }
                  </button>
                }
              </div>

              @if (timeframeSelection() === 'Anders') {
                <div class="mt-1">
                  <p class="text-[11px] font-bold uppercase tracking-wider text-[#617589] mb-2">Vertel het ons kort</p>
                  <textarea
                    class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-[#111418] placeholder:text-[#617589] focus:border-[#137fec] focus:outline-none focus:ring-2 focus:ring-[#137fec]/20"
                    formControlName="timeframe"
                    rows="3"
                    placeholder="Bijv. na de zomer of zodra vergunning rond is"
                    (input)="onCustomTimeframeInput($event)"
                  ></textarea>
                </div>
              }
            </div>
          } @else if (sheetType === 'extraNotes') {
            <textarea class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-[#111418] placeholder:text-[#617589] focus:border-[#137fec] focus:outline-none focus:ring-2 focus:ring-[#137fec]/20"
              formControlName="extraNotes" rows="3" placeholder="Alles wat we moeten weten"></textarea>
          }

          @if (sheetType === 'availability' && data()?.slotsAvailable) {
            <button type="button"
              class="w-full bg-[#137fec] py-3.5 text-sm font-bold text-white rounded-xl transition hover:bg-[#137fec]/90 disabled:opacity-60"
              [disabled]="requestingAppointment() || !selectedSlot()"
              (click)="requestAppointmentAndClose()">
              @if (requestingAppointment()) {
                <span class="flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined text-lg animate-spin">progress_activity</span>
                  Aanvragen...
                </span>
              } @else if (slotRequestSuccess()) {
                <span class="flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined text-lg">check_circle</span>
                  Aangevraagd!
                </span>
              } @else {
                Afspraak aanvragen
              }
            </button>
          } @else {
            <button type="submit"
              class="w-full bg-[#137fec] py-3.5 text-sm font-bold text-white rounded-xl transition hover:bg-[#137fec]/90"
              [disabled]="savingPreferences()">
              @if (savingPreferences()) {
                <span class="flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined text-lg animate-spin">progress_activity</span>
                  Opslaan...
                </span>
              } @else if (preferencesSuccess()) {
                <span class="flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined text-lg">check_circle</span>
                  Opgeslagen!
                </span>
              } @else {
                Opslaan
              }
            </button>
          }
        </form>
      </div>
    </div>
  }

  <!-- Bottom Sheet Overlay -->
  @if (showUploadSheet()) {
    <div class="fixed inset-0 z-50 flex items-end justify-center">
      <!-- Backdrop -->
      <button
        type="button"
        class="absolute inset-0 w-full bg-black/40 sheet-backdrop cursor-default"
        (click)="closeUploadSheet()"
        aria-label="Sluiten"
      ></button>

      <!-- Sheet -->
      <div class="relative z-10 w-full max-w-2xl rounded-t-2xl bg-white pb-safe sheet-enter">
        <!-- Handle bar -->
        <div class="flex justify-center pt-3 pb-1">
          <div class="h-1 w-10 rounded-full bg-gray-300"></div>
        </div>

        <!-- Header -->
        <div class="flex items-center justify-between border-b border-gray-100 px-6 pb-4 pt-2">
          <div>
            <h3 class="text-[#111418] text-lg font-bold">Bestanden uploaden</h3>
            <p class="text-[#617589] text-sm">Upload relevante documenten of foto's.</p>
          </div>
          <button
            type="button"
            class="flex size-9 items-center justify-center rounded-full bg-gray-100 text-[#617589] transition hover:bg-gray-200"
            (click)="closeUploadSheet()"
            aria-label="Sluiten"
          >
            <span class="material-symbols-outlined text-xl">close</span>
          </button>
        </div>

        <!-- Upload area -->
        <div class="flex flex-col gap-4 p-6">
          <label class="flex flex-col items-center justify-center gap-3 rounded-2xl border-2 border-dashed border-gray-200 bg-gray-50/80 px-6 py-10 text-center cursor-pointer hover:border-[#137fec]/40 hover:bg-[#137fec]/5 transition-colors">
            <div class="flex size-14 items-center justify-center rounded-full bg-[#137fec]/10">
              <span class="material-symbols-outlined text-[#137fec] text-3xl">cloud_upload</span>
            </div>
            <div>
              <span class="text-sm font-bold text-[#111418]">Klik om een bestand te selecteren</span>
              <p class="mt-1 text-xs text-[#617589]">JPG, PNG, PDF of andere bestanden</p>
            </div>
            <input type="file" class="hidden" multiple (change)="onFileSelected($event)" />
          </label>

          @if (uploadBusy()) {
            <div class="flex items-center gap-2 rounded-xl bg-[#137fec]/5 px-4 py-3">
              <span class="material-symbols-outlined text-[#137fec] text-lg animate-spin">progress_activity</span>
              <span class="text-sm font-medium text-[#137fec]">Uploaden...</span>
            </div>
          } @else if (uploadSuccess()) {
            <div class="flex items-center gap-2 rounded-xl bg-green-50 px-4 py-3">
              <span class="material-symbols-outlined text-green-500 text-lg">check_circle</span>
              <span class="text-sm font-medium text-green-600">Upload voltooid!</span>
            </div>
          } @else if (uploadError(); as errText) {
            <div class="flex items-center gap-2 rounded-xl bg-red-50 px-4 py-3">
              <span class="material-symbols-outlined text-red-500 text-lg">error</span>
              <span class="text-sm font-medium text-red-600">{{ errText }}</span>
            </div>
          }

          <div class="border-t border-gray-100 pt-4">
            <div class="flex items-center justify-between mb-1">
              <h4 class="text-[#111418] text-base font-bold leading-tight tracking-[-0.015em]">Foto's & bestanden</h4>
              @if (imageAttachments().length + documentAttachments().length > 0) {
                <span class="text-xs font-medium text-[#617589]">
                  {{ imageAttachments().length + documentAttachments().length }} bestand{{ imageAttachments().length + documentAttachments().length === 1 ? '' : 'en' }}
                </span>
              }
            </div>
            <p class="text-[#617589] text-sm mb-4">Geüploade documenten en foto's.</p>

            @if (imageAttachments().length > 0) {
              <div class="grid grid-cols-3 gap-2">
                @for (att of imageAttachments(); track att.id) {
                  <div class="group relative aspect-square overflow-hidden rounded-xl bg-gray-100">
                    <a class="block h-full" [href]="att.downloadUrl" target="_blank" rel="noopener">
                      <img class="h-full w-full object-cover" [src]="att.downloadUrl" [alt]="att.fileName" loading="lazy" />
                    </a>
                    <button
                      type="button"
                      class="absolute right-1.5 top-1.5 flex size-7 items-center justify-center rounded-full bg-black/50 text-white opacity-0 group-hover:opacity-100 transition-opacity"
                      [disabled]="deleteBusyId() === att.id"
                      (click)="deleteAttachment(att)"
                    >
                      @if (deleteBusyId() === att.id) {
                        <span class="material-symbols-outlined text-[14px] animate-spin">progress_activity</span>
                      } @else {
                        <span class="material-symbols-outlined text-[14px]">close</span>
                      }
                    </button>
                    <div class="absolute inset-x-0 bottom-0 bg-linear-to-t from-black/40 to-transparent p-2 pt-6 opacity-0 group-hover:opacity-100 transition-opacity">
                      <p class="text-[10px] text-white truncate">{{ att.fileName }}</p>
                    </div>
                  </div>
                }
              </div>
            }

            @if (documentAttachments().length > 0) {
              <div class="mt-3 flex flex-col gap-2">
                @for (att of documentAttachments(); track att.id) {
                  <div class="flex items-center justify-between gap-3 rounded-xl border border-gray-100 bg-gray-50/60 px-3 py-2">
                    <a class="flex items-center gap-2 text-sm font-medium text-[#111418]" [href]="att.downloadUrl" target="_blank" rel="noopener">
                      <span class="material-symbols-outlined text-base text-[#617589]">description</span>
                      <span class="truncate">{{ att.fileName }}</span>
                    </a>
                    <button
                      type="button"
                      class="flex size-8 items-center justify-center rounded-full bg-white text-[#617589] hover:text-[#111418]"
                      [disabled]="deleteBusyId() === att.id"
                      (click)="deleteAttachment(att)"
                    >
                      @if (deleteBusyId() === att.id) {
                        <span class="material-symbols-outlined text-[16px] animate-spin">progress_activity</span>
                      } @else {
                        <span class="material-symbols-outlined text-[16px]">close</span>
                      }
                    </button>
                  </div>
                }
              </div>
            }

            @if (imageAttachments().length + documentAttachments().length === 0) {
              <div class="flex flex-col items-center justify-center rounded-xl border border-dashed border-gray-200 bg-gray-50/50 py-6 text-center">
                <span class="material-symbols-outlined text-gray-300 text-3xl mb-2">photo_library</span>
                <p class="text-sm text-[#617589]">Nog geen bestanden geüpload</p>
              </div>
            }

            @if (deleteError(); as errText) {
              <p class="mt-3 text-xs text-red-600">{{ errText }}</p>
            }
          </div>
        </div>
      </div>
    </div>
  }
}
