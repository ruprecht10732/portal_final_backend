  Expired: 'offertes.status.expired',
};

const ALLOWED_QUOTE_TRANSITIONS: Record<QuoteStatus, readonly QuoteStatus[]> = {
  Draft: ['Sent', 'Expired'],
  Sent: ['Accepted', 'Rejected', 'Expired'],
  Accepted: [],
  Rejected: [],
  Expired: [],
};

@Component({
  selector: 'app-quotes-board',
