        </div>
      </shared-card>

      <shared-card>
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex flex-col gap-1">
              <h4 class="text-xs font-bold uppercase tracking-widest text-zinc-400">
                {{ 'webhook.whatsapp.title' | translate }}
              </h4>
              <p class="text-sm text-zinc-500">
                {{ 'webhook.whatsapp.subtitle' | translate }}
              </p>
            </div>

            <shared-button
              variant="secondary"
              [fullWidth]="false"
              [disabled]="isWebhookKeySaving()"
              (clicked)="toggleWebhookCreateForm()"
            >
              @if (showWebhookCreateForm()) {
                {{ 'webhook.cancel' | translate }}
              } @else {
                {{ 'webhook.createKey' | translate }}
              }
            </shared-button>
          </div>

          <div class="rounded-2xl border border-sky-200 bg-sky-50 px-4 py-3 text-sm text-sky-900">
            {{ 'webhook.whatsapp.optionalUsage' | translate }}
          </div>

          <div class="space-y-2">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-zinc-500">
