          @if (selectedInspectionDate()) {
            <div class="time-panel mt-4">
              <p class="text-xs font-semibold text-zinc-500 mb-3">{{ 'partners.offer.accept.selectSlotHint' | translate }}</p>
              <div class="slot-grid">
                @for (slot of slotOptions; track slot.start) {
                  <button type="button" class="slot-button" [class.is-selected]="isInspectionSlotActive(slot.start)" [class.is-disabled]="isPastSlot(selectedInspectionDate(), slot.start)" [disabled]="isPastSlot(selectedInspectionDate(), slot.start)" (click)="toggleInspectionSlot(slot.start)">
                    {{ slot.label }}
                  </button>
                }
              </div>
            </div>
          } @else {
            <p class="mt-3 text-xs font-medium text-zinc-500">{{ 'partners.offer.accept.selectDateHint' | translate }}</p>
          }

          @if (inspectionSlots().length > 0) {
            <div class="slot-list mt-4">
              @for (slot of inspectionSlots(); track $index) {
                <div class="slot-chip"><span>{{ formatSlotLabel(slot) }}</span><button type="button" (click)="removeInspectionSlot($index)" aria-label="remove">&times;</button></div>
              }
            </div>
          }

          @if (inspectionErrors().length > 0) {
            <div class="validation-list">@for (err of inspectionErrors(); track err) { <p>{{ err | translate }}</p> }</div>
          }
        </div>

        <!-- ── Job availability (optional) ── -->
        <div class="mt-6 border-t border-zinc-100 pt-5">
          <h4 class="text-sm font-bold text-zinc-900 mb-3">
            {{ 'partners.offer.accept.jobTitle' | translate }}
            <span class="text-xs font-normal text-zinc-400">{{ 'partners.offer.accept.optional' | translate }}</span>
            @if (jobSlots().length > 0) {
              <span class="ml-2 inline-flex items-center rounded-full bg-teal-100 px-2 py-0.5 text-xs font-semibold text-teal-700">{{ jobSlots().length }}</span>
            }
          </h4>

          <div class="calendar-card">
            <div class="calendar-header">
              <button type="button" class="calendar-nav" (click)="changeJobMonth(-1)">&lsaquo;</button>
              <span>{{ jobMonth() | date:'MMMM yyyy':'':'nl-NL' }}</span>
              <button type="button" class="calendar-nav" (click)="changeJobMonth(1)">&rsaquo;</button>
            </div>
            <div class="calendar-grid">
              <span class="calendar-weekday">Ma</span><span class="calendar-weekday">Di</span><span class="calendar-weekday">Wo</span><span class="calendar-weekday">Do</span><span class="calendar-weekday">Vr</span><span class="calendar-weekday">Za</span><span class="calendar-weekday">Zo</span>
              @for (day of jobCalendarDays(); track day.key) {
                <button type="button" class="calendar-day" [class.is-outside]="!day.isCurrentMonth" [class.is-today]="day.isToday" [class.is-selected]="selectedJobDate() === day.date" [class.is-disabled]="isPastDate(day.date)" [class.has-slots]="dateHasJobSlots(day.date)" [disabled]="isPastDate(day.date)" (click)="selectJobDate(day.date)">{{ day.label }}</button>
              }
            </div>
          </div>

          @if (selectedJobDate()) {
            <div class="time-panel mt-4">
              <p class="text-xs font-semibold text-zinc-500 mb-3">{{ 'partners.offer.accept.selectSlotHint' | translate }}</p>
              <div class="slot-grid">
                @for (slot of slotOptions; track slot.start) {
                  <button type="button" class="slot-button" [class.is-selected]="isJobSlotActive(slot.start)" [class.is-disabled]="isPastSlot(selectedJobDate(), slot.start)" [disabled]="isPastSlot(selectedJobDate(), slot.start)" (click)="toggleJobSlot(slot.start)">
                    {{ slot.label }}
                  </button>
                }
              </div>
            </div>
          } @else {
            <p class="mt-3 text-xs font-medium text-zinc-500">{{ 'partners.offer.accept.selectDateHint' | translate }}</p>
          }

          @if (jobSlots().length > 0) {
            <div class="slot-list mt-4">
              @for (slot of jobSlots(); track $index) {
                <div class="slot-chip"><span>{{ formatSlotLabel(slot) }}</span><button type="button" (click)="removeJobSlot($index)" aria-label="remove">&times;</button></div>
              }
            </div>
          }

          @if (jobErrors().length > 0) {
            <div class="validation-list">@for (err of jobErrors(); track err) { <p>{{ err | translate }}</p> }</div>
          }
        </div>
      </div>
    }
  </div>

  <div bottomSheetFooter class="border-t border-zinc-100 bg-white/90 px-6 pb-[calc(1.5rem+env(safe-area-inset-bottom))] pt-4 backdrop-blur">
    @if (acceptStep() === 1) {
      <button type="button" class="h-14 w-full rounded-[18px] bg-teal-600 text-base font-extrabold text-white shadow-lg shadow-teal-500/20 transition-transform active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed" [disabled]="!canProceedStep1()" (click)="nextAcceptStep()">
        {{ 'partners.offer.wizard.next' | translate }}
      </button>
    } @else if (acceptStep() === 2) {
      <button type="button" class="h-14 w-full rounded-[18px] bg-teal-600 text-base font-extrabold text-white shadow-lg shadow-teal-500/20 transition-transform active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed" [disabled]="!canProceedStep2()" (click)="nextAcceptStep()">
        {{ 'partners.offer.wizard.next' | translate }}
      </button>
    } @else if (acceptStep() === 3) {
      <button type="button" class="h-14 w-full rounded-[18px] bg-teal-600 text-base font-extrabold text-white shadow-lg shadow-teal-500/20 transition-transform active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed" [disabled]="!canProceedStep3()" (click)="nextAcceptStep()">
        {{ 'partners.offer.wizard.next' | translate }}
      </button>
    } @else {
      <button type="button" class="h-14 w-full rounded-[18px] bg-emerald-500 text-base font-extrabold text-white shadow-lg shadow-emerald-500/20 transition-transform active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed" [disabled]="!canSubmitStep4() || accepting()" (click)="submitAccept()">
        @if (accepting()) {
          <span class="flex items-center justify-center gap-2">
            <div class="h-4 w-4 animate-spin rounded-full border-2 border-white border-t-transparent"></div>
            {{ 'partners.offer.actions.busy' | translate }}
          </span>
        } @else {
          {{ 'partners.offer.wizard.submit' | translate }}
        }
      </button>
    }
  </div>
</app-bottom-sheet>

<!-- ============ REJECT BOTTOM SHEET ============ -->
<app-bottom-sheet
  [isOpen]="showRejectForm() && isMobile()"
  [title]="'partners.offer.reject.title' | translate"
  (closed)="cancelForm()"
>
  <div class="px-6 pb-6 pt-4">
    <p class="text-sm text-zinc-500">{{ 'partners.offer.reject.placeholder' | translate }}</p>
    <div class="mt-4">
      <label for="reject-reason-mobile" class="block text-xs font-bold uppercase tracking-widest text-zinc-400">{{ 'partners.offer.reject.reasonLabel' | translate }}</label>
      <textarea id="reject-reason-mobile" rows="3" maxlength="500"
        class="mt-2 w-full rounded-2xl border border-zinc-200 bg-zinc-50 px-4 py-3 text-sm text-zinc-700 placeholder:text-zinc-400 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/20"
        [value]="rejectReason()" (input)="rejectReason.set($any($event.target).value)"></textarea>
    </div>
  </div>

  <div bottomSheetFooter class="border-t border-zinc-100 bg-white/90 px-6 pb-[calc(1.5rem+env(safe-area-inset-bottom))] pt-4 backdrop-blur">
    <div class="flex flex-col gap-3">
      <button type="button" class="h-14 w-full rounded-[18px] bg-red-600 text-base font-extrabold text-white shadow-lg shadow-red-500/20 transition-transform active:scale-[0.98]" (click)="submitReject()" [disabled]="rejecting()">
        @if (rejecting()) {
          <span class="flex items-center justify-center gap-2">
            <div class="h-4 w-4 animate-spin rounded-full border-2 border-white border-t-transparent"></div>
            {{ 'partners.offer.actions.busy' | translate }}
          </span>
