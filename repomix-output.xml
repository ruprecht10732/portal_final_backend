<file path="../portal_final/src/app/routes/catalog/vat-rates/vat-rates-list/vat-rates-list.component.html">
<section class="flex flex-col gap-6">
  <!-- Header -->
  <header class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-xl font-semibold text-zinc-900">{{ 'catalog.vatRates.title' | translate }}</h1>
      <p class="text-sm text-zinc-500">{{ 'catalog.vatRates.subtitle' | translate }}</p>
    </div>
    <shared-button
      variant="primary"
      (clicked)="openAddModal()"
      [ariaLabel]="'catalog.vatRates.addButton' | translate"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      {{ 'catalog.vatRates.addButton' | translate }}
    </shared-button>
  </header>

  <shared-data-grid
    [columns]="columns()"
    [data]="vatRateRows()"
    [loading]="loading()"
    [config]="gridConfig"
    (rowDoubleClick)="onRowDoubleClick($event)"
    (deleteRows)="onDeleteRows($event)"
    [ariaLabel]="'catalog.vatRates.title'"
  />
</section>

<!-- Add/Edit Modal -->
@if (isModalOpen()) {
  <div
    class="fixed inset-0 bg-black/50 z-60"
    (click)="closeModal()"
    (keydown.escape)="closeModal()"
    aria-hidden="true"
  ></div>

  <dialog
    open
    tabindex="-1"
    class="fixed inset-0 z-70 m-auto w-[calc(100%-2rem)] max-w-md border-0 bg-white p-0 shadow-xl rounded-lg"
    aria-modal="true"
    [attr.aria-labelledby]="'modal-title'"
    (keydown.escape)="closeModal()"
  >
    <div class="flex flex-col gap-4 p-6">
      <h2 id="modal-title" class="text-base font-bold uppercase tracking-tight text-zinc-900">
        {{ modalTitle() }}
      </h2>

      <form (ngSubmit)="saveRate()" class="flex flex-col gap-4">
        <shared-input
          [label]="'catalog.vatRates.form.name' | translate"
          [placeholder]="'catalog.vatRates.form.namePlaceholder' | translate"
          [(value)]="formName"
          [required]="true"
          [error]="formName() ? formNameError() : ''"
        />

        <shared-number-input
          [label]="'catalog.vatRates.form.rate' | translate"
          [placeholder]="'21'"
          [(value)]="formRate"
          [required]="true"
          [min]="0"
          [max]="100"
          [step]="0.01"
          suffix="%"
          [error]="formRate() !== null ? formRateError() : ''"
          [hint]="'catalog.vatRates.form.rateHint' | translate"
        />

        <div class="grid grid-cols-2 gap-3 pt-2">
          <shared-button
            type="button"
            variant="secondary"
            (clicked)="closeModal()"
          >
            {{ 'common.cancel' | translate }}
          </shared-button>
          <shared-button
            type="submit"
            variant="primary"
            [disabled]="!isFormValid()"
            [loading]="saving()"
          >
            {{ 'common.save' | translate }}
          </shared-button>
        </div>
      </form>
    </div>
  </dialog>
}

<!-- Delete Confirmation Dialog -->
<shared-confirm-dialog
  [isOpen]="isDeleteDialogOpen()"
  [title]="'catalog.vatRates.deleteTitle' | translate"
  [message]="'catalog.vatRates.deleteMessage' | translate:{name: pendingDeleteRate()?.name}"
  [confirmText]="'common.delete' | translate"
  [cancelText]="'common.cancel' | translate"
  confirmVariant="danger"
  [confirmDisabled]="saving()"
  (confirm)="confirmDelete()"
  (cancelled)="closeDeleteDialog()"
/>
