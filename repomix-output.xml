@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;500;600&display=swap');

.quote-intro {
	position: relative;
	min-height: 100vh;
	background: radial-gradient(circle at center, #1e293b 0%, #0b1120 100%);
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	font-family: Montserrat, sans-serif;
	overflow: hidden;
	perspective: 2500px;
	color: #e2e8f0;
}

.quote-intro::before {
	content: '';
	position: absolute;
	inset: 0;
	background:
		radial-gradient(1.5px 1.5px at 20% 30%, rgba(194, 163, 93, 0.15), transparent),
		radial-gradient(1px 1px at 60% 20%, rgba(194, 163, 93, 0.1), transparent),
		radial-gradient(1.5px 1.5px at 80% 60%, rgba(194, 163, 93, 0.12), transparent),
		radial-gradient(1px 1px at 40% 70%, rgba(194, 163, 93, 0.08), transparent),
		radial-gradient(1px 1px at 10% 80%, rgba(194, 163, 93, 0.1), transparent),
		radial-gradient(1.5px 1.5px at 90% 40%, rgba(194, 163, 93, 0.12), transparent);
	animation: stars-drift 20s ease-in-out infinite alternate;
	pointer-events: none;
	z-index: 0;
}

.quote-intro::after {
	content: '';
	position: absolute;
	inset: 0;
	background: radial-gradient(circle at center, transparent 30%, rgba(0, 0, 0, 0.4) 100%);
	pointer-events: none;
	z-index: 0;
}

@keyframes stars-drift {
	0% { transform: translateY(0) scale(1); }
	100% { transform: translateY(-8px) scale(1.03); }
}

.intro-skip {
	position: absolute;
	top: 24px;
	right: 24px;
	font-size: 11px;
	letter-spacing: 0.2em;
	text-transform: uppercase;
	background: #0f172a;
	border: 1px solid rgba(194, 163, 93, 0.3);
	color: #e5c78a;
	padding: 8px 16px;
	border-radius: 999px;
	cursor: pointer;
	z-index: 2;
	transition: all 0.3s ease;
	backdrop-filter: blur(4px);
}

.intro-skip:hover {
	background: #1a2332;
	border-color: #c2a35d;
	color: #e5c78a;
	box-shadow: 0 0 20px rgba(194, 163, 93, 0.1);
}

.intro-scene {
	position: relative;
	width: min(90vw, 380px);
	height: 340px;
	cursor: pointer;
	border: 0;
	background: transparent;
	padding: 0;
	font: inherit;
	color: inherit;
	display: flex;
	align-items: center;
	justify-content: center;
	transform-style: preserve-3d;
	z-index: 1;
	opacity: 0;
	transform: translateY(20px) scale(0.96);
}

.intro-envelope {
	position: relative;
	width: min(85vw, 320px);
	aspect-ratio: 320/220;
	height: auto;
	background: linear-gradient(165deg, #1e293b 0%, #1a2332 100%);
	transform-style: preserve-3d;
	box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.6);
	transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.4s ease;
	container-type: size;
}

.intro-scene:hover .intro-envelope {
	transform: translateY(-4px);
	box-shadow: 0 36px 70px -10px rgba(0, 0, 0, 0.7);
}

.intro-lid {
	position: absolute;
	top: 0;
	left: 0;
	width: 0;
	height: 0;
	border-left: 50cqw solid transparent;
	border-right: 50cqw solid transparent;
	border-top: 52cqh solid #334155;
	transform-origin: top;
	transform: translateZ(2px);
	backface-visibility: hidden;
	z-index: 10;
}

.intro-inner-shadow {
	position: absolute;
	inset: 0;
	background: linear-gradient(to bottom, rgba(0, 0, 0, 0.6), transparent 40%);
	transform: translateZ(0.1px);
	pointer-events: none;
}

.intro-pocket {
	position: absolute;
	inset: 0;
	transform: translateZ(1.5px);
	pointer-events: none;
}

.intro-pocket::before,
.intro-pocket::after {
	content: '';
	position: absolute;
	bottom: 0;
	width: 0;
	height: 0;
	border-top: 50cqh solid transparent;
	border-bottom: 50cqh solid #0f172a;
}

.intro-pocket::before {
	left: 0;
	border-left: 50cqw solid #0f172a;
}

.intro-pocket::after {
	right: 0;
	border-right: 50cqw solid #0f172a;
}

.intro-bottom-flap {
	position: absolute;
	bottom: 0;
	left: 0;
	width: 0;
	height: 0;
	border-left: 50cqw solid transparent;
	border-right: 50cqw solid transparent;
	border-bottom: 50cqh solid #1e293b;
	transform: translateZ(1.6px);
}

.intro-letter {
	position: absolute;
	top: 50%;
	left: 50%;

	/* Centering handled by GSAP xPercent/yPercent so transforms don't conflict */
	width: min(85vw, 320px);
	aspect-ratio: 210 / 297;
	height: auto;
	max-height: 80vh;
	background: #fdfbf7;
	padding: clamp(20px, 5vw, 40px) clamp(16px, 4vw, 28px) clamp(15px, 3.5vw, 30px);
	border-radius: 2px;
	display: flex;
	flex-direction: column;
	align-items: center;
	text-align: center;
	box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
	overflow: hidden;
	transform-style: preserve-3d;
	opacity: 0;

	/* Start behind envelope body (z=0) so it can't clip through */
	transform: translate(-50%, -50%) translateZ(-1px);

	/* Fully hidden — revealed by GSAP clip-path animation */
	clip-path: inset(0 0 100% 0);
}

.intro-letter-shine {
	position: absolute;
	top: 0;
	left: -150%;
	width: 100%;
	height: 100%;
	background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
	transform: skewX(-20deg);
	pointer-events: none;
}

.intro-letter::after {
	content: '';
	position: absolute;
	inset: 10px;
	border: 1px solid rgba(194, 163, 93, 0.15);
	pointer-events: none;
}

.intro-letter-eyebrow {
	font-size: 9px;
	letter-spacing: 0.32em;
	text-transform: uppercase;
	color: rgba(100, 116, 139, 0.7);
	font-weight: 600;
	margin-bottom: 10px;
}

.intro-letter h1 {
	font-family: 'Playfair Display', serif;
	font-size: clamp(16px, 5vw, 20px);
	color: #1e293b;
	margin-bottom: 8px;
	letter-spacing: 3px;
	text-transform: uppercase;
	font-weight: 700;
}

.intro-letter-divider {
	width: clamp(60px, 20vw, 90px);
	height: 1px;
	background: linear-gradient(90deg, transparent, rgba(194, 163, 93, 0.7), transparent);
	margin-bottom: clamp(10px, 3.5vw, 16px);
}

.intro-letter p {
	font-size: clamp(10px, 3.2vw, 12px);
	color: #475569;
	line-height: 1.5;
	font-weight: 400;
	max-width: 240px;
}

.intro-letter p span {
	display: block;
	margin-top: 4px;
}

.intro-letter-signature {
	margin-top: auto;
	font-size: 11px;
	color: #1f2937;
	font-weight: 600;
}

.intro-letter-footer {
	margin-top: 8px;
	font-size: 9px;
	color: #c2a35d;
	font-weight: 600;
	letter-spacing: 0.3em;
	text-transform: uppercase;
}

.intro-seal {
	position: absolute;
	top: 110px;
	left: 50%;
	transform: translate3d(-50%, -50%, 2.1px);
	width: 52px;
	height: 52px;
	background: radial-gradient(circle at 35% 35%, #e5c78a, #c2a35d 60%, #8b6e30);
	border-radius: 50%;
	box-shadow: inset 0 -2px 5px rgba(0, 0, 0, 0.3), inset 0 2px 2px rgba(255, 255, 255, 0.4),
		0 6px 15px rgba(0, 0, 0, 0.5);
	display: flex;
	align-items: center;
	justify-content: center;
	z-index: 11;
	animation: seal-pulse 2.5s ease-in-out infinite;
}

@keyframes seal-pulse {
	0%, 100% { box-shadow: inset 0 -2px 5px rgba(0,0,0,0.3), inset 0 2px 2px rgba(255,255,255,0.4), 0 6px 15px rgba(0,0,0,0.5), 0 0 0 0 rgba(194,163,93,0); }
	50% { box-shadow: inset 0 -2px 5px rgba(0,0,0,0.3), inset 0 2px 2px rgba(255,255,255,0.4), 0 6px 15px rgba(0,0,0,0.5), 0 0 28px 4px rgba(194,163,93,0.25); }
}

.intro-seal span {
	color: rgba(255, 255, 255, 0.85);
	font-family: 'Playfair Display', serif;
	font-weight: 700;
	font-size: 22px;
	text-shadow: 1px 1px 2px rgba(0, 0,  0, 0.3);
	pointer-events: none;
}

.intro-ground-shadow {
	position: absolute;
	bottom: -35px;
	left: 50%;
	transform: translateX(-50%);
	width: 280px;
	height: 25px;
	background: rgba(0, 0, 0, 0.6);
	filter: blur(20px);
	border-radius: 50%;
	z-index: -1;
	opacity: 0.6;
}

.intro-hint {
	margin-top: 40px;
	color: #c2a35d;
	text-transform: uppercase;
	letter-spacing: 6px;
	font-size: 10px;
	font-weight: 600;
	opacity: 0;
	transition: opacity 0.6s ease;
	text-align: center;
	z-index: 1;
}

.intro-hint.is-visible {
	opacity: 0.65;
}

.intro-hint.is-open {
	opacity: 0;
	pointer-events: none;
}

.intro-continue {
	position: fixed;
	bottom: 40px;
	left: 50%;
	transform: translateX(-50%) translateY(10px);
	font-size: 13px;
	letter-spacing: 0.2em;
	text-transform: uppercase;
	background: linear-gradient(135deg, #d4af61, #c2a35d);
	color: #0f172a;
	padding: 14px 28px;
	border-radius: 999px;
	border: none;
	cursor: pointer;
	box-shadow: 0 12px 30px -8px rgba(194, 163, 93, 0.5);
	font-weight: 600;
	z-index: 20;
	transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
	opacity: 0;
	animation: continue-appear 0.6s 0.15s ease forwards;
}

.intro-continue:hover {
	transform: translateX(-50%) translateY(-1px);
	box-shadow: 0 16px 36px -6px rgba(194, 163, 93, 0.65);
	background: linear-gradient(135deg, #e0be6e, #c2a35d);
}

.intro-continue:active {
	transform: translateX(-50%) translateY(0);
	box-shadow: 0 8px 20px -8px rgba(194, 163, 93, 0.5);
}

@keyframes continue-appear {
	to {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}
}

@media (max-width: 640px) {
	.intro-scene {
		width: 100vw;
		height: 380px; /* Slightly taller to accommodate taller intro-letter if needed */
		transform: translateY(10px) scale(0.92);
	}

	.intro-skip {
		top: 16px;
		right: 16px;
	}

	.intro-hint {
		margin-top: 20px;
		letter-spacing: 4px;
	}

	.intro-letter {
		width: min(88vw, 280px); /* Slightly narrower on small phones */
		padding: 24px 20px 20px;
	}

	.intro-continue {
		width: calc(100% - 48px);
		max-width: 320px;
		padding: 16px 20px;
		bottom: 30px;
	}
}

/* S24 Ultra and similar high-DPI large screens usually have high viewport sizes,
	but we should ensure we don't scale too large if height is limited */
@media (max-height: 700px) {
	.intro-scene {
		height: 280px;
		transform: scale(0.85);
	}
	.intro-hint {
		margin-top: 10px;
	}
}

@media (prefers-reduced-motion: reduce) {
	.intro-hint,
	.intro-continue {
		transition: none;
		animation: none;
		opacity: 1;
		transform: none;
	}

	.intro-seal {
		animation: none;
	}

	.intro-scene {
		opacity: 1;
		transform: none;
	}

	@keyframes stars-drift {
		0%, 100% { transform: none; }
	}
}
</file>

