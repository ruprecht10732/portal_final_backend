<div class="flex flex-col h-full pb-16 sm:pb-0">
  <div class="border-b border-zinc-200">
    <shared-page-header
      [title]="partner()?.businessName ?? ('partners.detail.title' | translate)"
      [subtitle]="'partners.detail.subtitle' | translate"
      [backAriaLabel]="'partners.detail.goBack' | translate"
      (back)="goBack()"
    >
      @if (partner()) {
        <ng-container actions>
          <div class="flex items-center gap-2">
            <shared-button
              variant="secondary"
              size="compact"
              [fullWidth]="false"
              (clicked)="editPartner()"
            >
              <lucide-icon name="pencil" class="h-4 w-4 mr-2" aria-hidden="true"></lucide-icon>
              {{ 'partners.detail.edit' | translate }}
            </shared-button>
            <shared-button
              variant="danger"
              size="compact"
              [fullWidth]="false"
              (clicked)="openDeleteDialog()"
            >
              <lucide-icon name="trash-2" class="h-4 w-4 mr-2" aria-hidden="true"></lucide-icon>
              {{ 'partners.detail.delete' | translate }}
            </shared-button>
          </div>
        </ng-container>
      }
    </shared-page-header>
  </div>

  <!-- Mobile actions -->
  @if (partner()) {
    <div class="sm:hidden border-b border-gray-100 bg-white px-5 py-3">
      <div class="grid grid-cols-2 gap-2">
        <shared-button variant="secondary" size="compact" [fullWidth]="true" (clicked)="editPartner()">
          <lucide-icon name="pencil" class="h-4 w-4"></lucide-icon>
          {{ 'partners.detail.edit' | translate }}
        </shared-button>
        <shared-button variant="danger" size="compact" [fullWidth]="true" (clicked)="openDeleteDialog()">
          <lucide-icon name="trash-2" class="h-4 w-4"></lucide-icon>
          {{ 'partners.detail.delete' | translate }}
        </shared-button>
      </div>
    </div>
  }

  @if (error()) {
    <div class="flex-1 flex flex-col items-center justify-center p-12 gap-4">
      <p class="text-sm text-zinc-600">{{ error() }}</p>
      <shared-button variant="secondary" [fullWidth]="false" (clicked)="goBack()">
        {{ 'partners.detail.goBack' | translate }}
      </shared-button>
    </div>
  } @else if (loading()) {
    <div class="flex-1 flex flex-col items-center justify-center p-12 gap-4">
      <div class="animate-spin h-10 w-10 border-4 border-zinc-100 border-t-black"></div>
      <p class="text-xs font-mono uppercase text-zinc-400">{{ 'partners.detail.loading' | translate }}</p>
    </div>
  } @else if (partner(); as p) {
    <div class="flex-1 overflow-y-auto">
      <div class="w-full p-4 sm:p-6 lg:p-8 overflow-x-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.6fr)_minmax(0,1fr)] gap-6">
          <div class="flex flex-col gap-6">
            <app-partner-detail-hero-card
              [businessName]="p.businessName"
              [contactEmail]="p.contactEmail"
              [logoPreviewUrl]="logoPreviewUrl()"
              [logoDownloadUrl]="logoDownloadUrl()"
              [logoInitials]="logoInitials()"
              [logoImageError]="logoImageError()"
              [logoError]="logoError()"
              [createdAt]="formatDate(p.createdAt)"
              [updatedAt]="formatDate(p.updatedAt)"
              (logoFailed)="logoImageError.set(true)"
            />

            <app-partner-detail-company-card
              [titleKey]="'partners.detail.companyInfo'"
              [rows]="companyRows()"
              [editingKey]="editingField()"
              [editValue]="editValue()"
              (startEdit)="startEditFromEvent($event)"
              (cancelEdit)="cancelEdit()"
              (saveEdit)="saveEditFromEvent($event)"
              (editValueChange)="editValue.set($event)"
            />
          </div>

          <div class="flex flex-col gap-6">
            <app-partner-detail-contact-card
              [titleKey]="'partners.detail.contactInfo'"
              [rows]="contactRows()"
              [editingKey]="editingField()"
              [editValue]="editValue()"
              [whatsappUrl]="whatsappUrl()"
              [phoneUrl]="contactPhoneUrl()"
              [emailUrl]="contactEmailUrl()"
              (startEdit)="startEditFromEvent($event)"
              (cancelEdit)="cancelEdit()"
              (saveEdit)="saveEditFromEvent($event)"
              (editValueChange)="editValue.set($event)"
              (openWhatsApp)="openWhatsApp()"
              (openCall)="openCall()"
              (openEmail)="openEmail()"
            />

            <app-partner-detail-address-card
              [titleKey]="'partners.detail.address'"
              [rows]="addressRows()"
              [editingKey]="editingField()"
              [editValue]="editValue()"
              [mapAddress]="mapAddress()"
              [latitude]="mapLatitude()"
              [longitude]="mapLongitude()"
              [googleMapsUrl]="googleMapsUrl()"
              (startEdit)="startEditFromEvent($event)"
              (cancelEdit)="cancelEdit()"
              (saveEdit)="saveEditFromEvent($event)"
              (editValueChange)="editValue.set($event)"
              (addressSelect)="applyAddressSuggestion($event)"
              (openGoogleMaps)="openGoogleMaps()"
            />

            <app-partner-detail-services-card
              [serviceTypeIds]="p.serviceTypeIds ?? []"
              [serviceTypeLabels]="serviceTypeLabels()"
              [serviceTypesLoading]="serviceTypesLoading()"
              [serviceTypesError]="serviceTypesError()"
              [serviceTypesEditing]="serviceTypesEditing()"
              [serviceTypesSaving]="serviceTypesSaving()"
              [serviceTypeOptions]="serviceTypeOptions()"
              [serviceTypeSelection]="serviceTypeSelection()"
              (openEdit)="openServiceTypesEdit()"
              (closeEdit)="closeServiceTypesEdit()"
              (saveEdit)="saveServiceTypes()"
              (removeServiceType)="removeServiceType($event)"
              (selectionChange)="serviceTypeSelection.set($event)"
            />

            <app-partner-detail-offers-card
              [offers]="partnerOffers()"
              [loading]="offersLoading()"
              [error]="offersError()"
              [partnerPhone]="p.contactPhone"
              [partnerName]="p.businessName"
              (refresh)="refreshOffers()"
            />
          </div>
        </div>
      </div>
    </div>
  }

  <shared-confirm-dialog
    [isOpen]="showDeleteDialog()"
    [title]="'partners.detail.deleteConfirmTitle' | translate"
    [message]="'partners.detail.deleteConfirmMessage' | translate"
    [confirmText]="'partners.detail.deleteConfirm' | translate"
    [cancelText]="'partners.detail.deleteCancel' | translate"
    confirmVariant="danger"
    [confirmDisabled]="deleting()"
    (confirm)="confirmDelete()"
    (cancelled)="closeDeleteDialog()"
  />
</div>
</file>

