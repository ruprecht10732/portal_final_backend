<div class="flex flex-col w-full h-full pb-16 sm:pb-0">
  @if (!isModal()) {
    <shared-page-header
      [title]="'appointments.form.title' | translate"
      [backAriaLabel]="'common.back' | translate"
      (back)="goBack()"
    ></shared-page-header>
  }

  @if (error()) {
    <div class="bg-red-50 border-b border-red-500 text-red-900 p-4 text-sm font-medium flex items-start gap-3">
      <span class="font-bold uppercase text-red-600 shrink-0">{{ 'common.error' | translate }}</span>
      <span>{{ error() }}</span>
    </div>
  }

  <form (ngSubmit)="createAppointment()" class="flex-1 flex flex-col">
    <div class="grid grid-cols-1 lg:grid-cols-2 w-full border-b border-zinc-200">
      <!-- Section 1: Basic Info -->
      <section class="p-4 sm:p-6 border-b lg:border-b-0 lg:border-r border-zinc-200">
        <div class="flex items-center gap-3 mb-6">
          <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">01</span>
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
            {{ 'appointments.form.basicInfo' | translate }}
          </h2>
        </div>
        
        <div class="space-y-5">
          <shared-select
            [label]="'appointments.form.type' | translate"
            [options]="typeOptions"
            [value]="type()"
            (valueChange)="type.set($event!)"
            [required]="true"
          />

          <!-- Lead Selection (only for lead_visit) -->
          @if (isLeadVisit()) {
            <div class="space-y-4 p-4 bg-zinc-50 border border-zinc-200 rounded-lg">
              <div class="text-xs font-bold uppercase tracking-widest text-zinc-500">
                {{ 'appointments.form.leadSelection' | translate }}
              </div>

              @if (selectedLead(); as lead) {
                <!-- Selected lead card -->
                <div class="flex items-start justify-between gap-4 p-4 bg-white border border-zinc-200 rounded-lg">
                  <div class="flex flex-col gap-1">
                    <span class="font-semibold text-zinc-900">
                      {{ lead.consumer.firstName }} {{ lead.consumer.lastName }}
                    </span>
                    <span class="text-sm text-zinc-500">
                      {{ lead.address.street }} {{ lead.address.houseNumber }}, {{ lead.address.zipCode }} {{ lead.address.city }}
                    </span>
                    @if (lead.consumer.phone) {
                      <span class="text-sm text-zinc-400">{{ lead.consumer.phone }}</span>
                    }
                  </div>
                  <button
                    type="button"
                    (click)="clearLead()"
                    class="text-zinc-400 hover:text-zinc-600 p-1"
                    [attr.aria-label]="'appointments.form.changeLead' | translate"
                  >
                    <lucide-icon name="x" class="h-4 w-4"></lucide-icon>
                  </button>
                </div>

                <!-- Service Selection -->
                @if (leadServiceOptions().length > 0) {
                  <shared-select
                    [label]="'appointments.form.service' | translate"
                    [options]="leadServiceOptions()"
                    [value]="selectedLeadServiceId()"
                    (valueChange)="selectedLeadServiceId.set($event)"
                    [required]="true"
                  />
                }
              } @else {
                <!-- Lead search -->
                <shared-autocomplete
                  [label]="''"
                  [placeholder]="'appointments.form.searchLeadPlaceholder' | translate"
                  [value]="leadSearchQuery()"
                  (valueChange)="onLeadSearchChange($event); onLeadSelected($event)"
                  [options]="leadOptions()"
                  filterMode="manual"
                />
              }
            </div>
          }

          <shared-input
            [label]="'appointments.form.titleLabel' | translate"
            [placeholder]="'appointments.form.titlePlaceholder' | translate"
            [value]="title()"
            (valueChange)="title.set($event)"
            [required]="true"
          />

          <shared-textarea
            [label]="'appointments.form.description' | translate"
            [placeholder]="'appointments.form.descriptionPlaceholder' | translate"
            [rows]="3"
            [value]="description()"
            (valueChange)="description.set($event)"
          />

          <shared-autocomplete
            [label]="'appointments.form.location' | translate"
            [placeholder]="'appointments.form.locationPlaceholder' | translate"
            [value]="location()"
            (valueChange)="onLocationChange($event)"
            [options]="locationOptions()"
            [filterMode]="'manual'"
          />

          <shared-input
            [label]="'appointments.form.meetingLink' | translate"
            [placeholder]="'appointments.form.meetingLinkPlaceholder' | translate"
            [value]="meetingLink()"
            (valueChange)="meetingLink.set($event)"
            type="url"
          />
        </div>
      </section>

      <!-- Section 2: Date & Time -->
      <section class="p-4 sm:p-6">
        <div class="flex items-center gap-3 mb-6">
          <span class="bg-black text-white text-xs font-bold px-1.5 py-0.5">02</span>
          <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">
            {{ 'appointments.form.scheduling' | translate }}
          </h2>
        </div>

        <div class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <shared-input
              [label]="'appointments.form.startTime' | translate"
              type="datetime-local"
              [value]="startTime()"
              (valueChange)="startTime.set($event)"
              [required]="true"
              [clearable]="false"
            />
            <shared-input
              [label]="'appointments.form.endTime' | translate"
              type="datetime-local"
              [value]="endTime()"
              (valueChange)="endTime.set($event)"
              [required]="true"
              [clearable]="false"
            />
          </div>

          <shared-checkbox
            [label]="'appointments.form.allDay' | translate"
            [checked]="allDay()"
            (checkedChange)="allDay.set($event)"
          />

          @if (isLeadVisit()) {
            <shared-checkbox
              [label]="'appointments.form.sendConfirmation' | translate"
              [checked]="sendConfirmationEmail()"
              (checkedChange)="sendConfirmationEmail.set($event)"
            />
          }
        </div>
      </section>
    </div>

    <!-- Footer -->
    <div class="p-4 sm:p-6 flex flex-col-reverse sm:flex-row sm:justify-end gap-3 sm:gap-4">
      <shared-button 
        variant="secondary" 
        type="button" 
        [disabled]="saving()"
        (clicked)="goBack()"
        class="w-full sm:w-auto"
      >
        {{ 'common.cancel' | translate }}
      </shared-button>
      
      <shared-button
        variant="primary"
        type="submit"
        [disabled]="saving() || !canCreate()"
        class="w-full sm:w-auto"
      >
        {{ saving() ? ('common.saving' | translate) : ('appointments.form.create' | translate) }}
      </shared-button>
    </div>
  </form>
</div>
</file>

