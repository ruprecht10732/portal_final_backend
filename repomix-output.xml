  });

  protected readonly containerClass = computed(() => {
    const classes = [
      'bg-white',
      'border',
      'border-zinc-200',
      'rounded-xl',
      this.paddingClass(),
      this.variant(),
      this.className(),
    ].filter(Boolean);
    return classes.join(' ');
  });
}
